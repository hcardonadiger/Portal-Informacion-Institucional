@page
@model Diger.TramitesEstado.Web.Pages.Reuniones.CompromisosModel
@{
    ViewData["Title"] = "Seguimiento de compromisos";
    var r = Model.Resultado;
    var res = r.Resumen;
}

<div class="container" style="max-width:1180px">
    @if (TempData["SuccessMsg"] is string ok)
    {
        <div class="alert-ok" style="margin-bottom:1rem">✅ @ok</div>
    }
    <div class="hist-header">
        <div>
            <h2>Seguimiento de compromisos</h2>
            <p>Acuerdos de todas las reuniones y su estado de cumplimiento</p>
        </div>
        <div style="display:flex;gap:8px">
            <button type="button" class="btns" id="btn-toggle-vista" onclick="toggleVistaCompromisos()">🗂 Vista por institución</button>
            <a class="btns" asp-page="/Reuniones/Index">← Reuniones</a>
        </div>
    </div>

    @* ── KPIs ──────────────────────────────────────────────────── *@
    <div class="row2" style="grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:1.25rem">
        <a class="card kpi-link" style="margin:0;text-align:center" asp-page="/Reuniones/Compromisos">
            <div style="font-size:24px;font-weight:800;color:#0a2d6e">@res.Total</div>
            <div class="prog-label">Total</div>
        </a>
        <a class="card kpi-link" style="margin:0;text-align:center" asp-page="/Reuniones/Compromisos" asp-route-estado="@EstadoCompromiso.Pendiente">
            <div style="font-size:24px;font-weight:800;color:#0c447c">@res.Pendientes</div>
            <div class="prog-label">Pendientes</div>
        </a>
        <a class="card kpi-link" style="margin:0;text-align:center" asp-page="/Reuniones/Compromisos" asp-route-estado="@EstadoCompromiso.EnProgreso">
            <div style="font-size:24px;font-weight:800;color:#854f0b">@res.EnProgreso</div>
            <div class="prog-label">En progreso</div>
        </a>
        <a class="card kpi-link" style="margin:0;text-align:center" asp-page="/Reuniones/Compromisos" asp-route-soloVencidos="true">
            <div style="font-size:24px;font-weight:800;color:#a32d2d">@res.Vencidos</div>
            <div class="prog-label">Vencidos</div>
        </a>
        <a class="card kpi-link" style="margin:0;text-align:center" asp-page="/Reuniones/Compromisos" asp-route-estado="@EstadoCompromiso.Cumplido">
            <div style="font-size:24px;font-weight:800;color:#27500a">@res.Cumplidos</div>
            <div class="prog-label">Cumplidos</div>
        </a>
    </div>

    @* ── Filtros ───────────────────────────────────────────────── *@
    <form method="get" class="card" style="padding:.9rem 1rem;margin-bottom:1.1rem;display:flex;gap:14px;flex-wrap:wrap;align-items:flex-end">
        <div class="field" style="margin:0;min-width:150px">
            <label>Estado</label>
            <select name="estado" onchange="this.form.submit()">
                <option value="">Todos</option>
                @foreach (var e in CompromisoUi.Estados)
                {
                    <option value="@e" selected="@(Model.Estado == e)">@CompromisoUi.Label(e)</option>
                }
            </select>
        </div>
        <div class="field" style="margin:0;min-width:170px">
            <label>Institución</label>
            <select name="institucionId" onchange="this.form.submit()">
                <option value="">Todas</option>
                @foreach (var i in Model.Instituciones)
                {
                    <option value="@i.Id" selected="@(Model.InstitucionId == i.Id)">@i.Nombre</option>
                }
            </select>
        </div>
        <div class="field" style="margin:0;min-width:160px">
            <label>Responsable</label>
            <input name="responsable" value="@Model.Responsable" list="responsables-list" placeholder="Nombre…" />
            <datalist id="responsables-list">
                @foreach (var nom in r.Responsables) { <option value="@nom"></option> }
            </datalist>
        </div>
        <div class="field" style="margin:0;min-width:190px;flex:1">
            <label>Buscar</label>
            <input type="search" name="q" value="@Model.Q" placeholder="Compromiso, responsable, reunión…" />
        </div>
        <label class="chk" style="margin:0 0 .45rem">
            <input type="checkbox" name="soloVencidos" value="true" checked="@Model.SoloVencidos" onchange="this.form.submit()" />
            <span>Solo vencidos</span>
        </label>
        <button class="btnp" type="submit" style="margin-bottom:.45rem">Filtrar</button>
        <a class="btns" asp-page="/Reuniones/Compromisos" style="margin-bottom:.45rem">Limpiar</a>
    </form>

    @if (r.Pagina.Total == 0)
    {
        <div class="hist-empty">
            <div class="ico">📌</div>
            <p>No hay compromisos que coincidan.</p>
        </div>
    }
    else
    {
        <div id="vista-lista">
        <table class="seg-table">
            <thead>
                <tr>
                    <th>Compromiso</th>
                    <th>Reunión</th>
                    <th>Institución</th>
                    <th>Responsable</th>
                    <th>Plazo</th>
                    <th>Estado</th>
                    @if (Model.PuedeGestionar) { <th style="width:1%"></th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var c in r.Pagina.Items)
                {
                    var ec = CompromisoUi.Color(c.Estado);
                    <tr>
                        <td style="font-weight:600;color:#0a2d6e">
                            @c.Compromiso
                            @if (!string.IsNullOrWhiteSpace(c.NotaSeguimiento))
                            {
                                <div class="res-meta" style="font-weight:400;margin-top:2px">💬 @c.NotaSeguimiento</div>
                            }
                        </td>
                        <td><a class="seg-inst" asp-page="/Reuniones/Acta" asp-route-id="@c.ReunionId">@c.ReunionTitulo</a>
                            <div class="res-meta">@(c.ReunionFecha?.ToString("dd MMM yyyy") ?? "")</div>
                        </td>
                        <td class="res-meta">@(c.Institucion ?? "—")</td>
                        <td class="res-meta">@(c.Responsable ?? "—")</td>
                        <td style="white-space:nowrap">
                            @(c.Plazo?.ToString("dd MMM yyyy") ?? "—")
                            @if (c.Vencido)
                            {
                                <span style="background:@CompromisoUi.Vencido.bg;color:@CompromisoUi.Vencido.fg;border-radius:20px;padding:1px 8px;font-size:11px;font-weight:700;display:inline-block;margin-top:2px">Vencido</span>
                            }
                            @if (c.Estado == EstadoCompromiso.Cumplido && c.FechaCumplimiento is not null)
                            {
                                <div class="res-meta">✓ @c.FechaCumplimiento.Value.ToString("dd MMM yyyy")</div>
                            }
                        </td>
                        <td><span style="background:@ec.bg;color:@ec.fg;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:700">@CompromisoUi.Label(c.Estado)</span></td>
                        @if (Model.PuedeGestionar)
                        {
                            <td style="text-align:right">
                                <details class="seg-upd">
                                    <summary class="btns" style="font-size:12.5px;padding:6px 12px">Actualizar</summary>
                                    <form method="post" asp-page-handler="Actualizar" class="seg-upd-form">
                                        <input type="hidden" name="id" value="@c.Id" />
                                        @* preservar filtros *@
                                        <input type="hidden" name="q" value="@Model.Q" />
                                        <input type="hidden" name="festado" value="@(Model.Estado?.ToString())" />
                                        <input type="hidden" name="finstitucionId" value="@(Model.InstitucionId?.ToString())" />
                                        <input type="hidden" name="fresponsable" value="@Model.Responsable" />
                                        <input type="hidden" name="fsoloVencidos" value="@Model.SoloVencidos.ToString().ToLowerInvariant()" />
                                        <input type="hidden" name="fpage" value="@r.Pagina.Page" />
                                        <label>Estado</label>
                                        <select name="estado">
                                            @foreach (var e in CompromisoUi.Estados)
                                            {
                                                <option value="@e" selected="@(c.Estado == e)">@CompromisoUi.Label(e)</option>
                                            }
                                        </select>
                                        <label>Fecha de cumplimiento</label>
                                        <input type="date" name="fechaCumplimiento" value="@(c.FechaCumplimiento?.ToString("yyyy-MM-dd"))" />
                                        <label>Nota de seguimiento</label>
                                        <textarea name="nota" rows="2" placeholder="Avance / observación…">@c.NotaSeguimiento</textarea>
                                        <button class="btnp" type="submit" style="margin-top:.5rem">Guardar</button>
                                    </form>
                                </details>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>

        <partial name="_Paginacion" model="new PaginacionVm(r.Pagina.Page, r.Pagina.TotalPages, r.Pagina.Total, r.Pagina.Desde, r.Pagina.Hasta)" />
        </div>

        @* ── Vista agrupada por institución ───────────────────────── *@
        <div id="vista-agrupada" style="display:none">
            @foreach (var grupo in Model.Todos.GroupBy(c => c.Institucion ?? "Sin institución").OrderBy(g => g.Key))
            {
                <div class="grupo-inst">
                    <div class="grupo-inst-hdr" onclick="toggleGrupoInst(this)">
                        <span>🏛</span>
                        <strong>@grupo.Key</strong>
                        <span class="grupo-inst-badge">@grupo.Count() compromiso@(grupo.Count() == 1 ? "" : "s")</span>
                        <span class="grupo-inst-chevron">▾</span>
                    </div>
                    <div class="grupo-inst-body">
                        <table class="seg-table">
                            <thead>
                                <tr>
                                    <th>Compromiso</th>
                                    <th>Reunión</th>
                                    <th>Responsable</th>
                                    <th>Plazo</th>
                                    <th>Estado</th>
                                    @if (Model.PuedeGestionar) { <th style="width:1%"></th> }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in grupo)
                                {
                                    var ec = CompromisoUi.Color(c.Estado);
                                    <tr>
                                        <td style="font-weight:600;color:#0a2d6e">
                                            @c.Compromiso
                                            @if (!string.IsNullOrWhiteSpace(c.NotaSeguimiento))
                                            {
                                                <div class="res-meta" style="font-weight:400;margin-top:2px">💬 @c.NotaSeguimiento</div>
                                            }
                                        </td>
                                        <td><a class="seg-inst" asp-page="/Reuniones/Acta" asp-route-id="@c.ReunionId">@c.ReunionTitulo</a>
                                            <div class="res-meta">@(c.ReunionFecha?.ToString("dd MMM yyyy") ?? "")</div>
                                        </td>
                                        <td class="res-meta">@(c.Responsable ?? "—")</td>
                                        <td style="white-space:nowrap">
                                            @(c.Plazo?.ToString("dd MMM yyyy") ?? "—")
                                            @if (c.Vencido)
                                            {
                                                <span style="background:@CompromisoUi.Vencido.bg;color:@CompromisoUi.Vencido.fg;border-radius:20px;padding:1px 8px;font-size:11px;font-weight:700;display:inline-block;margin-top:2px">Vencido</span>
                                            }
                                            @if (c.Estado == EstadoCompromiso.Cumplido && c.FechaCumplimiento is not null)
                                            {
                                                <div class="res-meta">✓ @c.FechaCumplimiento.Value.ToString("dd MMM yyyy")</div>
                                            }
                                        </td>
                                        <td><span style="background:@ec.bg;color:@ec.fg;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:700">@CompromisoUi.Label(c.Estado)</span></td>
                                        @if (Model.PuedeGestionar)
                                        {
                                            <td style="text-align:right">
                                                <details class="seg-upd">
                                                    <summary class="btns" style="font-size:12.5px;padding:6px 12px">Actualizar</summary>
                                                    <form method="post" asp-page-handler="Actualizar" class="seg-upd-form">
                                                        <input type="hidden" name="id" value="@c.Id" />
                                                        @* preservar filtros *@
                                                        <input type="hidden" name="q" value="@Model.Q" />
                                                        <input type="hidden" name="festado" value="@(Model.Estado?.ToString())" />
                                                        <input type="hidden" name="finstitucionId" value="@(Model.InstitucionId?.ToString())" />
                                                        <input type="hidden" name="fresponsable" value="@Model.Responsable" />
                                                        <input type="hidden" name="fsoloVencidos" value="@Model.SoloVencidos.ToString().ToLowerInvariant()" />
                                                        <input type="hidden" name="fpage" value="@r.Pagina.Page" />
                                                        <label>Estado</label>
                                                        <select name="estado">
                                                            @foreach (var e in CompromisoUi.Estados)
                                                            {
                                                                <option value="@e" selected="@(c.Estado == e)">@CompromisoUi.Label(e)</option>
                                                            }
                                                        </select>
                                                        <label>Fecha de cumplimiento</label>
                                                        <input type="date" name="fechaCumplimiento" value="@(c.FechaCumplimiento?.ToString("yyyy-MM-dd"))" />
                                                        <label>Nota de seguimiento</label>
                                                        <textarea name="nota" rows="2" placeholder="Avance / observación…">@c.NotaSeguimiento</textarea>
                                                        <button class="btnp" type="submit" style="margin-top:.5rem">Guardar</button>
                                                    </form>
                                                </details>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
    function toggleVistaCompromisos() {
        var lista = document.getElementById('vista-lista');
        var agrupada = document.getElementById('vista-agrupada');
        var btn = document.getElementById('btn-toggle-vista');
        if (!lista || !agrupada) return;
        var enLista = agrupada.style.display === 'none';
        lista.style.display = enLista ? 'none' : '';
        agrupada.style.display = enLista ? '' : 'none';
        btn.textContent = enLista ? '📋 Vista de lista' : '🗂 Vista por institución';
    }
    function toggleGrupoInst(hdr) {
        var body = hdr.nextElementSibling;
        var chevron = hdr.querySelector('.grupo-inst-chevron');
        var abierto = body.style.display !== 'none';
        body.style.display = abierto ? 'none' : '';
        chevron.style.transform = abierto ? 'rotate(-90deg)' : 'rotate(0deg)';
    }
</script>
