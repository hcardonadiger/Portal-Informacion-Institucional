@page "{id:int}"
@model Diger.TramitesEstado.Web.Pages.Reuniones.ActaModel
@{
    var d = Model.Datos;
    var esCap = d.EsCapacitacionPlataforma;
    ViewData["Title"] = "Acta — " + d.Titulo;

    static IEnumerable<string> Lineas(string? s) =>
        string.IsNullOrWhiteSpace(s)
            ? Enumerable.Empty<string>()
            : s.Replace("\r\n", "\n").Split('\n').Select(x => x.Trim()).Where(x => x.Length > 0);

    static bool Hay(string? s) => !string.IsNullOrWhiteSpace(s);

    // Sanitización ligera para el HTML del editor enriquecido (contenido interno):
    // elimina scripts/estilos/iframes, manejadores on*= y URLs javascript:.
    static string SanitizarHtml(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return "";
        var s = System.Text.RegularExpressions.Regex.Replace(html,
            @"<(script|style|iframe|object|embed|link|meta)[^>]*>.*?</\1>|<(script|style|iframe|object|embed|link|meta)[^>]*/?>",
            "", System.Text.RegularExpressions.RegexOptions.IgnoreCase | System.Text.RegularExpressions.RegexOptions.Singleline);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\son\w+\s*=\s*(""[^""]*""|'[^']*'|[^\s>]+)", "",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"javascript:", "", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        return s;
    }
}

<div class="acta-toolbar">
    <a class="btns" asp-page="/Reuniones/Index">← Volver</a>
    <div style="display:flex;gap:8px">
        @if (Model.EsAdmin)
        {
            <a class="btns" asp-page="/Reuniones/Editor" asp-route-id="@Model.ReunionId">Editar</a>
        }
        <a class="btnp" asp-page-handler="Pdf" asp-route-id="@Model.ReunionId">⬇ Descargar PDF</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success hilo-panel" style="max-width:900px;margin:0 auto 1rem">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-error hilo-panel" style="max-width:900px;margin:0 auto 1rem">@TempData["ErrorMessage"]</div>
}

<section class="card hilo-panel" style="max-width:900px;margin:0 auto 1.25rem">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:.9rem">
        <h3 class="cuenta-card-title" style="margin:0;border:0;padding:0">🔗 Hilo de reuniones</h3>
        @if (Model.Hilo.HiloId is Guid hid)
        {
            <a class="btnp" asp-page="/Reuniones/Hilo" asp-route-id="@hid">Ver hilo completo →</a>
        }
    </div>

    @if (Model.Hilo.HiloId is null)
    {
        <p style="color:var(--diger-text-muted);font-size:13px;margin:0">
            Esta reunión no está enlazada a ningún hilo. Enlázala con otra reunión para dar
            seguimiento a las acciones y tareas ejecutadas a lo largo del tiempo.
        </p>
    }
    else
    {
        <p style="color:var(--diger-text-muted);font-size:13px;margin:0 0 .5rem">
            Reuniones enlazadas en este hilo (@(Model.Hilo.Otras.Count + 1)):
        </p>
        <ul class="hilo-linked">
            @foreach (var m in Model.Hilo.Otras)
            {
                <li>
                    <a asp-page="/Reuniones/Acta" asp-route-id="@m.Id">@m.Titulo</a>
                    <span>@(m.Fecha?.ToString("dd/MM/yyyy") ?? "sin fecha")@(string.IsNullOrWhiteSpace(m.Institucion) ? "" : " · " + m.Institucion)</span>
                </li>
            }
        </ul>
        @if (Model.EsAdmin)
        {
            <form method="post" asp-page-handler="Desenlazar" asp-route-id="@Model.ReunionId" style="margin-top:.6rem">
                <button type="submit" class="btns" style="color:var(--diger-danger);border-color:#fca5a5"
                        onclick="return confirm('¿Quitar esta reunión del hilo?')">Quitar esta reunión del hilo</button>
            </form>
        }
    }

    @if (Model.EsAdmin)
    {
        <form method="post" asp-page-handler="Enlazar" asp-route-id="@Model.ReunionId"
              style="margin-top:1rem;border-top:1px solid var(--diger-border);padding-top:1rem">
            <label style="display:block;font-size:13px;font-weight:600;color:var(--diger-text-secondary);margin-bottom:6px">
                Enlazar con otra reunión
            </label>
            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
                <select name="otraReunionId" style="flex:1;min-width:260px;padding:9px 12px;border:1.5px solid var(--diger-border);border-radius:9px;font-family:inherit;font-size:14px;background:var(--diger-bg-soft)">
                    <option value="0">— Seleccione una reunión —</option>
                    @foreach (var e in Model.Enlazables)
                    {
                        <option value="@e.Id">@e.Titulo@(e.Fecha is null ? "" : " (" + e.Fecha.Value.ToString("dd/MM/yyyy") + ")")</option>
                    }
                </select>
                <button type="submit" class="btnp">Enlazar</button>
            </div>
            @if (Model.Enlazables.Count == 0)
            {
                <p style="color:var(--diger-text-faint);font-size:12px;margin:.5rem 0 0">No hay otras reuniones disponibles para enlazar.</p>
            }
        </form>
    }
</section>

<article class="acta">
    <header class="acta-head">
        <div class="acta-brand"><span class="acta-logo">DG</span> DIGER</div>
        <div class="acta-kind">@(esCap ? "Acta de Capacitación" : "Acta de Reunión")</div>
    </header>

    <h1 class="acta-title">@d.Titulo</h1>

    <section class="acta-meta">
        @if (d.Fecha is not null) { <div><span>Fecha</span>@d.Fecha.Value.ToString("dd 'de' MMMM 'de' yyyy")</div> }
        @if (Hay(d.Hora)) { <div><span>Hora</span>@d.Hora</div> }
        @if (Hay(d.Duracion)) { <div><span>Duración</span>@d.Duracion</div> }
        @if (Hay(d.Modalidad)) { <div><span>Modalidad</span>@d.Modalidad</div> }
        @if (Hay(d.Tipo)) { <div><span>Tipo</span>@d.Tipo</div> }
        @if (Model.InstitucionesParticipantes.Count == 0 && Hay(Model.InstitucionNombre)) { <div><span>Institución</span>@Model.InstitucionNombre</div> }
        @if (Hay(d.Lugar)) { <div><span>Lugar</span>@d.Lugar</div> }
    </section>

    @if (Model.InstitucionesParticipantes.Count > 0)
    {
        <section class="acta-sec">
            <h2>Instituciones convocadas <span class="acta-count">@Model.InstitucionesParticipantes.Count</span></h2>
            <div style="display:flex;flex-wrap:wrap;gap:6px">
                @foreach (var inst in Model.InstitucionesParticipantes)
                {
                    <span style="background:#eef3fc;border:1px solid #cfe0fb;border-radius:20px;padding:3px 12px;font-size:13px;color:#0a2d6e">@inst.Nombre</span>
                }
            </div>
        </section>
    }

    @if (Hay(d.ObjetivoAgenda) || Hay(d.Desarrollo))
    {
        <section class="acta-sec">
            <h2>Memoria de la reunión</h2>
            @if (Hay(d.ObjetivoAgenda)) { <h3>Objetivo / agenda</h3> <p>@d.ObjetivoAgenda</p> }
            @if (Hay(d.Desarrollo)) { <h3>Desarrollo</h3> <div class="acta-rte">@Html.Raw(SanitizarHtml(d.Desarrollo))</div> }
        </section>
    }

    @if (esCap && (Hay(d.Tema) || Hay(d.ObjetivoCap) || Hay(d.Contenido)))
    {
        <section class="acta-sec">
            <h2>Detalle de capacitación</h2>
            @if (Hay(d.Tema)) { <h3>Tema</h3> <p>@d.Tema</p> }
            @if (Hay(d.ObjetivoCap)) { <h3>Objetivo</h3> <p>@d.ObjetivoCap</p> }
            @if (Lineas(d.Contenido).Any())
            {
                <h3>Contenido</h3>
                <ul>@foreach (var l in Lineas(d.Contenido)) { <li>@l</li> }</ul>
            }
        </section>
    }

    @if (Hay(d.EpNombre) || Hay(d.FacNombre))
    {
        <section class="acta-sec acta-cols">
            @if (Hay(d.EpNombre))
            {
                <div>
                    <h2>Enlace institucional</h2>
                    <p class="acta-person">
                        <strong>@d.EpNombre</strong>
                        @if (Hay(d.EpCargo)) { <br/> @d.EpCargo }
                        @if (Hay(d.EpCorreo)) { <br/> @d.EpCorreo }
                        @if (Hay(d.EpTel)) { <br/> @d.EpTel }
                    </p>
                </div>
            }
            @if (Hay(d.FacNombre))
            {
                <div>
                    <h2>Facilitador DIGER</h2>
                    <p class="acta-person">
                        <strong>@d.FacNombre</strong>
                        @if (Hay(d.FacCargo)) { <br/> @d.FacCargo }
                        @if (Hay(d.FacCorreo)) { <br/> @d.FacCorreo }
                    </p>
                </div>
            }
        </section>
    }

    @if (Model.Asistentes.Count > 0)
    {
        <section class="acta-sec">
            <h2>Asistentes <span class="acta-count">@Model.Asistentes.Count</span></h2>
            <table class="acta-table">
                <thead><tr><th>#</th><th>Nombre</th><th>Cargo</th><th>Institución</th><th>Correo</th></tr></thead>
                <tbody>
                    @for (var i = 0; i < Model.Asistentes.Count; i++)
                    {
                        var a = Model.Asistentes[i];
                        <tr>
                            <td>@(i + 1)</td><td>@a.Nombre</td><td>@a.Cargo</td>
                            <td>@a.Institucion</td><td>@a.Correo</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }

    @if (Model.DesgloseAsistenciaPorInstitucion.Count > 0)
    {
        <section class="acta-sec">
            <h2>Desglose de asistencia por institución</h2>
            <table class="acta-table">
                <thead><tr><th>Institución</th><th style="width:120px">Asistentes</th></tr></thead>
                <tbody>
                    @foreach (var (inst, cantidad) in Model.DesgloseAsistenciaPorInstitucion)
                    {
                        <tr><td>@inst</td><td>@cantidad</td></tr>
                    }
                </tbody>
            </table>
        </section>
    }

    @if (d.Convocados is not null || d.NumAsistentes is not null || d.PctAsistencia is not null || Hay(d.Satisfaccion) || Lineas(d.Compromisos).Any())
    {
        <section class="acta-sec">
            <h2>Resultados</h2>
            <div class="acta-stats">
                @if (d.Convocados is not null) { <div><b>@d.Convocados</b><span>Convocados</span></div> }
                @if (d.NumAsistentes is not null) { <div><b>@d.NumAsistentes</b><span>Asistentes</span></div> }
                @if (d.PctAsistencia is not null) { <div><b>@d.PctAsistencia%</b><span>Asistencia</span></div> }
                @if (Hay(d.Satisfaccion)) { <div><b>@d.Satisfaccion</b><span>Satisfacción</span></div> }
            </div>
            @if (Lineas(d.Compromisos).Any())
            {
                <h3>Compromisos</h3>
                <ul>@foreach (var l in Lineas(d.Compromisos)) { <li>@l</li> }</ul>
            }
        </section>
    }

    @if (Model.Acuerdos.Count > 0)
    {
        var hoy = DateOnly.FromDateTime(DateTime.Today);
        <section class="acta-sec">
            <h2>Acuerdos y seguimiento</h2>
            <table class="acta-table">
                <thead><tr><th>#</th><th>Compromiso</th><th>Responsable</th><th>Plazo</th><th>Estado</th><th>Seguimiento</th></tr></thead>
                <tbody>
                    @for (var i = 0; i < Model.Acuerdos.Count; i++)
                    {
                        var ac = Model.Acuerdos[i];
                        var ec = CompromisoUi.Color(ac.Estado);
                        var vencido = ac.Plazo is { } p && p < hoy &&
                            ac.Estado is EstadoCompromiso.Pendiente or EstadoCompromiso.EnProgreso or EstadoCompromiso.Reprogramado;
                        <tr>
                            <td>@(i + 1)</td><td>@ac.Compromiso</td><td>@ac.Responsable</td>
                            <td>
                                @(ac.Plazo?.ToFechaCorta() ?? "—")
                                @if (vencido) { <span style="background:@CompromisoUi.Vencido.bg;color:@CompromisoUi.Vencido.fg;border-radius:20px;padding:1px 8px;font-size:11px;font-weight:700;margin-left:4px">Vencido</span> }
                            </td>
                            <td><span style="background:@ec.bg;color:@ec.fg;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:700">@CompromisoUi.Label(ac.Estado)</span></td>
                            <td>@(string.IsNullOrWhiteSpace(ac.NotaSeguimiento) ? "—" : ac.NotaSeguimiento)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }

    @if (Hay(d.ValDiger) || Hay(d.ValInst) || Lineas(d.DocsRecursos).Any() || Hay(d.Foto1Url) || Hay(d.Foto2Url))
    {
        <section class="acta-sec">
            <h2>Validación y evidencias</h2>
            @if (Hay(d.ValDiger) || Hay(d.ValInst))
            {
                <div class="acta-cols">
                    @if (Hay(d.ValDiger)) { <div><h3>Validación DIGER</h3><p>@d.ValDiger</p></div> }
                    @if (Hay(d.ValInst)) { <div><h3>Validación institución</h3><p>@d.ValInst</p></div> }
                </div>
            }
            @if (Lineas(d.DocsRecursos).Any())
            {
                <h3>Documentos / recursos</h3>
                <ul>@foreach (var l in Lineas(d.DocsRecursos)) { <li>@l</li> }</ul>
            }
            @if (Hay(d.Foto1Url) || Hay(d.Foto2Url))
            {
                <div class="acta-fotos">
                    @if (Hay(d.Foto1Url)) { <figure><img src="@d.Foto1Url" alt="Evidencia 1" /><figcaption>@d.Foto1Desc</figcaption></figure> }
                    @if (Hay(d.Foto2Url)) { <figure><img src="@d.Foto2Url" alt="Evidencia 2" /><figcaption>@d.Foto2Desc</figcaption></figure> }
                </div>
            }
        </section>
    }

    <footer class="acta-foot">
        <div class="acta-firma"><span></span>Enlace institucional</div>
        <div class="acta-firma"><span></span>Facilitador DIGER</div>
    </footer>
</article>

<style>
    .acta-toolbar { max-width: 820px; margin: 1rem auto 0; padding: 0 1rem; display: flex; justify-content: space-between; align-items: center; }
    .acta { max-width: 820px; margin: 1rem auto 3rem; background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 2.4rem 2.6rem; box-shadow: 0 2px 12px rgba(10,45,110,.07); color: #1c2333; }
    .acta-head { display: flex; justify-content: space-between; align-items: center; padding-bottom: 1rem; border-bottom: 3px solid #0a2d6e; }
    .acta-brand { font-weight: 800; font-size: 18px; color: #0a2d6e; display: flex; align-items: center; gap: 8px; }
    .acta-logo { background: #0a2d6e; color: #fff; border-radius: 7px; padding: 3px 8px; font-size: 13px; letter-spacing: .04em; }
    .acta-kind { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #6b7fa3; }
    .acta-title { font-size: 24px; color: #0a2d6e; margin: 1.4rem 0 1rem; line-height: 1.25; }
    .acta-meta { display: grid; grid-template-columns: repeat(3, 1fr); gap: .7rem 1.4rem; margin-bottom: 1.8rem; }
    .acta-meta div { font-size: 14px; }
    .acta-meta span { display: block; font-size: 11px; text-transform: uppercase; letter-spacing: .06em; color: #8a96ad; margin-bottom: 2px; }
    .acta-sec { margin: 1.8rem 0; }
    .acta-sec h2 { font-size: 14px; color: #0a2d6e; text-transform: uppercase; letter-spacing: .05em; border-bottom: 2px solid #eef1f7; padding-bottom: .45rem; margin: 0 0 .9rem; }
    .acta-count { background: #e8f0ff; color: #1455a4; border-radius: 20px; padding: 1px 9px; font-size: 12px; margin-left: 6px; }
    .acta-sec h3 { font-size: 12.5px; color: #4a5568; margin: .9rem 0 .3rem; text-transform: uppercase; letter-spacing: .04em; }
    .acta-sec p { font-size: 14px; line-height: 1.55; margin: .2rem 0; white-space: pre-line; }
    .acta-rte { font-size: 14px; line-height: 1.55; }
    .acta-rte ul, .acta-rte ol { margin: .3rem 0 .3rem 1.4rem; }
    .acta-sec ul { margin: .3rem 0; padding-left: 1.2rem; }
    .acta-sec li { font-size: 14px; line-height: 1.5; margin-bottom: .25rem; }
    .acta-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 1.4rem; }
    .acta-person { font-size: 14px; line-height: 1.5; }
    .acta-table { width: 100%; border-collapse: collapse; margin-top: .4rem; }
    .acta-table th { text-align: left; font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: #6b7fa3; border-bottom: 2px solid #e2e8f0; padding: 6px 8px; }
    .acta-table td { font-size: 13px; padding: 7px 8px; border-bottom: 1px solid #eef1f7; vertical-align: top; }
    .acta-stats { display: flex; flex-wrap: wrap; gap: 1.6rem; margin: .4rem 0 .6rem; }
    .acta-stats div { display: flex; flex-direction: column; }
    .acta-stats b { font-size: 22px; color: #0a2d6e; }
    .acta-stats span { font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: #8a96ad; }
    .acta-fotos { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: .6rem; }
    .acta-fotos img { width: 100%; border-radius: 8px; border: 1px solid #e2e8f0; }
    .acta-fotos figcaption { font-size: 12px; color: #6b7fa3; margin-top: 4px; }
    .acta-foot { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-top: 3.5rem; }
    .acta-firma { text-align: center; font-size: 12px; color: #4a5568; }
    .acta-firma span { display: block; border-top: 1px solid #1c2333; margin-bottom: 6px; height: 2.4rem; }

    @@media (max-width: 700px) {
        .acta { padding: 1.4rem 1.2rem; }
        .acta-meta, .acta-cols, .acta-fotos { grid-template-columns: 1fr; }
    }

    .hilo-linked {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .hilo-linked li {
        display: flex;
        align-items: baseline;
        gap: 10px;
        flex-wrap: wrap;
        padding: 6px 10px;
        border-radius: 8px;
        background: var(--diger-bg-soft);
        border: 1px solid var(--diger-border);
    }

    .hilo-linked li a {
        font-weight: 600;
        color: var(--diger-blue);
        text-decoration: none;
    }

    .hilo-linked li a:hover {
        text-decoration: underline;
    }

    .hilo-linked li span {
        font-size: 12px;
        color: var(--diger-text-muted);
    }

    @@media print {
        .app-header, .gov-bar, .diger-footer, .acta-toolbar, .hilo-panel { display: none !important; }
        body { background: #fff; }
        .acta { max-width: none; margin: 0; border: 0; border-radius: 0; box-shadow: none; padding: 0; }
        .acta-sec, .acta-table tr, figure { break-inside: avoid; }
    }
</style>
