@page "{id:guid}"
@model Diger.TramitesEstado.Web.Pages.Reuniones.HiloModel
@{
    ViewData["Title"] = "Hilo de reuniones";
    var reuniones = Model.Hilo.Reuniones;
    var totalAcuerdos = reuniones.Sum(r => r.Acuerdos.Count);
    var cumplidos = reuniones.Sum(r => r.Acuerdos.Count(a => a.Estado == EstadoCompromiso.Cumplido));

    (string Label, string Bg, string Fg) EstadoInfo(EstadoCompromiso e) => e switch
    {
        EstadoCompromiso.Cumplido     => ("Cumplido", "var(--diger-success-bg)", "var(--diger-success)"),
        EstadoCompromiso.EnProgreso   => ("En progreso", "var(--diger-blue-light)", "var(--diger-blue)"),
        EstadoCompromiso.Reprogramado => ("Reprogramado", "var(--diger-warning-bg)", "var(--diger-warning)"),
        EstadoCompromiso.Cancelado    => ("Cancelado", "#eef1f7", "var(--diger-text-muted)"),
        _                             => ("Pendiente", "var(--diger-warning-bg)", "var(--diger-warning)")
    };
}

<div class="container" style="max-width:1000px">
    <div style="margin:1.5rem 0;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
        <a class="btns" asp-page="/Reuniones/Index">← Reuniones</a>
    </div>

    <div style="margin-bottom:1.6rem">
        <h1 class="page-title">🔗 Hilo de reuniones</h1>
        <p class="page-subtitle">
            @reuniones.Count reuniones enlazadas · @cumplidos de @totalAcuerdos acciones o tareas cumplidas
        </p>
    </div>

    <div class="hilo-timeline">
        @{ var idx = 0; }
        @foreach (var r in reuniones)
        {
            idx++;
            <div class="hilo-node">
                <div class="hilo-node-marker">@idx</div>
                <div class="card hilo-node-body">
                    <div style="display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;align-items:baseline">
                        <a asp-page="/Reuniones/Acta" asp-route-id="@r.Id"
                           style="font-weight:700;color:var(--diger-blue-dark);text-decoration:none;font-size:15px">@r.Titulo</a>
                        <span style="font-size:12.5px;color:var(--diger-text-muted)">@(r.Fecha?.ToString("dd 'de' MMMM 'de' yyyy") ?? "sin fecha")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(r.Institucion) || !string.IsNullOrWhiteSpace(r.Tipo))
                    {
                        <div style="font-size:12px;color:var(--diger-text-muted);margin-top:2px">
                            @r.Institucion@(string.IsNullOrWhiteSpace(r.Tipo) ? "" : (string.IsNullOrWhiteSpace(r.Institucion) ? "" : " · ") + r.Tipo)
                        </div>
                    }

                    @if (r.Acuerdos.Count == 0)
                    {
                        <p style="font-size:12.5px;color:var(--diger-text-faint);margin:.7rem 0 0">Sin acciones o tareas registradas.</p>
                    }
                    else
                    {
                        <ul class="hilo-acuerdos">
                            @foreach (var a in r.Acuerdos)
                            {
                                var est = EstadoInfo(a.Estado);
                                <li>
                                    <div style="flex:1;min-width:0">
                                        <div style="font-size:13.5px;color:var(--diger-text)">@a.Compromiso</div>
                                        <div style="font-size:11.5px;color:var(--diger-text-muted);margin-top:2px">
                                            @(string.IsNullOrWhiteSpace(a.Responsable) ? "Sin responsable" : a.Responsable)@(a.Plazo is null ? "" : " · plazo " + a.Plazo.Value.ToString("dd/MM/yyyy"))@(a.FechaCumplimiento is null ? "" : " · cumplido " + a.FechaCumplimiento.Value.ToString("dd/MM/yyyy"))
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(a.NotaSeguimiento))
                                        {
                                            <div style="font-size:11.5px;color:var(--diger-text-faint);margin-top:2px;font-style:italic">@a.NotaSeguimiento</div>
                                        }
                                    </div>
                                    <span class="hilo-estado" style="background:@est.Bg;color:@est.Fg">@est.Label</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        }
    </div>
</div>

<style>
    .hilo-timeline {
        position: relative;
        padding-left: 8px;
    }

    .hilo-node {
        display: flex;
        gap: 16px;
        position: relative;
        padding-bottom: 1.1rem;
    }

    .hilo-node::before {
        content: "";
        position: absolute;
        left: 15px;
        top: 34px;
        bottom: -6px;
        width: 2px;
        background: var(--diger-blue-pale);
    }

    .hilo-node:last-child::before { display: none; }

    .hilo-node-marker {
        flex: none;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--diger-blue);
        color: #fff;
        font-weight: 800;
        font-size: 13px;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
        box-shadow: 0 0 0 4px var(--diger-bg);
    }

    .hilo-node-body {
        flex: 1;
        min-width: 0;
        margin-bottom: 0;
    }

    .hilo-acuerdos {
        list-style: none;
        margin: .8rem 0 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .hilo-acuerdos li {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 8px;
        background: var(--diger-bg-soft);
        border: 1px solid var(--diger-border);
    }

    .hilo-estado {
        flex: none;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 9px;
        border-radius: var(--diger-radius-pill);
        white-space: nowrap;
    }
</style>
