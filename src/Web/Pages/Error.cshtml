@page
@model Diger.TramitesEstado.Web.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="container">
    <div style="max-width:520px;margin:80px auto;text-align:center">
        <div style="font-size:48px;margin-bottom:16px">⚠️</div>
        <h2 style="color:#1455a4;margin-bottom:8px">
            @(Model.Code == 404 ? "Página no encontrada" : "Ocurrió un error")
        </h2>
        <p style="color:#6b7fa3;margin-bottom:24px">@Model.Message</p>
        <a class="btnp" asp-page="/Index">← Volver al inicio</a>
    </div>
</div>
