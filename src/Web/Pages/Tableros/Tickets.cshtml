@page
@using System.Text.Json
@model Diger.TramitesEstado.Web.Pages.Tableros.TicketsModel
@{
    ViewData["Title"] = "Tablero de Tickets";
    var d = Model.Data;
    var estados = Enum.GetValues<EstadoTicket>();
    var prioridades = Enum.GetValues<PrioridadTicket>();
    var t = d.TendenciaCreados;
    string flecha = t.Delta > 0 ? "▲" : t.Delta < 0 ? "▼" : "▬";
    string trendColor = t.Delta > 0 ? "#a32d2d" : t.Delta < 0 ? "#0f6e56" : "#6b7fa3";
    // datos para charts
    var estadoRutas = estados.Select(e => e.ToString()).ToArray();
    var prioRutas = prioridades.Select(p => p.ToString()).ToArray();
    var J = (object o) => Html.Raw(JsonSerializer.Serialize(o));
}

<div class="container" style="max-width:1100px">
    <div class="hist-header">
        <div><h2>Tablero de Tickets</h2><p>Soporte de la plataforma SOL — su alcance</p></div>
        <a class="btns" asp-page="/Tableros/Index">← Tableros</a>
    </div>

    @if (Model.AlcanceTecnico)
    {
        <div class="alert-ok" style="margin-bottom:1rem">Métricas limitadas a <strong>sus temas</strong> y <strong>sus tickets asignados</strong>.</div>
    }

    <form method="get" class="seg-filters">
        <div class="field"><label>Institución</label>
            <select name="institucionId" onchange="this.form.submit()">
                <option value="">Todas</option>
                @foreach (var i in Model.Instituciones) { <option value="@i.Id" selected="@(Model.InstitucionId == i.Id)">@i.Nombre</option> }
            </select>
        </div>
        <div class="field"><label>Desde</label><input type="date" name="desde" value="@(Model.Desde?.ToString("yyyy-MM-dd"))" /></div>
        <div class="field"><label>Hasta</label><input type="date" name="hasta" value="@(Model.Hasta?.ToString("yyyy-MM-dd"))" /></div>
        <button class="btnp" type="submit" style="margin-bottom:.1rem">Filtrar</button>
        <a class="btns" asp-page="/Tableros/Tickets" style="margin-bottom:.1rem">Limpiar</a>
    </form>

    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-num">@d.Total</div><div class="kpi-lbl">Total tickets</div></div>
        <div class="kpi-card warn"><div class="kpi-num">@d.Abiertos</div><div class="kpi-lbl">Abiertos / en progreso</div></div>
        <div class="kpi-card @(d.CriticosAbiertos > 0 ? "alert" : "")"><div class="kpi-num">@d.CriticosAbiertos</div><div class="kpi-lbl">Críticos abiertos</div></div>
        <div class="kpi-card ok"><div class="kpi-num">@d.PorcentajeResueltos%</div><div class="kpi-lbl">Resueltos</div></div>
        <div class="kpi-card"><div class="kpi-num">@d.DiasPromedioResolucion</div><div class="kpi-lbl">Días prom. resolución</div></div>
        <div class="kpi-card @(d.SlaVencidos > 0 ? "alert" : "")"><div class="kpi-num">@d.SlaVencidos</div><div class="kpi-lbl">SLA vencido</div></div>
        <div class="kpi-card"><div class="kpi-num">@d.TendenciaCreados.Actual <span style="font-size:15px;color:@trendColor">@flecha @(Math.Abs(t.PorcentajeCambio))%</span></div><div class="kpi-lbl">Creados este mes</div></div>
    </div>

    <div class="dash-grid">
        <div class="dash-card" style="grid-column:1 / -1">
            <h3>Tendencia (12 meses) — creados vs resueltos</h3>
            <div style="position:relative;height:260px"><canvas id="chTrend"></canvas></div>
        </div>
        <div class="dash-card"><h3>Por estado <span class="hint">(clic para filtrar)</span></h3><div style="position:relative;height:230px"><canvas id="chEstado"></canvas></div></div>
        <div class="dash-card"><h3>Por prioridad <span class="hint">(clic para filtrar)</span></h3><div style="position:relative;height:230px"><canvas id="chPrioridad"></canvas></div></div>
        <div class="dash-card"><h3>Por categoría</h3><div style="position:relative;height:230px"><canvas id="chCategoria"></canvas></div></div>
        <div class="dash-card"><h3>Por tema</h3><div style="position:relative;height:230px"><canvas id="chTema"></canvas></div></div>
        <div class="dash-card">
            <h3>Por institución</h3>
            @if (!d.PorInstitucion.Any()) { <p style="font-size:13px;color:#6b7fa3">Sin datos.</p> }
            else
            {
                var mI = Math.Max(1, d.PorInstitucion.Max(x => x.Cantidad));
                @foreach (var c in d.PorInstitucion.Take(8))
                {
                    var instId = Model.Instituciones.FirstOrDefault(i => i.Nombre == c.Etiqueta)?.Id;
                    <a class="bar-row" style="text-decoration:none" href="@(instId is null ? "/Tickets/Index" : $"/Tickets/Index?institucionId={instId}")">
                        <span class="bar-lbl">@c.Etiqueta</span>
                        <div class="bar-track"><div class="bar-fill" style="width:@(c.Cantidad * 100 / mI)%"></div></div>
                        <span class="bar-val">@c.Cantidad</span>
                    </a>
                }
            }
        </div>
    </div>

    <div class="dash-card" style="margin-top:16px">
        <h3>Tickets abiertos más antiguos</h3>
        @if (!d.AbiertosAntiguos.Any()) { <p style="font-size:13px;color:#6b7fa3">No hay tickets abiertos.</p> }
        else
        {
            <table class="seg-table">
                <thead><tr><th>Nº</th><th>Título</th><th>Institución</th><th>Prioridad</th><th style="text-align:right">Días</th></tr></thead>
                <tbody>
                    @foreach (var x in d.AbiertosAntiguos)
                    {
                        <tr>
                            <td class="res-meta" style="white-space:nowrap">@x.Numero</td>
                            <td><a class="seg-inst" asp-page="/Tickets/Detalle" asp-route-id="@x.Id">@x.Titulo</a></td>
                            <td class="res-meta">@(x.Institucion ?? "—")</td>
                            <td class="res-meta">@x.Prioridad</td>
                            <td style="text-align:right;font-weight:700;color:@(x.DiasAbierto >= 7 ? "#a32d2d" : "#0a2d6e")">@x.DiasAbierto</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@section Scripts {
<script src="~/lib/chart/chart.umd.min.js" asp-append-version="true"></script>
<script>
  var instFiltro = @J(Model.InstitucionId?.ToString() ?? "");
  function drill(base, key, val){
    var u = base + '?' + key + '=' + encodeURIComponent(val);
    if(instFiltro) u += '&institucionId=' + instFiltro;
    window.location = u;
  }
  Chart.defaults.font.family = 'system-ui, sans-serif';
  Chart.defaults.plugins.legend.position = 'bottom';

  // Tendencia (líneas)
  new Chart(document.getElementById('chTrend'), {
    type: 'line',
    data: { labels: @J(d.CreadosPorMes.Select(x => x.Mes)),
      datasets: [
        { label: 'Creados', data: @J(d.CreadosPorMes.Select(x => x.Cantidad)), borderColor: '#1455a4', backgroundColor: 'rgba(20,85,164,.12)', fill: true, tension: .3 },
        { label: 'Resueltos', data: @J(d.ResueltosPorMes.Select(x => x.Cantidad)), borderColor: '#2f7d32', backgroundColor: 'rgba(47,125,50,.10)', fill: true, tension: .3 }
      ] },
    options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } }
  });

  // Donut por estado (drill-down)
  var estadoRutas = @J(estadoRutas);
  new Chart(document.getElementById('chEstado'), {
    type: 'doughnut',
    data: { labels: @J(d.PorEstado.Select(x => x.Etiqueta)),
      datasets: [{ data: @J(d.PorEstado.Select(x => x.Cantidad)), backgroundColor: ['#378add','#ef9f27','#639922','#888780'] }] },
    options: { responsive: true, maintainAspectRatio: false, onClick: function(e,els){ if(els.length) drill('/Tickets/Index','estado',estadoRutas[els[0].index]); } }
  });

  // Donut por prioridad (drill-down)
  var prioRutas = @J(prioRutas);
  new Chart(document.getElementById('chPrioridad'), {
    type: 'doughnut',
    data: { labels: @J(d.PorPrioridad.Select(x => x.Etiqueta)),
      datasets: [{ data: @J(d.PorPrioridad.Select(x => x.Cantidad)), backgroundColor: ['#888780','#378add','#d85a30','#c62828'] }] },
    options: { responsive: true, maintainAspectRatio: false, onClick: function(e,els){ if(els.length) drill('/Tickets/Index','prioridad',prioRutas[els[0].index]); } }
  });

  // Donut por categoría
  new Chart(document.getElementById('chCategoria'), {
    type: 'doughnut',
    data: { labels: @J(d.PorCategoria.Select(x => x.Etiqueta)),
      datasets: [{ data: @J(d.PorCategoria.Select(x => x.Cantidad)), backgroundColor: ['#185fa5','#1d9e75','#ba7517','#d4537e','#534ab7','#888780','#2a9d8f','#e76f51'] }] },
    options: { responsive: true, maintainAspectRatio: false }
  });

  // Donut por tema
  new Chart(document.getElementById('chTema'), {
    type: 'doughnut',
    data: { labels: @J(d.PorTema.Select(x => x.Etiqueta)),
      datasets: [{ data: @J(d.PorTema.Select(x => x.Cantidad)), backgroundColor: ['#1d9e75','#534ab7','#d4537e','#ba7517','#185fa5','#888780','#2a9d8f','#e76f51'] }] },
    options: { responsive: true, maintainAspectRatio: false }
  });
</script>
}
