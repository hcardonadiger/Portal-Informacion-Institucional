@page
@using System.Text.Json
@model Diger.TramitesEstado.Web.Pages.Tableros.ReunionesModel
@{
    ViewData["Title"] = "Tablero de Reuniones";
    var d = Model.Data;
    var J = (object o) => Html.Raw(JsonSerializer.Serialize(o));

    // Dona de compromisos por estado (etiquetas/colores desde CompromisoUi).
    var estLabels = CompromisoUi.Estados.Select(e => CompromisoUi.Label(e)).ToList();
    var estData   = CompromisoUi.Estados.Select(e => d.PorEstadoAcuerdo.FirstOrDefault(x => x.Etiqueta == e.ToString())?.Cantidad ?? 0).ToList();
    var estColors = CompromisoUi.Estados.Select(e => CompromisoUi.Color(e).fg).ToList();
}

<div class="container" style="max-width:1100px">
    <div class="hist-header">
        <div><h2>Tablero de Reuniones y Acuerdos</h2><p>Seguimiento de compromisos — su alcance</p></div>
        <div style="display:flex;gap:8px">
            <a class="btnp" asp-page="/Reuniones/Compromisos">Gestionar compromisos →</a>
            <a class="btns" asp-page="/Tableros/Index">← Tableros</a>
        </div>
    </div>

    <form method="get" class="seg-filters">
        <div class="field" style="min-width:200px"><label>Institución</label>
            <select name="institucionId" onchange="this.form.submit()">
                <option value="">Todas</option>
                @foreach (var i in Model.Instituciones) { <option value="@i.Id" selected="@(Model.InstitucionId == i.Id)">@i.Nombre</option> }
            </select>
        </div>
        <a class="btns" asp-page="/Tableros/Reuniones" style="margin-bottom:.1rem">Limpiar</a>
    </form>

    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-num">@d.Total</div><div class="kpi-lbl">Reuniones</div></div>
        <div class="kpi-card"><div class="kpi-num">@d.Mes</div><div class="kpi-lbl">Este mes</div></div>
        <div class="kpi-card"><div class="kpi-num">@d.AcuerdosTotal</div><div class="kpi-lbl">Compromisos</div></div>
        <div class="kpi-card @(d.AcuerdosVencidos > 0 ? "alert" : "")"><div class="kpi-num">@d.AcuerdosVencidos</div><div class="kpi-lbl">Vencidos</div></div>
        <div class="kpi-card warn"><div class="kpi-num">@d.AcuerdosProximos</div><div class="kpi-lbl">Próximos</div></div>
        <div class="kpi-card"><div class="kpi-num">@d.AcuerdosCumplidos</div><div class="kpi-lbl">Cumplidos</div></div>
        <div class="kpi-card"><div class="kpi-num">@d.TasaCumplimiento%</div><div class="kpi-lbl">Tasa de cumplimiento</div></div>
    </div>

    <div class="dash-grid">
        <div class="dash-card" style="grid-column:1 / -1">
            <h3>Reuniones por mes (12 meses)</h3>
            <div style="position:relative;height:240px"><canvas id="chMes"></canvas></div>
        </div>
        <div class="dash-card"><h3>Compromisos por estado</h3><div style="position:relative;height:240px"><canvas id="chEstado"></canvas></div></div>
        <div class="dash-card"><h3>Reuniones por tipo</h3><div style="position:relative;height:240px"><canvas id="chTipo"></canvas></div></div>
        <div class="dash-card" style="grid-column:1 / -1">
            <h3>Reuniones por institución</h3>
            @if (!d.PorInstitucion.Any()) { <p style="font-size:13px;color:#6b7fa3">Sin datos.</p> }
            else
            {
                var mI = Math.Max(1, d.PorInstitucion.Max(x => x.Cantidad));
                @foreach (var c in d.PorInstitucion.Take(10))
                {
                    <div class="bar-row"><span class="bar-lbl">@c.Etiqueta</span>
                        <div class="bar-track"><div class="bar-fill" style="width:@(c.Cantidad * 100 / mI)%"></div></div>
                        <span class="bar-val">@c.Cantidad</span></div>
                }
            }
        </div>
    </div>

    <div class="dash-card" style="margin-top:16px">
        <div style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;flex-wrap:wrap">
            <h3 style="margin:0">Compromisos abiertos con plazo (@(d.AcuerdosVencidos) vencidos · @(d.AcuerdosProximos) próximos · @(d.AcuerdosSinPlazo) sin plazo)</h3>
            <a class="btns" asp-page="/Reuniones/Compromisos" style="font-size:12.5px">Ver todos →</a>
        </div>
        @if (!d.Acuerdos.Any()) { <p style="font-size:13px;color:#6b7fa3">No hay compromisos abiertos con plazo registrado.</p> }
        else
        {
            <table class="seg-table">
                <thead><tr><th>Compromiso</th><th>Responsable</th><th>Reunión</th><th>Estado</th><th style="text-align:right">Plazo</th></tr></thead>
                <tbody>
                    @foreach (var a in d.Acuerdos)
                    {
                        var ec = CompromisoUi.Color(a.Estado);
                        <tr>
                            <td style="font-size:13px">@a.Compromiso</td>
                            <td class="res-meta">@(a.Responsable ?? "—")</td>
                            <td><a class="seg-inst" asp-page="/Reuniones/Acta" asp-route-id="@a.ReunionId" style="font-size:12.5px">@a.ReunionTitulo</a></td>
                            <td><span style="background:@ec.bg;color:@ec.fg;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:700">@CompromisoUi.Label(a.Estado)</span></td>
                            <td style="text-align:right;white-space:nowrap;font-weight:700;color:@(a.Vencido ? "#a32d2d" : "#0a2d6e")">@(a.Plazo?.ToFechaCorta())</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* ── Personas capacitadas (panel desplegable) ───────────────────────────── *@
    <details class="cap-panel">
        <summary>
            <span class="cap-sum-txt">Ver listado de personas capacitadas (@d.PersonasCapacitadas.Count)</span>
            <span class="cap-chev" aria-hidden="true">⌃</span>
        </summary>
        @if (!d.PersonasCapacitadas.Any())
        {
            <p style="font-size:13px;color:#6b7fa3;padding:14px 16px;margin:0">
                No hay personas capacitadas registradas para este alcance.
            </p>
        }
        else
        {
            <table class="cap-table">
                <thead>
                    <tr><th>Nombre</th><th>Capacitación</th><th style="width:130px">Participación</th></tr>
                </thead>
                <tbody>
                    @foreach (var p in d.PersonasCapacitadas)
                    {
                        <tr>
                            <td>
                                <div class="cap-nombre">@p.Nombre</div>
                                @if (!string.IsNullOrWhiteSpace(p.Institucion))
                                {
                                    <div class="cap-inst">@p.Institucion</div>
                                }
                            </td>
                            <td>
                                @if (p.Capacitaciones.Count == 0) { <span class="cap-dash">—</span> }
                                else if (p.Capacitaciones.Count == 1) { <span>@p.Capacitaciones[0]</span> }
                                else
                                {
                                    <ul class="cap-list">
                                        @foreach (var c in p.Capacitaciones) { <li>@c</li> }
                                    </ul>
                                }
                            </td>
                            <td>
                                @if (p.EsMultiple)
                                {
                                    <span class="cap-badge multi">Múltiples (@p.Veces)</span>
                                }
                                else
                                {
                                    <span class="cap-badge unica">Única vez</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </details>
</div>

<style>
    .cap-panel { margin-top: 16px; background: #f7faff; border: 1px solid #d8e4f5; border-radius: 12px; overflow: hidden; }
    .cap-panel > summary {
        cursor: pointer; list-style: none; padding: 12px 16px;
        display: flex; align-items: center; justify-content: space-between; gap: 10px;
        font-size: 13.5px; font-weight: 600; color: #0a2d6e; user-select: none;
    }
    .cap-panel > summary::-webkit-details-marker { display: none; }
    .cap-panel > summary:hover { background: #eef4fd; }
    .cap-sum-txt::before { content: "\1F464"; margin-right: 8px; opacity: .65; }
    .cap-chev { transition: transform .2s; font-size: 15px; color: #6b7fa3; }
    .cap-panel[open] .cap-chev { transform: rotate(180deg); }
    .cap-table { width: 100%; border-collapse: collapse; background: #fff; }
    .cap-table th {
        text-align: left; font-size: 11px; text-transform: uppercase; letter-spacing: .05em;
        color: #6b7fa3; background: #fff; border-bottom: 1.5px solid #e2e8f0; padding: 9px 14px;
    }
    .cap-table td { padding: 10px 14px; border-bottom: 1px solid #eef1f7; font-size: 13px; vertical-align: top; }
    .cap-table tr:nth-child(even) td { background: #fbfcfe; }
    .cap-nombre { font-weight: 600; color: #0a2d6e; }
    .cap-inst { font-size: 10.5px; text-transform: uppercase; letter-spacing: .04em; color: #8a96ad; margin-top: 2px; }
    .cap-dash { color: #8a96ad; }
    .cap-list { margin: 0; padding-left: 14px; }
    .cap-list li { margin-bottom: 2px; }
    .cap-badge { display: inline-block; border-radius: 20px; padding: 3px 11px; font-size: 12px; font-weight: 700; white-space: nowrap; }
    .cap-badge.unica { background: #eafaf0; color: #1d7a4c; border: 1px solid #b7e6cb; }
    .cap-badge.multi { background: #fdf6e3; color: #9a6b08; border: 1px solid #f5d98a; }
</style>

@section Scripts {
<script src="~/lib/chart/chart.umd.min.js" asp-append-version="true"></script>
<script>
  Chart.defaults.font.family = 'system-ui, sans-serif';
  Chart.defaults.plugins.legend.position = 'bottom';
  new Chart(document.getElementById('chMes'), {
    type: 'bar',
    data: { labels: @J(d.PorMes.Select(x => x.Mes)),
      datasets: [{ label: 'Reuniones', data: @J(d.PorMes.Select(x => x.Cantidad)), backgroundColor: '#0f8a6a' }] },
    options: { responsive: true, maintainAspectRatio: false, plugins:{legend:{display:false}}, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } }
  });
  new Chart(document.getElementById('chTipo'), {
    type: 'doughnut',
    data: { labels: @J(d.PorTipo.Select(x => x.Etiqueta)),
      datasets: [{ data: @J(d.PorTipo.Select(x => x.Cantidad)), backgroundColor: ['#1455a4','#1d9e75','#ef9f27','#534ab7','#d4537e','#888780','#d85a30','#185fa5'] }] },
    options: { responsive: true, maintainAspectRatio: false }
  });
  new Chart(document.getElementById('chEstado'), {
    type: 'doughnut',
    data: { labels: @J(estLabels),
      datasets: [{ data: @J(estData), backgroundColor: @J(estColors) }] },
    options: { responsive: true, maintainAspectRatio: false }
  });
</script>
}
