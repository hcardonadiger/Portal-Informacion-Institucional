@page
@using System.Text.Json
@model Diger.TramitesEstado.Web.Pages.Tableros.ExpedientesModel
@{
    ViewData["Title"] = "Tablero de Expedientes";
    var d = Model.Data;
    var pctCerrados = d.Total == 0 ? 0 : d.Cerrados * 100 / d.Total;
    var J = (object o) => Html.Raw(JsonSerializer.Serialize(o));
}

<div class="container" style="max-width:1100px">
    <div class="hist-header">
        <div><h2>Tablero de Expedientes</h2><p>Avance de digitalización — su alcance</p></div>
        <a class="btns" asp-page="/Tableros/Index">← Tableros</a>
    </div>

    <form method="get" class="seg-filters">
        <div class="field" style="min-width:200px"><label>Institución</label>
            <select name="institucionId" onchange="this.form.submit()">
                <option value="">Todas</option>
                @foreach (var i in Model.Instituciones) { <option value="@i.Id" selected="@(Model.InstitucionId == i.Id)">@i.Nombre</option> }
            </select>
        </div>
        <a class="btns" asp-page="/Tableros/Expedientes" style="margin-bottom:.1rem">Limpiar</a>
    </form>

    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-num">@d.Total</div><div class="kpi-lbl">Expedientes de Digitalización - Trámites Nuevos</div></div>
        <div class="kpi-card"><div class="kpi-num">@d.TramitesTotal</div><div class="kpi-lbl">Trámites</div></div>
        <div class="kpi-card ok"><div class="kpi-num">@d.Cerrados</div><div class="kpi-lbl">Cerrados</div></div>
        <div class="kpi-card"><div class="kpi-num">@pctCerrados%</div><div class="kpi-lbl">% completado</div></div>
    </div>

    <div class="dash-grid">
        <div class="dash-card" style="grid-column:1 / -1">
            <h3>Expedientes creados (12 meses)</h3>
            <div style="position:relative;height:240px"><canvas id="chMes"></canvas></div>
        </div>
        <div class="dash-card"><h3>Por estado</h3><div style="position:relative;height:240px"><canvas id="chEstado"></canvas></div></div>
        <div class="dash-card">
            <h3>Por institución</h3>
            @if (!d.PorInstitucion.Any()) { <p style="font-size:13px;color:#6b7fa3">Sin datos.</p> }
            else
            {
                var mI = Math.Max(1, d.PorInstitucion.Max(x => x.Cantidad));
                @foreach (var c in d.PorInstitucion.Take(12))
                {
                    <div class="bar-row"><span class="bar-lbl">@c.Etiqueta</span>
                        <div class="bar-track"><div class="bar-fill" style="width:@(c.Cantidad * 100 / mI)%"></div></div>
                        <span class="bar-val">@c.Cantidad</span></div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
<script src="~/lib/chart/chart.umd.min.js" asp-append-version="true"></script>
<script>
  Chart.defaults.font.family = 'system-ui, sans-serif';
  Chart.defaults.plugins.legend.position = 'bottom';
  new Chart(document.getElementById('chMes'), {
    type: 'bar',
    data: { labels: @J(d.CreadosPorMes.Select(x => x.Mes)),
      datasets: [{ label: 'Creados', data: @J(d.CreadosPorMes.Select(x => x.Cantidad)), backgroundColor: '#1455a4' }] },
    options: { responsive: true, maintainAspectRatio: false, plugins:{legend:{display:false}}, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } }
  });
  new Chart(document.getElementById('chEstado'), {
    type: 'doughnut',
    data: { labels: @J(d.PorEstado.Select(x => x.Etiqueta)),
      datasets: [{ data: @J(d.PorEstado.Select(x => x.Cantidad)), backgroundColor: ['#888780','#378add','#534ab7','#ef9f27','#2f7d32'] }] },
    options: { responsive: true, maintainAspectRatio: false }
  });
</script>
}
