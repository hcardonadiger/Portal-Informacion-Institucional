@page
@using System.Text.Json
@model Diger.TramitesEstado.Web.Pages.Tableros.IndexModel
@{
    ViewData["Title"] = "Tableros";
    var d = Model.Data;
    (string bg, string fg) EstadoColor(EstadoTicket e) => e switch
    {
        EstadoTicket.Abierto => ("#e6f1fb", "#0c447c"), EstadoTicket.EnProgreso => ("#faeeda", "#854f0b"),
        EstadoTicket.Resuelto => ("#eaf3de", "#27500a"), _ => ("#f1efe8", "#444441"),
    };
    string EstadoLbl(EstadoTicket e) => e == EstadoTicket.EnProgreso ? "En progreso" : e.ToString();
}

<div class="container" style="max-width:1100px">
    <div class="hist-header">
        <div>
            <h2>Tableros</h2>
            <p>Resumen del portal — métricas de su alcance</p>
        </div>
    </div>

    <div class="kpi-grid">
        <a class="kpi-card @(d.TicketsCriticos > 0 ? "alert" : "")">
            <div class="kpi-num">@d.TicketsCriticos</div><div class="kpi-lbl">Tickets críticos</div>
        </a>
        <div class="kpi-card warn"><div class="kpi-num">@d.TicketsAbiertos</div><div class="kpi-lbl">Tickets abiertos</div></div>
        <div class="kpi-card"><div class="kpi-num">@d.TicketsEnProgreso</div><div class="kpi-lbl">En progreso</div></div>
        <a class="kpi-card @(d.AcuerdosVencidos > 0 ? "alert" : "")" asp-page="/Reuniones/Compromisos" asp-route-soloVencidos="true"><div class="kpi-num">@d.AcuerdosVencidos</div><div class="kpi-lbl">Acuerdos vencidos</div></a>
        <a class="kpi-card" asp-page="/Reuniones/Compromisos"><div class="kpi-num">@d.AcuerdosProximos</div><div class="kpi-lbl">Acuerdos próximos</div></a>
        <div class="kpi-card ok"><div class="kpi-num">@d.ExpedientesCerrados</div><div class="kpi-lbl">Expedientes cerrados</div></div>
    </div>

    <div class="dash-card" style="margin-bottom:16px">
        <h3>Tickets creados por mes (12 meses)
            @{ var tt = d.TicketsCreados; var fl = tt.Delta > 0 ? "▲" : tt.Delta < 0 ? "▼" : "▬"; var tc = tt.Delta > 0 ? "#a32d2d" : tt.Delta < 0 ? "#0f6e56" : "#6b7fa3"; }
            <span style="font-size:13px;color:@tc;font-weight:700;margin-left:6px">@fl @Math.Abs(tt.PorcentajeCambio)% vs mes anterior</span>
        </h3>
        <div style="position:relative;height:200px"><canvas id="chResumen"></canvas></div>
    </div>

    <div class="dash-grid">
        <div class="dash-card">
            <h3>Atajos a tableros</h3>
            <div style="display:flex;flex-direction:column;gap:8px">
                <a class="btns" asp-page="/Tableros/Tickets" style="justify-content:space-between">Tickets de soporte <span class="bar-val">@d.TicketsTotal</span></a>
                <a class="btns" asp-page="/Tableros/Expedientes" style="justify-content:space-between">Expedientes de Digitalización - Trámites Nuevos <span class="bar-val">@d.ExpedientesTotal</span></a>
                <a class="btns" asp-page="/Tableros/Reuniones" style="justify-content:space-between">Reuniones y acuerdos <span class="bar-val">@d.ReunionesTotal</span></a>
            </div>
            <p style="font-size:12.5px;color:#6b7fa3;margin-top:1rem">
                Reuniones este mes: <strong>@d.ReunionesMes</strong> · Expedientes en proceso: <strong>@d.ExpedientesEnProceso</strong>
            </p>
        </div>

        <div class="dash-card">
            <h3>Últimos tickets</h3>
            @if (!d.UltimosTickets.Any())
            {
                <p style="font-size:13px;color:#6b7fa3">Sin tickets en su alcance.</p>
            }
            else
            {
                <div style="display:flex;flex-direction:column;gap:7px">
                    @foreach (var t in d.UltimosTickets)
                    {
                        var ec = EstadoColor(t.Estado);
                        <a asp-page="/Tickets/Detalle" asp-route-id="@t.Id" style="text-decoration:none;display:flex;align-items:center;gap:8px;font-size:13px">
                            <span class="res-meta" style="font-variant-numeric:tabular-nums">@t.Numero</span>
                            <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#1c2333">@t.Titulo</span>
                            <span style="background:@ec.bg;color:@ec.fg;border-radius:20px;padding:1px 9px;font-size:11px;font-weight:700">@EstadoLbl(t.Estado)</span>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script src="~/lib/chart/chart.umd.min.js" asp-append-version="true"></script>
<script>
  Chart.defaults.font.family = 'system-ui, sans-serif';
  new Chart(document.getElementById('chResumen'), {
    type: 'line',
    data: { labels: @Html.Raw(JsonSerializer.Serialize(d.TicketsPorMes.Select(x => x.Mes))),
      datasets: [{ label: 'Tickets', data: @Html.Raw(JsonSerializer.Serialize(d.TicketsPorMes.Select(x => x.Cantidad))),
        borderColor: '#1455a4', backgroundColor: 'rgba(20,85,164,.12)', fill: true, tension: .3 }] },
    options: { responsive: true, maintainAspectRatio: false, plugins:{legend:{display:false}}, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } }
  });
</script>
}
