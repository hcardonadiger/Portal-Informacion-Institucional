@page
@model Diger.TramitesEstado.Web.Pages.Cuenta.RestablecerPasswordModel
@{
    ViewData["Title"] = "Restablecer contraseña";
    Layout = "_Layout";
}

<div class="container" style="max-width:440px">
    <div class="card" style="margin-top:2rem">
        <div style="text-align:center;margin-bottom:1.5rem">
            <div class="iavt" style="margin:0 auto 12px;width:54px;height:54px;font-size:18px">🔒</div>
            <h2 style="color:#0a2d6e;font-size:20px;margin:0">Crear nueva contraseña</h2>
            <p style="color:#6b7fa3;font-size:13px;margin-top:4px">Para el usuario: <strong>@Model.Correo</strong></p>
        </div>

        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="alert-error" style="margin-bottom:1rem">@Model.Error</div>
        }

        @if (Model.Exitoso)
        {
            <div class="alert-success" style="margin-bottom:1rem;background-color:#f0fdf4;border-color:#bbf7d0;color:#166534;padding:14px;border-radius:8px;font-size:14px;text-align:center">
                <strong>¡Contraseña actualizada exitosamente!</strong><br />
                <span style="font-size:13px">Ya puedes ingresar al portal utilizando tu nueva contraseña.</span>
            </div>
            <div style="text-align:center;margin-top:1rem">
                <a class="btnp" asp-page="/Cuenta/Login" style="width:100%;justify-content:center">Iniciar sesión ahora</a>
            </div>
        }
        else
        {
            <form method="post">
                <input type="hidden" asp-for="Correo" />
                <input type="hidden" asp-for="Token" />

                <div class="field">
                    <label>Nueva contraseña</label>
                    <input asp-for="NuevaPassword" type="password" required autocomplete="new-password" placeholder="Mínimo 8 caracteres" />
                </div>
                <div class="field">
                    <label>Confirmar nueva contraseña</label>
                    <input asp-for="ConfirmarPassword" type="password" required autocomplete="new-password" placeholder="Repita la nueva contraseña" />
                </div>
                <button class="btnp" type="submit" style="width:100%;justify-content:center;margin-top:.5rem">
                    Guardar nueva contraseña
                </button>
            </form>

            <div style="text-align:center;margin-top:1.2rem;padding-top:1rem;border-top:1px solid #e2e8f0">
                <a asp-page="/Cuenta/OlvidarPassword" style="font-size:12.5px;color:#0a2d6e;text-decoration:none">Solicitar otro enlace</a>
            </div>
        }
    </div>
</div>
