@page
@model Diger.TramitesEstado.Web.Pages.Cuenta.Manage.IndexModel
@{
    ViewData["Title"] = "Datos Personales";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="card">
    <h3 style="margin-top:0;margin-bottom:1.5rem;color:#0a2d6e;font-size:16px;border-bottom:1px solid #e2e8f0;padding-bottom:10px">
        Información de la Cuenta
    </h3>
    
    <form method="post">
        <div class="field">
            <label>Nombre Completo</label>
            <input asp-for="Nombre" required maxlength="150" />
            <span asp-validation-for="Nombre" class="text-error"></span>
        </div>
        
        <div class="field">
            <label>Correo Institucional (Login)</label>
            <input asp-for="Correo" type="email" required maxlength="200" />
            <span asp-validation-for="Correo" class="text-error"></span>
        </div>
        
        <h3 style="margin-top:2rem;margin-bottom:1.5rem;color:#0a2d6e;font-size:16px;border-bottom:1px solid #e2e8f0;padding-bottom:10px">
            Cambio de Contraseña (Opcional)
        </h3>
        
        <div class="field">
            <label>Contraseña Actual</label>
            <input asp-for="PasswordActual" type="password" placeholder="Requerida solo si vas a cambiarla" />
            <span asp-validation-for="PasswordActual" class="text-error"></span>
        </div>
        
        <div class="field">
            <label>Nueva Contraseña</label>
            <input asp-for="PasswordNuevo" type="password" placeholder="Mínimo 6 caracteres" />
            <span asp-validation-for="PasswordNuevo" class="text-error"></span>
        </div>

        <div style="margin-top:2rem">
            <button type="submit" class="btnp">Guardar Cambios</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
