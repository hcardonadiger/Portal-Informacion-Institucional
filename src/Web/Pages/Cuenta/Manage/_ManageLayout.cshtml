@{
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="container" style="max-width: 950px;">
    <div class="header-action" style="margin-bottom: 2.5rem;">
        <div>
            <h1 class="page-title">Mi Perfil</h1>
            <p class="page-subtitle">Administra tu información personal y credenciales de acceso</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success" style="margin-bottom:1.5rem; padding:1rem; background-color:#def7ec; color:#03543f; border-radius:8px;">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-error" style="margin-bottom:1.5rem; padding:1rem; background-color:#fde8e8; color:#9b1c1c; border-radius:8px;">@TempData["ErrorMessage"]</div>
    }

    <div style="display: flex; gap: 2rem;">
        <div style="width: 250px; flex-shrink: 0;">
            <partial name="_ManageNav" />
        </div>
        <div style="flex-grow: 1; min-width: 0;">
            @RenderBody()
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
