@page
@model Diger.TramitesEstado.Web.Pages.Cuenta.OlvidarPasswordModel
@{
    ViewData["Title"] = "Recuperar contraseña";
    Layout = "_Layout";
}

<div class="container" style="max-width:440px">
    <div class="card" style="margin-top:2rem">
        <div style="text-align:center;margin-bottom:1.5rem">
            <div class="iavt" style="margin:0 auto 12px;width:54px;height:54px;font-size:18px">🔑</div>
            <h2 style="color:#0a2d6e;font-size:20px;margin:0">Recuperación de contraseña</h2>
            <p style="color:#6b7fa3;font-size:13px;margin-top:4px">Ingrese su correo para recibir las instrucciones</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="alert-error" style="margin-bottom:1rem">@Model.Error</div>
        }

        @if (!string.IsNullOrEmpty(Model.Mensaje))
        {
            <div class="alert-success" style="margin-bottom:1rem;background-color:#eff6ff;border-color:#bfdbfe;color:#1e40af;padding:12px;border-radius:8px;font-size:13.5px">
                @Model.Mensaje
            </div>
            <div style="text-align:center;margin-top:1rem">
                <a class="btns" asp-page="/Cuenta/Login" style="width:100%;justify-content:center">← Volver al inicio de sesión</a>
            </div>
        }
        else
        {
            <form method="post">
                <div class="field">
                    <label>Correo electrónico registrado</label>
                    <input asp-for="Correo" type="email" required autocomplete="email" placeholder="usuario@diger.gob.hn" />
                </div>
                <button class="btnp" type="submit" style="width:100%;justify-content:center;margin-top:.5rem">
                    Enviar enlace de recuperación
                </button>
            </form>

            <div style="text-align:center;margin-top:1.2rem;padding-top:1rem;border-top:1px solid #e2e8f0">
                <a asp-page="/Cuenta/Login" style="font-size:13px;color:#0a2d6e;text-decoration:none">← Volver al inicio de sesión</a>
            </div>
        }
    </div>
</div>
