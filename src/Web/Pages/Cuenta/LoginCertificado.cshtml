@page
@model Diger.TramitesEstado.Web.Pages.Cuenta.LoginCertificadoModel
@{
    ViewData["Title"] = "Validando certificado...";
    Layout = "_Layout";
}

<div class="container" style="max-width:440px">
    <div class="card" style="margin-top:2rem;text-align:center">
        <h2 style="color:#0a2d6e;font-size:20px;margin-bottom:1rem">Autenticación con Certificado</h2>
        
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            var isDev = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development";
            var backUrl = isDev ? "https://localhost:49175/Cuenta/Login" : $"https://{Request.Host.Host.Replace("cert.", "")}/Cuenta/Login";
            <div class="alert-error" style="text-align:left;margin-bottom:1rem">@Model.Error</div>
            <a href="@backUrl" class="btnp">Volver al inicio de sesión</a>
        }
        else
        {
            <div id="loadingUI">
                <p style="color:#6b7fa3;font-size:16px;margin-bottom:1rem;">Verificando tu certificado digital...</p>
                <div class="spinner" style="margin: 0 auto 1rem auto; width: 40px; height: 40px; border: 4px solid #f3f3f3; border-top: 4px solid #0a2d6e; border-radius: 50%; animation: spin 1s linear infinite;"></div>
                <p style="color:#999;font-size:12px;">Por favor, espera un momento. Serás redirigido automáticamente.</p>
            </div>

            <form id="certForm" method="post" asp-page="/Cuenta/LoginCertificado" asp-route-returnUrl="@Model.ReturnUrl">
                <!-- El AntiforgeryToken se inyecta automáticamente aquí por ASP.NET Core -->
            </form>

            <style>
                @@keyframes spin {
                    0% { transform: rotate(0deg); }
                    100% { transform: rotate(360deg); }
                }
            </style>

            <script>
                document.addEventListener("DOMContentLoaded", function() {
                    // Enviar el formulario automáticamente después de un pequeño retraso para asegurar que la UI renderice
                    setTimeout(function() {
                        document.getElementById('certForm').submit();
                    }, 800);
                });
            </script>
        }
    </div>
</div>
