@page
@model Diger.TramitesEstado.Web.Pages.Cuenta.VerificarCertificadoModel
@{
    ViewData["Title"] = "Verificando Certificado...";
    Layout = "_Layout";
}

<div class="container" style="max-width:440px">
    <div class="card" style="margin-top:2rem;text-align:center">
        <h2 style="color:#0a2d6e;font-size:20px;margin-bottom:1rem">Verificación de Seguridad</h2>
        
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="alert-error" style="text-align:left;margin-bottom:1rem">@Model.Error</div>
            var isDev = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development";
            var backUrl = isDev ? "https://localhost:49175/Cuenta/Certificado" : $"https://{Request.Host.Host.Replace("cert.", "")}/Cuenta/Certificado";
            <a href="@backUrl" class="btnp">Volver al Perfil</a>
        }
        else
        {
            <p style="color:#6b7fa3;font-size:14px">Verificando tu certificado digital...</p>
        }
    </div>
</div>
