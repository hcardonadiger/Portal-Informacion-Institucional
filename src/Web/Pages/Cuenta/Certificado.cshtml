@page
@model Diger.TramitesEstado.Web.Pages.Cuenta.CertificadoModel
@{
    ViewData["Title"] = "Certificado digital";
    Layout = "_CuentaLayout";
}

<div class="card">
    <h3 class="cuenta-card-title">Certificado digital (Smart Card / Token)</h3>

    <div style="background:#f8fafc;padding:1.6rem;border-radius:8px;border:1px solid #e2e8f0;text-align:center">
        @if (Model.TieneCertificadoVinculado)
        {
            <div style="width:48px;height:48px;background:#def7ec;color:#03543f;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:24px">✓</div>
            <h4 style="margin:0 0 .5rem;color:#0a2d6e">Certificado vinculado</h4>
            <p style="color:#6b7fa3;font-size:13px;margin:0 0 1.5rem">
                Tienes un certificado digital asignado a tu cuenta. Puedes usarlo para iniciar sesión sin contraseña.
            </p>
            <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
                <a href="@Model.CertUrl" class="btnp">Actualizar certificado</a>
                <form method="post" asp-page-handler="Desvincular" style="display:inline">
                    <button type="submit" class="btns"
                            style="color:var(--diger-danger);border-color:#fca5a5;background:#fef2f2"
                            onclick="return confirm('¿Seguro que deseas desvincular tu certificado digital?')">
                        Desvincular
                    </button>
                </form>
            </div>
        }
        else
        {
            <div style="width:48px;height:48px;background:#e1effe;color:#1e429f;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:24px">🔐</div>
            <h4 style="margin:0 0 .5rem;color:#0a2d6e">Sin certificado</h4>
            <p style="color:#6b7fa3;font-size:13px;margin:0 0 1.5rem">
                No tienes ningún certificado digital vinculado. Conecta tu Smart Card (ej. Token Bit4Id) y vincúlalo para facilitar tu acceso.
            </p>
            <a href="@Model.CertUrl" class="btnp">Vincular certificado</a>
        }
    </div>

    <p style="font-size:12px;color:#9aadcc;margin-top:1.5rem">
        <strong>Nota:</strong> al hacer clic en Vincular/Actualizar, se te solicitará seleccionar tu certificado y colocar tu PIN.
    </p>
</div>
