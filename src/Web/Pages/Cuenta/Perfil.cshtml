@page
@model Diger.TramitesEstado.Web.Pages.Cuenta.PerfilModel
@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="header-action">
    <div>
        <h1 class="page-title">Mi Perfil</h1>
        <p class="page-subtitle">Administra tu información personal y credenciales de acceso</p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success" style="margin-bottom:1.5rem">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-error" style="margin-bottom:1.5rem">@TempData["ErrorMessage"]</div>
}

<div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem">
    
    <div class="card">
        <h3 style="margin-top:0;margin-bottom:1.5rem;color:#0a2d6e;font-size:16px;border-bottom:1px solid #e2e8f0;padding-bottom:10px">
            Datos Personales
        </h3>
        
        <form method="post">
            <div class="field">
                <label>Nombre Completo</label>
                <input asp-for="Nombre" required maxlength="150" />
                <span asp-validation-for="Nombre" class="text-error"></span>
            </div>
            
            <div class="field">
                <label>Correo Institucional (Login)</label>
                <input asp-for="Correo" type="email" required maxlength="200" />
                <span asp-validation-for="Correo" class="text-error"></span>
            </div>
            
            <h3 style="margin-top:2rem;margin-bottom:1.5rem;color:#0a2d6e;font-size:16px;border-bottom:1px solid #e2e8f0;padding-bottom:10px">
                Cambio de Contraseña (Opcional)
            </h3>
            
            <div class="field">
                <label>Contraseña Actual</label>
                <input asp-for="PasswordActual" type="password" placeholder="Requerida solo si vas a cambiarla" />
                <span asp-validation-for="PasswordActual" class="text-error"></span>
            </div>
            
            <div class="field">
                <label>Nueva Contraseña</label>
                <input asp-for="PasswordNuevo" type="password" placeholder="Mínimo 6 caracteres" />
                <span asp-validation-for="PasswordNuevo" class="text-error"></span>
            </div>

            <div style="margin-top:2rem">
                <button type="submit" class="btnp">Guardar Cambios</button>
            </div>
        </form>
    </div>

    <div class="card">
        <h3 style="margin-top:0;margin-bottom:1.5rem;color:#0a2d6e;font-size:16px;border-bottom:1px solid #e2e8f0;padding-bottom:10px">
            Certificado Digital (Smart Card / Token)
        </h3>
        
        <div style="background:#f8fafc;padding:1.5rem;border-radius:6px;border:1px solid #e2e8f0;text-align:center">
            @if (Model.TieneCertificadoVinculado)
            {
                <div style="width:48px;height:48px;background:#def7ec;color:#03543f;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:24px">
                    ✓
                </div>
                <h4 style="margin:0 0 .5rem;color:#0a2d6e">Certificado Vinculado</h4>
                <p style="color:#6b7fa3;font-size:13px;margin:0 0 1.5rem">
                    Tienes un certificado digital asignado a tu cuenta. Puedes usarlo para iniciar sesión sin contraseña.
                </p>
                <div style="display:flex;gap:1rem;justify-content:center">
                    <a href="@Model.CertUrl" class="btnp">Actualizar Certificado</a>
                    <form method="post" asp-page-handler="Desvincular" style="display:inline">
                        <button type="submit" class="btnd" onclick="return confirm('¿Seguro que deseas desvincular tu certificado digital?')">Desvincular</button>
                    </form>
                </div>
            }
            else
            {
                <div style="width:48px;height:48px;background:#e1effe;color:#1e429f;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:24px">
                    🔐
                </div>
                <h4 style="margin:0 0 .5rem;color:#0a2d6e">Sin Certificado</h4>
                <p style="color:#6b7fa3;font-size:13px;margin:0 0 1.5rem">
                    No tienes ningún certificado digital vinculado. Conecta tu Smart Card (ej. Token Bit4Id) y vincúlalo para facilitar tu acceso.
                </p>
                <a href="@Model.CertUrl" class="btnp">Vincular Certificado</a>
            }
        </div>
        
        <p style="font-size:12px;color:#9aadcc;margin-top:1.5rem">
            <strong>Nota:</strong> Al hacer clic en Vincular/Actualizar, se te solicitará seleccionar tu certificado y colocar tu PIN.
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
