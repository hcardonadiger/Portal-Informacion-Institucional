@page
@model Diger.TramitesEstado.Web.Pages.Cuenta.LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "_Layout";
}

<div class="container" style="max-width:440px">
    <div class="card" style="margin-top:2rem">
        <div style="text-align:center;margin-bottom:1.5rem">
            <div class="iavt" style="margin:0 auto 12px;width:54px;height:54px;font-size:18px">DG</div>
            <h2 style="color:#0a2d6e;font-size:20px;margin:0">DIGER — Trámites Estado</h2>
            <p style="color:#6b7fa3;font-size:13px;margin-top:4px">Ingrese con su cuenta institucional</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="alert-error">@Model.Error</div>
        }

        <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
            <div class="field">
                <label>Correo institucional</label>
                <input asp-for="Correo" type="email" autocomplete="username" placeholder="usuario@diger.gob.hn" />
            </div>
            <div class="field">
                <label>Contraseña</label>
                <input asp-for="Password" type="password" autocomplete="current-password" placeholder="••••••••" />
            </div>
            <button class="btnp" type="submit" style="width:100%;justify-content:center;margin-top:.5rem">
                Iniciar sesión
            </button>
        </form>

        <form method="post" asp-page-handler="Certificado" asp-route-returnUrl="@Model.ReturnUrl" style="margin-top:1rem;padding-top:1rem;border-top:1px solid #e2e8f0;">
            <p style="text-align:center;font-size:13px;color:#6b7fa3;margin-bottom:.8rem">O si tienes certificado digital asociado:</p>
            <button class="btns" type="submit" style="width:100%;justify-content:center;">
                <span style="margin-right:6px">🔐</span> Ingresar con Certificado
            </button>
            <div style="text-align:center; margin-top:.8rem">
                <a asp-page="/Cuenta/AyudaCertificado" style="font-size:12.5px; color:#0a2d6e; text-decoration:none;">¿Cómo uso un certificado digital?</a>
            </div>
        </form>

        <div style="margin-top:1.25rem;padding-top:1rem;border-top:1px dashed #e2e8f0;font-size:11.5px;color:#9aadcc;line-height:1.7">
            <strong style="color:#6b7fa3">Usuarios de prueba</strong><br />
            admin@diger.gob.hn · Admin#2026<br />
            coordinador@diger.gob.hn · Coord#2026<br />
            tecnico@diger.gob.hn · Tecnico#2026
        </div>
    </div>
</div>
