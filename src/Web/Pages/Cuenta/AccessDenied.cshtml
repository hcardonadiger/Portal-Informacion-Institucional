@page
@model Diger.TramitesEstado.Web.Pages.Cuenta.AccessDeniedModel
@{
    ViewData["Title"] = "Acceso denegado";
    var rol = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
}

<div class="container" style="max-width:520px;text-align:center;padding-top:3rem">
    <h2 style="color:#0a2d6e;margin:.6rem 0 .3rem">Acceso denegado</h2>
    <p style="color:#5f5e5a">No tienes permiso para acceder a esta opción del portal@(string.IsNullOrEmpty(rol) ? "" : $" con el rol {rol}").</p>
    <p class="hint">Si crees que deberías tener acceso, solicítalo a un administrador.</p>
    <div style="display:flex;gap:10px;justify-content:center;margin-top:1.2rem">
        <a class="btnp" asp-page="/Tableros/Index">Ir al inicio</a>
        <form method="post" asp-page="/Cuenta/Logout"><button class="btns" type="submit">Cerrar sesión</button></form>
    </div>
</div>
