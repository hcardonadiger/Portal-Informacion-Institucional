@page "{id:int?}"
@model Diger.TramitesEstado.Web.Pages.Instituciones.EditorModel
@{
    ViewData["Title"] = Model.InstId is null ? "Nueva institución" : "Editar institución";
}

<div class="container" style="max-width:620px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:1.5rem">
        <a class="btns" asp-page="/Instituciones/Index" style="font-size:13px">← Volver</a>
        <h2 style="margin:0;font-size:18px;color:#0a2d6e">@ViewData["Title"]</h2>
    </div>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert-error">@Model.Error</div>
    }

    <form method="post" class="card">
        <div asp-validation-summary="ModelOnly" class="alert-error"></div>

        <div class="field">
            <label>Nombre / sigla de la institución <span style="color:#dc2626">*</span></label>
            <input asp-for="Nombre" placeholder="Ej: CNBS" />
            <span asp-validation-for="Nombre" class="hint error"></span>
        </div>

        @if (Model.InstId is not null)
        {
            <div class="field">
                <label class="rpill @(Model.Activo ? "on" : "")" style="display:inline-flex">
                    <input type="checkbox" asp-for="Activo" style="margin-right:6px" /> Institución activa
                </label>
            </div>
        }

        <div class="field">
            <label>Trámites de la institución <span style="font-weight:400;color:#6b7fa3">— uno por línea</span></label>
            <textarea asp-for="TramitesText" style="min-height:200px;font-family:inherit"
                      placeholder="REGISTRO DE ACTORES&#10;CERTIFICADO DE EVALUACIÓN DE RIESGO&#10;..."></textarea>
            <span class="hint">Cada línea será un trámite del catálogo de esta institución.</span>
        </div>

        <div class="nav">
            <a class="btns" asp-page="/Instituciones/Index">Cancelar</a>
            <button class="btnp" type="submit">@(Model.InstId is null ? "Crear" : "Guardar cambios")</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
