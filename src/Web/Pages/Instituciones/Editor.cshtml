@page "{id?}"
@model Diger.TramitesEstado.Web.Pages.Instituciones.EditorModel
@{
    ViewData["Title"] = Model.InstId is null ? "Nueva institución" : "Editar institución";
}

<div class="container" style="max-width:620px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:1.5rem">
        <a class="btns" asp-page="/Instituciones/Index" style="font-size:13px">← Volver</a>
        <h2 style="margin:0;font-size:18px;color:#0a2d6e">@ViewData["Title"]</h2>
    </div>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert-error">@Model.Error</div>
    }

    <form method="post" class="card">
        <div asp-validation-summary="ModelOnly" class="alert-error"></div>

        @if (Model.InstId is null)
        {
            <div class="field">
                <label>Id (Siglas) de la institución <span style="color:#dc2626">*</span></label>
                <input asp-for="Id" placeholder="Ej: CNBS" />
                <span asp-validation-for="Id" class="hint error"></span>
                <span class="hint">Identificador único en mayúsculas (ej. CNBS). No se puede cambiar después.</span>
            </div>
        }
        else
        {
            <input type="hidden" asp-for="Id" />
        }

        <div class="field">
            <label>Nombre de la institución <span style="color:#dc2626">*</span></label>
            <input asp-for="Nombre" placeholder="Ej: Comisión Nacional de Bancos y Seguros" />
            <span asp-validation-for="Nombre" class="hint error"></span>
        </div>

        @if (Model.InstId is not null)
        {
            <div class="field">
                <label class="rpill @(Model.Activo ? "on" : "")" style="display:inline-flex">
                    <input type="checkbox" asp-for="Activo" style="margin-right:6px" /> Institución activa
                </label>
            </div>
        }

        @* ── Identidad visual ── *@
        <div style="border-top:1px solid var(--diger-border);margin:16px 0 14px;padding-top:14px">
            <div style="font-size:12px;font-weight:700;color:#6b7fa3;text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px">Identidad visual</div>
            <div class="row2" style="gap:14px">
                <div class="field">
                    <label>Nombre corto / sigla</label>
                    <input asp-for="NombreCorto" placeholder="Ej: CNBS" maxlength="20" style="text-transform:uppercase" />
                    <span class="hint">Se muestra en el encabezado de la aplicación para los usuarios de esta institución.</span>
                </div>
                <div class="field" style="max-width:160px">
                    <label>Color institucional</label>
                    <div style="display:flex;gap:8px;align-items:center">
                        <input type="color" asp-for="Color" id="color-picker" style="width:44px;height:38px;padding:2px;border-radius:6px;border:1.5px solid var(--diger-border);cursor:pointer" />
                        <input asp-for="Color" id="color-hex" placeholder="#02395e" maxlength="7"
                               style="flex:1;font-family:monospace;font-size:13px"
                               oninput="syncColor('hex')" />
                    </div>
                    <span class="hint">Color primario de la institución (hex, ej: #1a5276).</span>
                </div>
            </div>
            <div class="field">
                <label>URL del logo</label>
                <input asp-for="LogoUrl" type="url" placeholder="https://…/logo.png" />
                <span class="hint">Imagen cuadrada o rectangular, fondo transparente recomendado (PNG/SVG).</span>
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <div style="margin-top:8px">
                        <img src="@Model.LogoUrl" alt="Logo actual" style="max-height:48px;max-width:180px;object-fit:contain;border:1px solid var(--diger-border);border-radius:6px;padding:4px;background:#f8fafc" />
                    </div>
                }
            </div>
            <div class="field">
                <label>Descripción</label>
                <textarea asp-for="Descripcion" rows="2" placeholder="Descripción corta de la institución (opcional)"></textarea>
            </div>
        </div>

        <div class="field">
            <label>Trámites de la institución <span style="font-weight:400;color:#6b7fa3">— uno por línea</span></label>
            <textarea asp-for="TramitesText" style="min-height:200px;font-family:inherit"
                      placeholder="REGISTRO DE ACTORES&#10;CERTIFICADO DE EVALUACIÓN DE RIESGO&#10;..."></textarea>
            <span class="hint">Cada línea será un trámite del catálogo de esta institución.</span>
        </div>

        <div class="nav">
            <a class="btns" asp-page="/Instituciones/Index">Cancelar</a>
            <button class="btnp" type="submit">@(Model.InstId is null ? "Crear" : "Guardar cambios")</button>
        </div>
    </form>

    @if (Model.Detalle is { } det)
    {
        <div class="card" style="margin-top:1rem">
            <h3 class="sec-h">Relaciones de la institución</h3>
            <div class="kpi-grid" style="margin-bottom:.4rem">
                <a class="kpi-card" style="text-decoration:none" href="/Tableros/Expedientes?institucionId=@det.Id">
                    <div class="kpi-num">@det.Expedientes</div><div class="kpi-lbl">Expedientes</div></a>
                <a class="kpi-card @(det.TicketsAbiertos > 0 ? "warn" : "")" style="text-decoration:none" href="/Tickets/Index?institucionId=@det.Id">
                    <div class="kpi-num">@det.Tickets</div><div class="kpi-lbl">Tickets · @det.TicketsAbiertos abiertos</div></a>
                <a class="kpi-card" style="text-decoration:none" href="/Tableros/Reuniones?institucionId=@det.Id">
                    <div class="kpi-num">@det.Reuniones</div><div class="kpi-lbl">Reuniones</div></a>
                <div class="kpi-card"><div class="kpi-num">@det.Contactos</div><div class="kpi-lbl">Contactos</div></div>
                <div class="kpi-card"><div class="kpi-num">@det.UsuariosAsignados</div><div class="kpi-lbl">Usuarios asignados</div></div>
                <div class="kpi-card"><div class="kpi-num">@det.Tramites.Count</div><div class="kpi-lbl">Trámites definidos</div></div>
            </div>
            <p class="hint">No se puede eliminar una institución con registros asociados; en ese caso, desactívela.</p>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var picker = document.getElementById('color-picker');
        var hex    = document.getElementById('color-hex');
        if (picker && hex) {
            picker.addEventListener('input', function () { hex.value = picker.value; });
            hex.addEventListener('input', function () {
                if (/^#[0-9a-fA-F]{6}$/.test(hex.value)) picker.value = hex.value;
            });
        }
    </script>
}
