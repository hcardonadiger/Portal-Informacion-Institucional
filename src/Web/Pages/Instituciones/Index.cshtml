@page
@model Diger.TramitesEstado.Web.Pages.Instituciones.IndexModel
@{
    ViewData["Title"] = "Catálogo de Instituciones";
}

<div class="container" style="max-width:1040px">
    <partial name="_SuccessBanner" />
    @if (TempData["ErrorMsg"] is string err)
    {
        <div class="alert-error" style="margin-bottom:1rem">@err</div>
    }
    <div class="hist-header">
        <div>
            <h2>Catálogo de Instituciones</h2>
            <p>Instituciones y sus definiciones de trámites</p>
        </div>
        <a class="btnp" asp-page="/Instituciones/Editor">+ Nueva institución</a>
    </div>

    <form method="get" class="lista-buscar">
        <input type="search" name="q" value="@Model.Q" placeholder="Buscar por nombre…" />
        <button class="btns" type="submit">Buscar</button>
        @if (!string.IsNullOrEmpty(Model.Q)) { <a class="btns" asp-page="/Instituciones/Index">Limpiar</a> }
    </form>

    @if (Model.Resultado.Total == 0)
    {
        <div class="hist-empty">
            <div class="ico"></div>
            <p>@(string.IsNullOrEmpty(Model.Q) ? "No hay instituciones registradas." : "Sin resultados para la búsqueda.")</p>
        </div>
    }
    else
    {
        <table class="seg-table">
            <thead>
                <tr>
                    <th>Institución</th>
                    <th style="text-align:center">Trámites</th>
                    <th style="text-align:center">Expedientes</th>
                    <th style="text-align:center">Tickets</th>
                    <th style="text-align:center">Reuniones</th>
                    <th style="text-align:center">Contactos</th>
                    <th style="text-align:center">Estado</th>
                    <th style="width:1%"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in Model.Resultado.Items)
                {
                    <tr>
                        <td><a class="seg-inst" asp-page="/Instituciones/Editor" asp-route-id="@i.Id">@i.Nombre</a></td>
                        <td style="text-align:center">@i.NumTramites</td>
                        <td style="text-align:center" class="res-meta">@i.Expedientes</td>
                        <td style="text-align:center" class="res-meta">@i.Tickets</td>
                        <td style="text-align:center" class="res-meta">@i.Reuniones</td>
                        <td style="text-align:center" class="res-meta">@i.Contactos</td>
                        <td style="text-align:center">
                            @if (i.Activo)
                            {
                                <span class="wf-badge wf-completada">Activa</span>
                            }
                            else
                            {
                                <span class="wf-badge wf-cancelada">Inactiva</span>
                            }
                        </td>
                        <td style="white-space:nowrap;text-align:right">
                            <a class="btns" asp-page="/Instituciones/Editor" asp-route-id="@i.Id"
                               style="font-size:12.5px;padding:6px 12px">Editar</a>
                            <form method="post" asp-page-handler="Eliminar" style="display:inline">
                                <input type="hidden" name="id" value="@i.Id" />
                                <button class="hist-del" type="submit" style="margin-left:4px"
                                        data-confirm="¿Eliminar esta institución? (solo si no tiene registros asociados)">✕</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <partial name="_Paginacion" model="new PaginacionVm(Model.Resultado.Page, Model.Resultado.TotalPages, Model.Resultado.Total, Model.Resultado.Desde, Model.Resultado.Hasta)" />
    }
</div>
