@page
@model Diger.TramitesEstado.Web.Pages.Tickets.TemasModel
@{
    ViewData["Title"] = "Categorías y temas de tickets";
}

<div class="container" style="max-width:960px">
    <partial name="_SuccessBanner" />
    @if (TempData["ErrorMsg"] is string terr)
    {
        <div class="alert-error" style="margin-bottom:1rem">@terr</div>
    }
    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert-error" style="margin-bottom:1rem">@Model.Error</div>
    }

    <div class="hist-header">
        <div>
            <h2>Categorías y temas</h2>
            <p>La <strong>categoría</strong> agrupa varios <strong>temas</strong>; cada tema define su tiempo máximo de atención (en horas).</p>
        </div>
        <a class="btns" asp-page="/Tickets/Index" style="font-size:13px">← Tickets</a>
    </div>

    @* ── Categorías (nivel superior) ─────────────────────────────── *@
    <div class="card">
        <h3 class="sec-h">Categorías</h3>
        <form method="post" asp-page-handler="CrearCategoria" style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;margin-bottom:1rem">
            <div class="field" style="margin:0;flex:1;min-width:220px">
                <label>Nueva categoría <span style="color:#dc2626">*</span></label>
                <input name="NombreCategoria" value="@Model.NombreCategoria" placeholder="p. ej. Plataforma SOL" maxlength="80" />
            </div>
            <button class="btnp" type="submit" style="margin-bottom:.1rem">Agregar categoría</button>
        </form>

        @if (!Model.Categorias.Any())
        {
            <p class="res-meta">Aún no hay categorías.</p>
        }
        else
        {
            <table class="seg-table">
                <thead><tr><th>Nombre</th><th style="width:90px">Activa</th><th style="width:1%">Temas</th><th style="width:1%"></th></tr></thead>
                <tbody>
                    @foreach (var c in Model.Categorias)
                    {
                        <tr>
                            <form method="post" asp-page-handler="ActualizarCategoria" style="display:contents">
                                <input type="hidden" name="id" value="@c.Id" />
                                <td><input name="nombre" value="@c.Nombre" maxlength="80" style="width:100%" /></td>
                                <td style="text-align:center"><input type="checkbox" name="activo" value="true" checked="@c.Activo" /></td>
                                <td class="res-meta" style="text-align:center">@c.Temas</td>
                                <td style="text-align:right"><button class="btns" type="submit" style="font-size:12.5px;padding:6px 12px">Guardar</button></td>
                            </form>
                            <td style="text-align:right">
                                <form method="post" asp-page-handler="EliminarCategoria" style="display:inline">
                                    <input type="hidden" name="id" value="@c.Id" />
                                    <button class="hist-del" type="submit" data-confirm="¿Eliminar la categoría «@c.Nombre»? Sus temas quedarán sin categoría.">✕</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* ── Temas ───────────────────────────────────────────────────── *@
    <div class="card">
        <h3 class="sec-h">Temas</h3>
        <form method="post" asp-page-handler="Crear" style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end">
            <div class="field" style="margin:0;flex:1;min-width:180px">
                <label>Nombre <span style="color:#dc2626">*</span></label>
                <input name="Nombre" value="@Model.Nombre" placeholder="p. ej. Error en plataforma" maxlength="80" />
            </div>
            <div class="field" style="margin:0;width:190px">
                <label>Categoría</label>
                <select name="CategoriaId">
                    <option value="">— Sin categoría —</option>
                    @foreach (var c in Model.Categorias)
                    {
                        <option value="@c.Id">@c.Nombre</option>
                    }
                </select>
            </div>
            <div class="field" style="margin:0;width:150px">
                <label>Tiempo máximo (horas)</label>
                <input type="number" name="HorasResolucion" min="0" max="100000" placeholder="0 = sin límite" />
            </div>
            <button class="btnp" type="submit" style="margin-bottom:.1rem">Agregar tema</button>
        </form>

        @if (!Model.Temas.Any())
        {
            <p class="res-meta" style="margin-top:1rem">Aún no hay temas.</p>
        }
        else
        {
            <table class="seg-table" style="margin-top:1rem">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th style="width:180px">Categoría</th>
                        <th style="width:110px">Tiempo máx. (h)</th>
                        <th style="width:80px">Activo</th>
                        <th style="width:1%">Uso</th>
                        <th style="width:1%"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tm in Model.Temas)
                    {
                        <tr>
                            <form method="post" asp-page-handler="Actualizar" style="display:contents">
                                <input type="hidden" name="id" value="@tm.Id" />
                                <td><input name="nombre" value="@tm.Nombre" maxlength="80" style="width:100%" /></td>
                                <td>
                                    <select name="categoriaId" style="width:100%">
                                        <option value="">— Sin categoría —</option>
                                        @foreach (var c in Model.Categorias)
                                        {
                                            <option value="@c.Id" selected="@(c.Id == tm.CategoriaId)">@c.Nombre</option>
                                        }
                                    </select>
                                </td>
                                <td><input type="number" name="horas" min="0" max="100000" value="@tm.HorasResolucion" style="width:100%" /></td>
                                <td style="text-align:center"><input type="checkbox" name="activo" value="true" checked="@tm.Activo" /></td>
                                <td class="res-meta" style="white-space:nowrap">
                                    <span title="Tickets">@tm.Tickets</span>
                                    <span title="Especialistas" style="margin-left:6px">@tm.Especialistas</span>
                                </td>
                                <td style="text-align:right"><button class="btns" type="submit" style="font-size:12.5px;padding:6px 12px">Guardar</button></td>
                            </form>
                            <td style="text-align:right">
                                @if (tm.Tickets == 0)
                                {
                                    <form method="post" asp-page-handler="Eliminar" style="display:inline">
                                        <input type="hidden" name="id" value="@tm.Id" />
                                        <button class="hist-del" type="submit" data-confirm="¿Eliminar el tema «@tm.Nombre»?">✕</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="res-meta" title="Tiene tickets: desactívalo en lugar de eliminarlo">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <p class="hint" style="margin-top:.7rem">Tiempo máximo = plazo de atención en horas (0 = sin límite). Un tema con tickets no se elimina; desactívalo.</p>
        }
    </div>
</div>
