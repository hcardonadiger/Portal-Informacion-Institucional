@page
@model Diger.TramitesEstado.Web.Pages.Tickets.IndexModel
@{
    ViewData["Title"] = "Tickets de soporte";
    var puedeGestionar = User.IsInRole(nameof(RolUsuario.Administrador)) || User.IsInRole(nameof(RolUsuario.Coordinador)) || User.IsInRole(nameof(RolUsuario.Tecnico));
    var puedeEliminar  = User.IsInRole(nameof(RolUsuario.Administrador)) || User.IsInRole(nameof(RolUsuario.Coordinador));

    (string bg, string fg) EstadoColor(EstadoTicket e) => e switch
    {
        EstadoTicket.Abierto    => ("#e6f1fb", "#0c447c"),
        EstadoTicket.EnProgreso => ("#faeeda", "#854f0b"),
        EstadoTicket.Resuelto   => ("#eaf3de", "#27500a"),
        _                       => ("#f1efe8", "#444441"),
    };
    (string bg, string fg) PrioColor(PrioridadTicket p) => p switch
    {
        PrioridadTicket.Critica => ("#fcebeb", "#a32d2d"),
        PrioridadTicket.Alta    => ("#faece7", "#993c1d"),
        PrioridadTicket.Media   => ("#e6f1fb", "#185fa5"),
        _                       => ("#f1efe8", "#5f5e5a"),
    };
    string EstadoLbl(EstadoTicket e) => e switch
    {
        EstadoTicket.EnProgreso => "En progreso", _ => e.ToString()
    };
    var estados = new[] { EstadoTicket.Abierto, EstadoTicket.EnProgreso, EstadoTicket.Resuelto, EstadoTicket.Cerrado };
}

<div class="container" style="max-width:1100px">
    @if (TempData["SuccessMsg"] is string ok)
    {
        <div class="alert-ok" style="margin-bottom:1rem">✅ @ok</div>
    }
    <div class="hist-header">
        <div>
            <h2>Tickets de soporte</h2>
            <p>Incidencias y solicitudes sobre la plataforma SOL</p>
        </div>
        @if (puedeGestionar)
        {
            <a class="btnp" asp-page="/Tickets/Editor">+ Nuevo ticket</a>
        }
    </div>

    <form method="get" class="card" style="padding:.9rem 1rem;margin-bottom:1.1rem;display:flex;gap:14px;flex-wrap:wrap;align-items:flex-end">
        <div class="field" style="margin:0;min-width:150px">
            <label>Estado</label>
            <select name="estado" onchange="this.form.submit()">
                <option value="">Todos</option>
                @foreach (var e in estados) { <option value="@e" selected="@(Model.Estado == e)">@EstadoLbl(e)</option> }
            </select>
        </div>
        <div class="field" style="margin:0;min-width:130px">
            <label>Prioridad</label>
            <select name="prioridad" onchange="this.form.submit()">
                <option value="">Todas</option>
                @foreach (var p in Enum.GetValues<PrioridadTicket>()) { <option value="@p" selected="@(Model.Prioridad == p)">@p</option> }
            </select>
        </div>
        <div class="field" style="margin:0;min-width:170px">
            <label>Institución</label>
            <select name="institucionId" onchange="this.form.submit()">
                <option value="">Todas</option>
                @foreach (var i in Model.Instituciones) { <option value="@i.Id" selected="@(Model.InstitucionId == i.Id)">@i.Nombre</option> }
            </select>
        </div>
        <label class="chk" style="margin:0 0 .45rem">
            <input type="checkbox" name="mias" value="true" checked="@Model.Mias" onchange="this.form.submit()" />
            <span>Mis tickets</span>
        </label>
        <a class="btns" asp-page="/Tickets/Index" style="margin-bottom:.45rem">Limpiar</a>
    </form>

    @if (!Model.Tickets.Any())
    {
        <div class="hist-empty">
            <div class="ico">🎫</div>
            <p>No hay tickets@(Model.Estado is null ? "" : " en este estado").</p>
        </div>
    }
    else
    {
        <table class="seg-table">
            <thead>
                <tr>
                    <th style="width:1%">Nº</th>
                    <th>Título</th>
                    <th>Institución</th>
                    <th>Prioridad</th>
                    <th>Estado</th>
                    <th>Asignado</th>
                    <th style="width:1%"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Tickets)
                {
                    var ec = EstadoColor(t.Estado);
                    var pc = PrioColor(t.Prioridad);
                    <tr>
                        <td class="res-meta" style="white-space:nowrap;font-variant-numeric:tabular-nums">@t.Numero</td>
                        <td><a class="seg-inst" asp-page="/Tickets/Detalle" asp-route-id="@t.Id">@t.Titulo</a>
                            @if (t.NumComentarios > 0)
                            {
                                <span class="res-meta" style="margin-left:6px">💬 @t.NumComentarios</span>
                            }
                        </td>
                        <td class="res-meta">@(t.Institucion ?? "—")</td>
                        <td><span style="background:@pc.bg;color:@pc.fg;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:700">@t.Prioridad</span></td>
                        <td><span style="background:@ec.bg;color:@ec.fg;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:700">@EstadoLbl(t.Estado)</span></td>
                        <td class="res-meta">@(t.AsignadoA ?? "—")</td>
                        <td style="white-space:nowrap;text-align:right">
                            <a class="btns" asp-page="/Tickets/Detalle" asp-route-id="@t.Id"
                               style="font-size:12.5px;padding:6px 12px">Abrir</a>
                            @if (puedeEliminar)
                            {
                                <form method="post" asp-page-handler="Eliminar" style="display:inline">
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <button class="hist-del" type="submit" style="margin-left:4px"
                                            onclick="return confirm('¿Eliminar este ticket?')">✕</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
