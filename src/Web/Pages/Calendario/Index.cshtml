@page
@model Diger.TramitesEstado.Web.Pages.Calendario.IndexModel
@{
    ViewData["Title"] = "Calendario";
    var meses = new[] { "", "Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre" };
    var dias = new[] { "Dom", "Lun", "Mar", "Mié", "Jue", "Vie", "Sáb" };
    var primer = Model.PrimerDia;
    var offset = (int)primer.DayOfWeek;            // Domingo = 0
    var inicioGrid = primer.AddDays(-offset);
    var totalReuniones = Model.Data.Reuniones.Count;
    var cultEs = System.Globalization.CultureInfo.GetCultureInfo("es");
}

<div class="container" style="max-width:1280px">
    <partial name="_SuccessBanner" />

    <div class="cal-toolbar">
        <div class="cal-nav">
            <a class="btns" asp-page="/Calendario/Index" asp-route-anio="@Model.MesAnterior.Year" asp-route-mes="@Model.MesAnterior.Month">◀</a>
            <h2 class="cal-title">@meses[primer.Month] @primer.Year</h2>
            <a class="btns" asp-page="/Calendario/Index" asp-route-anio="@Model.MesSiguiente.Year" asp-route-mes="@Model.MesSiguiente.Month">▶</a>
            <a class="btns" asp-page="/Calendario/Index">Hoy</a>
        </div>
        <div style="display:flex;gap:8px;align-items:center">
            <span class="res-meta">@totalReuniones reunión(es) · @Model.Data.Actividad.Count actividad(es)</span>
            @if (Model.PuedeGestionar)
            {
                <a class="btnp" asp-page="/Reuniones/Editor">+ Nueva reunión</a>
            }
        </div>
    </div>

    <div class="cal-layout">
        @* ── Calendario ──────────────────────────────────────────── *@
        <div class="cal-cal">
            <div class="cal-grid cal-head">
                @foreach (var d in dias) { <div class="cal-dow">@d</div> }
            </div>
            <div class="cal-grid cal-body">
                @for (var i = 0; i < 42; i++)
                {
                    var dia = inicioGrid.AddDays(i);
                    var esMes = dia.Month == primer.Month && dia.Year == primer.Year;
                    var esHoy = dia == Model.Hoy;
                    var reus = Model.ReunionesPorDia[dia].ToList();
                    var acts = Model.ActividadPorDia[dia].ToList();
                    <div class="cal-cell@(esMes ? "" : " cal-out")@(esHoy ? " cal-today" : "")">
                        <div class="cal-cell-top">
                            <span class="cal-num">@dia.Day</span>
                            @if (Model.PuedeGestionar && esMes)
                            {
                                <a class="cal-add" title="Nueva reunión este día"
                                   asp-page="/Reuniones/Editor" asp-route-fecha="@dia.ToString("yyyy-MM-dd")">+</a>
                            }
                        </div>
                        @foreach (var r in reus.Take(3))
                        {
                            var destino = Model.PuedeGestionar ? "/Reuniones/Editor" : "/Reuniones/Acta";
                            <a class="cal-chip" data-tipo="Reunion" asp-page="@destino" asp-route-id="@r.Id"
                               title="@(r.Privada ? "Privada · " : "")@(string.IsNullOrWhiteSpace(r.Hora) ? "" : r.Hora + " · ")@r.Titulo@(string.IsNullOrWhiteSpace(r.Institucion) ? "" : " — " + r.Institucion)">
                                @if (!string.IsNullOrWhiteSpace(r.Hora)) { <b>@r.Hora</b> }
                                @r.Titulo
                            </a>
                        }
                        @if (reus.Count > 3)
                        {
                            <div class="cal-mas" data-tipo="Reunion">+@(reus.Count - 3) reunión(es)</div>
                        }
                        @if (acts.Any())
                        {
                            <div class="cal-dots" title="@acts.Count acción(es) en el portal">
                                @foreach (var e in acts.Take(6))
                                {
                                    var ui = CalendarioUi.Evento(e.Tipo);
                                    <span class="cal-dot" data-tipo="@e.Tipo" style="background:@ui.Color" title="@ui.Etiqueta"></span>
                                }
                                @if (acts.Count > 6) { <span class="cal-dot-mas">+@(acts.Count - 6)</span> }
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="cal-legend">
                <span class="res-meta" style="font-size:12px;align-self:center">Mostrar:</span>
                @foreach (var t in Enum.GetValues<TipoEventoCalendario>())
                {
                    var ui = CalendarioUi.Evento(t);
                    <button type="button" class="cal-filtro on" data-filtro="@t" onclick="toggleFiltro(this)">
                        <span class="cal-dot" style="background:@ui.Color"></span> @ui.Etiqueta
                    </button>
                }
            </div>
        </div>

        @* ── Feed de actividad ───────────────────────────────────── *@
        <div class="cal-feed">
            <h3>Actividad del mes</h3>
            @if (!Model.Data.Actividad.Any())
            {
                <p class="res-meta" style="padding:.5rem 0">Sin acciones registradas en el portal este mes.</p>
            }
            else
            {
                DateOnly? ultimoDia = null;
                foreach (var e in Model.Data.Actividad)
                {
                    if (ultimoDia != e.Fecha)
                    {
                        ultimoDia = e.Fecha;
                        <div class="cal-feed-day">@e.Fecha.ToString("dddd dd 'de' MMMM", cultEs)</div>
                    }
                    var ui = CalendarioUi.Evento(e.Tipo);
                    <a class="cal-ev" data-tipo="@e.Tipo" asp-page="@e.Pagina" asp-route-id="@e.RefId">
                        <span class="cal-ev-ico" style="background:@(ui.Color)1a;color:@ui.Color">@ui.Icono</span>
                        <span class="cal-ev-body">
                            <span class="cal-ev-top">
                                <b>@ui.Etiqueta</b>
                                @if (!string.IsNullOrWhiteSpace(e.Etiqueta)) { <span class="cal-ev-tag">@e.Etiqueta</span> }
                                <span class="cal-ev-time">@e.Cuando.ToString("HH:mm")</span>
                            </span>
                            <span class="cal-ev-titulo">@e.Titulo</span>
                            @if (!string.IsNullOrWhiteSpace(e.Detalle))
                            {
                                <span class="cal-ev-det">@(e.Detalle!.Length > 90 ? e.Detalle[..90] + "…" : e.Detalle)</span>
                            }
                        </span>
                    </a>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
  var CAL_KEY = 'cal.filtros.ocultos';
  function ocultos(){ try { return new Set(JSON.parse(localStorage.getItem(CAL_KEY) || '[]')); } catch (e) { return new Set(); } }

  function aplicarFiltros(){
    var off = ocultos();
    document.querySelectorAll('[data-tipo]').forEach(function(el){
      el.style.display = off.has(el.getAttribute('data-tipo')) ? 'none' : '';
    });
    document.querySelectorAll('.cal-filtro').forEach(function(b){
      var on = !off.has(b.getAttribute('data-filtro'));
      b.classList.toggle('on', on); b.classList.toggle('off', !on);
    });
    // Oculta encabezados de día del feed que quedaron sin eventos visibles.
    document.querySelectorAll('.cal-feed-day').forEach(function(h){
      var visible = false, n = h.nextElementSibling;
      while (n && n.classList.contains('cal-ev')) {
        if (n.style.display !== 'none') { visible = true; break; }
        n = n.nextElementSibling;
      }
      h.style.display = visible ? '' : 'none';
    });
  }

  function toggleFiltro(btn){
    var t = btn.getAttribute('data-filtro');
    var off = ocultos();
    if (off.has(t)) off.delete(t); else off.add(t);
    localStorage.setItem(CAL_KEY, JSON.stringify(Array.from(off)));
    aplicarFiltros();
  }

  aplicarFiltros();
</script>
}
