@using Diger.TramitesEstado.Application.Accesos
@using System.Security.Claims
@using System.Text.Json
@using Diger.TramitesEstado.Application.Usuarios.Queries.AutenticarUsuario
@using Diger.TramitesEstado.Infrastructure.Security
@inject Diger.TramitesEstado.Web.Common.AccesoModulosService Acceso

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DIGER</title>
    <link rel="stylesheet" href="~/css/diger.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <header class="topnav">
            <div class="topnav-inner">
                <a class="topnav-brand" asp-page="/Tableros/Index">
                    <span class="topnav-logo">DG</span> Portal DIGER
                </a>
                <nav class="topnav-links">
                    @if (await Acceso.PuedeAsync(ModulosPortal.Tableros)) { <a asp-page="/Tableros/Index">Tableros</a> }
                    @if (await Acceso.PuedeAsync(ModulosPortal.Calendario)) { <a asp-page="/Calendario/Index">Calendario</a> }
                    @if (await Acceso.PuedeAsync(ModulosPortal.Expedientes)) { <a asp-page="/Index">Expedientes</a> }
                    @if (await Acceso.PuedeAsync(ModulosPortal.Reuniones))
                    {
                        <a asp-page="/Reuniones/Index">Reuniones</a>
                        <a asp-page="/Reuniones/Compromisos">Compromisos</a>
                    }
                    @if (await Acceso.PuedeAsync(ModulosPortal.Tickets)) { <a asp-page="/Tickets/Index">Tickets</a> }
                    @if (await Acceso.PuedeAsync(ModulosPortal.Contactos)) { <a asp-page="/Contactos/Index">Contactos</a> }
                    @if (Acceso.EsAdministrador)
                    {
                        <a asp-page="/Instituciones/Index">Instituciones</a>
                        <a asp-page="/Usuarios/Index">Usuarios</a>
                        <a asp-page="/Accesos/Index">Accesos</a>
                    }
                </nav>
                <div class="topnav-user">
                    @{
                        var asignacionesJson = User.FindFirstValue(AppClaims.AsignacionesJson);
                        List<AsignacionDto>? asignaciones = null;
                        if (!string.IsNullOrWhiteSpace(asignacionesJson))
                        {
                            try { asignaciones = JsonSerializer.Deserialize<List<AsignacionDto>>(asignacionesJson); }
                            catch { }
                        }
                    }

                    @if (asignaciones != null && asignaciones.Count > 1)
                    {
                        var activeArea = User.FindFirstValue(AppClaims.ActiveArea);
                        var activeUnidad = User.FindFirstValue(AppClaims.ActiveUnidad);
                        var activeInst = User.FindFirstValue(AppClaims.ActiveInstitucion);
                        var activeRol = User.FindFirstValue(AppClaims.ActiveRol);

                        // Find the current index based on claims
                        int currentIndex = asignaciones.FindIndex(a => 
                            a.InstitucionId == activeInst && 
                            a.AreaId == activeArea && 
                            a.UnidadId == activeUnidad &&
                            a.Rol == activeRol);

                        <form method="post" asp-page="/Cuenta/CambiarContexto" style="display:inline; margin-right: 15px;">
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <select name="indiceSeleccionado" onchange="this.form.submit()" class="form-select form-select-sm" style="display:inline-block; width:auto; font-size:0.85rem;">
                                @for (int i = 0; i < asignaciones.Count; i++)
                                {
                                    var a = asignaciones[i];
                                    var label = $"{a.Rol} - {a.InstitucionId}" + 
                                                (a.AreaId != null ? $" / {a.AreaId}" : "") + 
                                                (a.UnidadId != null ? $" / {a.UnidadId}" : "");
                                    if (i == currentIndex)
                                    {
                                        <option value="@i" selected>@label</option>
                                    }
                                    else
                                    {
                                        <option value="@i">@label</option>
                                    }
                                }
                            </select>
                        </form>
                    }

                    <span class="topnav-name">@User.Identity!.Name</span>
                    <span class="topnav-rol">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</span>
                    <form method="post" asp-page="/Cuenta/Logout" style="display:inline">
                        <button type="submit" class="topnav-logout" title="Cerrar sesión">Salir</button>
                    </form>
                </div>
            </div>
        </header>
    }
    @RenderBody()
    <script src="~/js/diger.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
