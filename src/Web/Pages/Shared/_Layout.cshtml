@using Diger.TramitesEstado.Application.Accesos
@inject Diger.TramitesEstado.Web.Common.AccesoModulosService Acceso
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DIGER</title>
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/diger.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <header class="topnav">
            <div class="topnav-inner">
                <a class="topnav-brand" asp-page="/Tableros/Index">
                    <img src="~/img/logo_diger.png" asp-append-version="true" class="topnav-logo-img" alt="DIGER" />
                </a>
                <nav class="topnav-links">
                    @{
                        var puedeTableros    = await Acceso.PuedeAsync(ModulosPortal.Tableros);
                        var puedeCalendario  = await Acceso.PuedeAsync(ModulosPortal.Calendario);
                        var puedeExpedientes = await Acceso.PuedeAsync(ModulosPortal.Expedientes);
                        var puedeReuniones   = await Acceso.PuedeAsync(ModulosPortal.Reuniones);
                        var puedeTickets     = await Acceso.PuedeAsync(ModulosPortal.Tickets);
                        var puedeContactos   = await Acceso.PuedeAsync(ModulosPortal.Contactos);
                    }
                    @if (puedeTableros || puedeCalendario || puedeExpedientes)
                    {
                        <div class="topnav-dropdown">
                            <a href="javascript:void(0)" class="topnav-dropdown-trigger">
                                Seguimiento <span class="topnav-chevron">&#9662;</span>
                            </a>
                            <div class="topnav-dropdown-menu">
                                <div class="topnav-dropdown-menu-inner">
                                    @if (puedeTableros) { <a asp-page="/Tableros/Index">Tableros</a> }
                                    @if (puedeCalendario) { <a asp-page="/Calendario/Index">Calendario</a> }
                                    @if (puedeExpedientes) { <a asp-page="/Index">Expedientes</a> }
                                </div>
                            </div>
                        </div>
                    }
                    @if (puedeReuniones)
                    {
                        <div class="topnav-dropdown">
                            <a href="javascript:void(0)" class="topnav-dropdown-trigger">
                                Pendientes <span class="topnav-chevron">&#9662;</span>
                            </a>
                            <div class="topnav-dropdown-menu">
                                <div class="topnav-dropdown-menu-inner">
                                    <a asp-page="/Reuniones/Index">Reuniones</a>
                                    <a asp-page="/Reuniones/Compromisos">Compromisos</a>
                                </div>
                            </div>
                        </div>
                    }
                    @if (puedeTickets) { <a asp-page="/Tickets/Index">Tickets</a> }
                    @if (puedeContactos) { <a asp-page="/Contactos/Index">Contactos</a> }
                    @if (Acceso.EsAdministrador)
                    {
                        <a asp-page="/Instituciones/Index">Instituciones</a>
                        <div class="topnav-dropdown">
                            <a href="javascript:void(0)" class="topnav-dropdown-trigger">
                                Seguridad <span class="topnav-chevron">&#9662;</span>
                            </a>
                            <div class="topnav-dropdown-menu">
                                <div class="topnav-dropdown-menu-inner">
                                    <a asp-page="/Usuarios/Index">Usuarios</a>
                                    <a asp-page="/Accesos/Index">Accesos</a>
                                </div>
                            </div>
                        </div>
                    }
                </nav>
                <div class="topnav-user">
                    <span class="topnav-name">@User.Identity!.Name</span>
                    <span class="topnav-rol">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</span>
                    <form method="post" asp-page="/Cuenta/Logout" style="display:inline">
                        <button type="submit" class="topnav-logout" title="Cerrar sesión">Salir</button>
                    </form>
                </div>
            </div>
        </header>
    }
    @RenderBody()
    <script src="~/js/diger.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
