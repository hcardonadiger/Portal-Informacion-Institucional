@using Diger.TramitesEstado.Application.Accesos
@using System.Security.Claims
@using System.Text.Json
@using Diger.TramitesEstado.Application.Usuarios.Queries.AutenticarUsuario
@using Diger.TramitesEstado.Infrastructure.Security
@using Diger.TramitesEstado.Web.Common
@inject AccesoModulosService Acceso
@inject JerarquiaUiService JerarquiaUi
@inject IInstitucionBrandingService BrandingSvc
@{
    var _activeInstId = User.FindFirstValue(AppClaims.ActiveInstitucion);
    var _instBranding = await BrandingSvc.GetAsync(_activeInstId);

    bool EsRuta(params string[] prefijos)
    {
        var path = Context.Request.Path;
        foreach (var p in prefijos)
        {
            if (p == "/") { if (path == "/" || path == "") return true; }
            else if (path.StartsWithSegments(p, StringComparison.OrdinalIgnoreCase)) return true;
        }
        return false;
    }

    string Iniciales(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return "?";
        var partes = nombre.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var s = partes.Length >= 2 ? $"{partes[0][0]}{partes[1][0]}" : partes[0][..Math.Min(2, partes[0].Length)];
        return s.ToUpperInvariant();
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="@(_instBranding?.Color ?? "#02395e")" />
    <title>@ViewData["Title"] — DIGER</title>

    @* Token Anti-CSRF disponible para peticiones AJAX/Fetch futuras *@
    @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
    @{ var token = Antiforgery.GetAndStoreTokens(Context).RequestToken; }
    <meta name="csrf-token" content="@token" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/diger.css" asp-append-version="true" />
    @if (_instBranding?.Color is { Length: > 0 } instColor)
    {
        <style>:root { --diger-blue: @instColor; --diger-blue-dark: @instColor; --diger-blue-mid: @instColor; }</style>
    }
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        var puedeTableros    = await Acceso.PuedeAsync(ModulosPortal.Tableros);
        var puedeCalendario  = await Acceso.PuedeAsync(ModulosPortal.Calendario);
        var puedeExpedientes = await Acceso.PuedeAsync(ModulosPortal.Expedientes);
        var puedeReuniones   = await Acceso.PuedeAsync(ModulosPortal.Reuniones);
        var puedeTickets     = await Acceso.PuedeAsync(ModulosPortal.Tickets);
        var puedeContactos   = await Acceso.PuedeAsync(ModulosPortal.Contactos);

        var asignacionesJson = User.FindFirstValue(AppClaims.AsignacionesJson);
        List<AsignacionAuthDto>? asignaciones = null;
        if (!string.IsNullOrWhiteSpace(asignacionesJson))
        {
            try { asignaciones = JsonSerializer.Deserialize<List<AsignacionAuthDto>>(asignacionesJson); }
            catch { }
        }

        var rolFiltro = User.FindFirstValue(AppClaims.ActiveRol);
        bool showAsignaciones = asignaciones != null && asignaciones.Count > 1;
        bool showJerarquia = rolFiltro == "JefeInstitucion" || rolFiltro == "JefeArea";
        <div class="app-shell">
            <div class="gov-bar">
                <div class="gov-bar-inner">
                    <span>Gobierno de la República de Honduras</span>
                    <a href="https://www.diger.gob.hn" target="_blank" rel="noopener">diger.gob.hn</a>
                </div>
            </div>
            <header class="app-header">
                <div class="app-header-inner">
                    <a class="app-brand" asp-page="/Tableros/Index" title="Inicio">
                        <span class="app-brand-word">DIGER</span>
                        <span class="app-brand-divider"></span>
                        @if (_instBranding is not null)
                        {
                            if (!string.IsNullOrEmpty(_instBranding.LogoUrl))
                            {
                                <img src="@_instBranding.LogoUrl" class="app-brand-inst-logo"
                                     alt="@(_instBranding.NombreCorto ?? _instBranding.Nombre)" />
                            }
                            <span class="app-brand-inst">@(_instBranding.NombreCorto ?? _instBranding.Nombre)</span>
                        }
                        else
                        {
                            <span class="app-brand-title">Digitalización de Trámites</span>
                        }
                    </a>

                    <button type="button" class="nav-toggle" onclick="toggleMainNav()" aria-label="Abrir menú">&#9776;</button>

                    <nav class="main-nav" id="mainNav">
                        @if (puedeTableros || puedeCalendario || puedeExpedientes)
                        {
                            var grpSeg = EsRuta("/Tableros") || EsRuta("/Calendario") || EsRuta("/", "/Expedientes");
                            <div class="nav-group @(grpSeg ? "on" : "")">
                                <button type="button" class="nav-group-btn" onclick="toggleNavGroup(this)">Seguimiento<span class="nav-caret">&#9662;</span></button>
                                <div class="nav-group-menu">
                                    @if (puedeTableros)
                                    {
                                        <a class="nav-item @(EsRuta("/Tableros") ? "on" : "")" asp-page="/Tableros/Index">Tableros</a>
                                    }
                                    @if (puedeCalendario)
                                    {
                                        <a class="nav-item @(EsRuta("/Calendario") ? "on" : "")" asp-page="/Calendario/Index">Calendario</a>
                                    }
                                    @if (puedeExpedientes)
                                    {
                                        <a class="nav-item @(EsRuta("/", "/Expedientes") ? "on" : "")" asp-page="/Index">Expedientes</a>
                                    }
                                </div>
                            </div>
                        }
                        @if (puedeReuniones)
                        {
                            var grpPend = EsRuta("/Reuniones");
                            <div class="nav-group @(grpPend ? "on" : "")">
                                <button type="button" class="nav-group-btn" onclick="toggleNavGroup(this)">Pendientes<span class="nav-caret">&#9662;</span></button>
                                <div class="nav-group-menu">
                                    <a class="nav-item @(EsRuta("/Reuniones") && !EsRuta("/Reuniones/Compromisos") ? "on" : "")" asp-page="/Reuniones/Index">Reuniones</a>
                                    <a class="nav-item @(EsRuta("/Reuniones/Compromisos") ? "on" : "")" asp-page="/Reuniones/Compromisos">Compromisos</a>
                                </div>
                            </div>
                        }
                        @if (puedeTickets || puedeContactos)
                        {
                            var grpTram = EsRuta("/Tickets") || EsRuta("/Contactos");
                            <div class="nav-group @(grpTram ? "on" : "")">
                                <button type="button" class="nav-group-btn" onclick="toggleNavGroup(this)">Trámites<span class="nav-caret">&#9662;</span></button>
                                <div class="nav-group-menu">
                                    @if (puedeTickets)
                                    {
                                        <a class="nav-item @(EsRuta("/Tickets") ? "on" : "")" asp-page="/Tickets/Index">Tickets</a>
                                    }
                                    @if (puedeContactos)
                                    {
                                        <a class="nav-item @(EsRuta("/Contactos") ? "on" : "")" asp-page="/Contactos/Index">Contactos</a>
                                    }
                                </div>
                            </div>
                        }
                        @if (Acceso.EsAdministrador)
                        {
                            var grpAdmin = EsRuta("/Instituciones") || EsRuta("/Areas") || EsRuta("/Unidades") || EsRuta("/Usuarios") || EsRuta("/Accesos");
                            <div class="nav-group @(grpAdmin ? "on" : "")">
                                <button type="button" class="nav-group-btn" onclick="toggleNavGroup(this)">Administración<span class="nav-caret">&#9662;</span></button>
                                <div class="nav-group-menu">
                                    <a class="nav-item @(EsRuta("/Instituciones") ? "on" : "")" asp-page="/Instituciones/Index">Instituciones</a>
                                    <a class="nav-item @(EsRuta("/Areas") ? "on" : "")" asp-page="/Areas/Index">Áreas</a>
                                    <a class="nav-item @(EsRuta("/Unidades") ? "on" : "")" asp-page="/Unidades/Index">Unidades</a>
                                    <a class="nav-item @(EsRuta("/Usuarios") ? "on" : "")" asp-page="/Usuarios/Index">Usuarios</a>
                                    <a class="nav-item @(EsRuta("/Accesos") ? "on" : "")" asp-page="/Accesos/Index">Accesos</a>
                                </div>
                            </div>
                        }
                    </nav>

                    <div class="header-right">
                        <button type="button" class="header-icon" title="Notificaciones (0)">&#128276;</button>
                        <div class="user-menu">
                            <button type="button" class="user-menu-btn" onclick="toggleUserPanel()">
                                <span class="side-avatar">@Iniciales(User.Identity!.Name)</span>
                                <span class="user-menu-meta">
                                    <span class="user-menu-name">@User.Identity!.Name</span>
                                    <span class="user-menu-rol">@(User.FindFirst(ClaimTypes.Role)?.Value)</span>
                                </span>
                                <span class="nav-caret">&#9662;</span>
                            </button>
                            <div class="user-menu-panel" id="sideUserPanel">
                        @if (showAsignaciones)
                        {
                            var activeArea = User.FindFirstValue(AppClaims.ActiveArea);
                            var activeUnidad = User.FindFirstValue(AppClaims.ActiveUnidad);
                            var activeInst = User.FindFirstValue(AppClaims.ActiveInstitucion);
                            var activeRol = User.FindFirstValue(AppClaims.ActiveRol);
                            int currentIndex = asignaciones!.FindIndex(a =>
                                a.InstitucionId == activeInst && a.AreaId == activeArea &&
                                a.UnidadId == activeUnidad && a.Rol == activeRol);

                            <div class="side-panel-section">
                                <div class="side-panel-label">Contexto activo</div>
                                <form method="post" asp-page="/Cuenta/CambiarContexto">
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <select name="indiceSeleccionado" onchange="this.form.submit()">
                                        @for (int i = 0; i < asignaciones.Count; i++)
                                        {
                                            var a = asignaciones[i];
                                            var label = $"{a.Rol} - {a.InstitucionId}" + (a.AreaId != null ? $" / {a.AreaId}" : "") + (a.UnidadId != null ? $" / {a.UnidadId}" : "");
                                            if (i == currentIndex) { <option value="@i" selected>@label</option> }
                                            else { <option value="@i">@label</option> }
                                        }
                                    </select>
                                </form>
                            </div>
                        }

                        @if (showJerarquia)
                        {
                            var currentArea = User.FindFirstValue(AppClaims.ActiveArea);
                            var currentUnidad = User.FindFirstValue(AppClaims.ActiveUnidad);

                            <div class="side-panel-section">
                                <div class="side-panel-label">Filtrar por jerarquía</div>
                                <form method="post" asp-page="/Cuenta/CambiarFiltroJerarquia">
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                    @if (rolFiltro == "JefeInstitucion")
                                    {
                                        var areas = await JerarquiaUi.GetAreasAsync();
                                        <select name="areaId" onchange="this.form.submit()">
                                            <option value="">-- Toda la Institución --</option>
                                            @foreach (var a in areas)
                                            {
                                                if (a.Id == currentArea) { <option value="@a.Id" selected>@a.Nombre</option> }
                                                else { <option value="@a.Id">@a.Nombre</option> }
                                            }
                                        </select>
                                    }
                                    else if (rolFiltro == "JefeArea")
                                    {
                                        <input type="hidden" name="areaId" value="@currentArea" />
                                    }

                                    @if ((rolFiltro == "JefeInstitucion" && !string.IsNullOrEmpty(currentArea)) || rolFiltro == "JefeArea")
                                    {
                                        var unidades = await JerarquiaUi.GetUnidadesAsync(currentArea);
                                        <select name="unidadId" onchange="this.form.submit()">
                                            <option value="">-- Todas las Unidades --</option>
                                            @foreach (var u in unidades)
                                            {
                                                if (u.Id == currentUnidad) { <option value="@u.Id" selected>@u.Nombre</option> }
                                                else { <option value="@u.Id">@u.Nombre</option> }
                                            }
                                        </select>
                                    }
                                </form>
                            </div>
                        }

                        <a class="user-panel-link" asp-page="/Cuenta/Perfil">Mi perfil</a>
                        <button type="submit" form="logoutForm" class="side-panel-logout">Cerrar sesión</button>
                    </div>
                            <form id="logoutForm" method="post" asp-page="/Cuenta/Logout" style="display:none"></form>
                        </div>
                    </div>
            </div>
                <div class="nav-backdrop" id="navBackdrop" onclick="toggleMainNav(false)"></div>
            </header>

            <main class="app-main">
                @RenderBody()
            </main>

            <footer class="diger-footer">
                <div class="diger-footer-inner">
                    <span>© @DateTime.Now.Year DIGER — Gobierno de la República de Honduras. Todos los derechos reservados.</span>
                    <a href="https://www.diger.gob.hn" target="_blank" rel="noopener">Portal DIGER</a>
                </div>
            </footer>
        </div>
    }
    else
    {
        @RenderBody()
    }
    <script src="~/js/diger.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
