@model Diger.TramitesEstado.Web.Models.PaginacionVm
@{
    var query = Context.Request.Query;
    Func<int, string> Link = p =>
    {
        var parts = query.Where(kv => kv.Key != "pg")
            .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value.ToString())}").ToList();
        parts.Add("pg=" + p);
        return Context.Request.Path + "?" + string.Join("&", parts);
    };
    var ini = Math.Max(1, Model.Page - 2);
    var fin = Math.Min(Model.TotalPages, Model.Page + 2);
}
@if (Model.Total > 0)
{
    <div class="pager">
        <span class="pager-info">@Model.Desde–@Model.Hasta de @Model.Total</span>
        @if (Model.TotalPages > 1)
        {
            <div class="pager-btns">
                <a class="pager-b @(Model.HasPrev ? "" : "off")" href="@(Model.HasPrev ? Link(Model.Page - 1) : "#")" aria-label="Anterior">←</a>
                @if (ini > 1)
                {
                    <a class="pager-b" href="@Link(1)">1</a>
                    @if (ini > 2) { <span class="pager-dots">…</span> }
                }
                @for (var p = ini; p <= fin; p++)
                {
                    <a class="pager-b @(p == Model.Page ? "on" : "")" href="@Link(p)">@p</a>
                }
                @if (fin < Model.TotalPages)
                {
                    @if (fin < Model.TotalPages - 1) { <span class="pager-dots">…</span> }
                    <a class="pager-b" href="@Link(Model.TotalPages)">@Model.TotalPages</a>
                }
                <a class="pager-b @(Model.HasNext ? "" : "off")" href="@(Model.HasNext ? Link(Model.Page + 1) : "#")" aria-label="Siguiente">→</a>
            </div>
        }
    </div>
}
