@page "{id:guid?}"
@model Diger.TramitesEstado.Web.Pages.Usuarios.EditorModel
@{
    ViewData["Title"] = Model.UsuarioId is null ? "Nuevo usuario" : "Editar usuario";
}

<div class="container" style="max-width:600px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:1.5rem">
        <a class="btns" asp-page="/Usuarios/Index" style="font-size:13px">← Volver</a>
        <h2 style="margin:0;font-size:18px;color:#0a2d6e">@ViewData["Title"]</h2>
    </div>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert-error">@Model.Error</div>
    }

    <form method="post" class="card">
        <div class="field">
            <label>Nombre completo <span style="color:#dc2626">*</span></label>
            <input asp-for="Nombre" placeholder="Nombre y apellidos" />
        </div>
        <div class="field">
            <label>Correo (login) <span style="color:#dc2626">*</span></label>
            <input asp-for="Correo" type="email" placeholder="usuario@diger.gob.hn" />
        </div>
        <div class="row2">
            <div class="field">
                <label>Rol</label>
                <select asp-for="Rol">
                    @foreach (var r in Model.Roles)
                    {
                        <option value="@r">@r</option>
                    }
                </select>
            </div>
            @if (Model.UsuarioId is null)
            {
                <div class="field">
                    <label>Contraseña inicial <span style="color:#dc2626">*</span></label>
                    <input asp-for="Password" type="password" autocomplete="new-password" placeholder="Mínimo 8 caracteres" />
                </div>
            }
            else
            {
                <div class="field">
                    <label>Estado</label>
                    <label class="chk" style="margin-top:8px">
                        <input asp-for="Activo" type="checkbox" />
                        <span>Usuario activo</span>
                    </label>
                </div>
            }
        </div>

        <div class="field" style="margin-top:.4rem">
            <label>Asignaciones (Alcance Jerárquico)</label>
            <p class="hint" style="margin:0 0 .6rem">
                Define a qué instituciones, áreas o unidades puede acceder este usuario. <strong>No aplica al Administrador</strong>.
            </p>
            <div style="border:1px solid #eef1f7;border-radius:10px;padding:.7rem;background:#fcfcfd">
                <table style="width:100%;border-collapse:collapse;margin-bottom:1rem" id="tblAsignaciones">
                    <thead>
                        <tr style="text-align:left;border-bottom:1px solid #eef1f7;font-size:12px;color:#6b7280">
                            <th style="padding-bottom:6px">Institución</th>
                            <th style="padding-bottom:6px">Área (Opcional)</th>
                            <th style="padding-bottom:6px">Unidad (Opcional)</th>
                            <th style="padding-bottom:6px;width:50px"></th>
                        </tr>
                    </thead>
                    <tbody id="tbodyAsignaciones"></tbody>
                </table>
                <button type="button" class="btns" style="padding:4px 10px;font-size:13px" onclick="addAsignacion()">+ Agregar Asignación</button>
            </div>
        </div>

        <script>
            const jerarquia = @Html.Raw(Model.JerarquiaJson);
            let asignaciones = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Asignaciones));
            if (!asignaciones) asignaciones = [];
            
            function renderAsignaciones() {
                const tbody = document.getElementById('tbodyAsignaciones');
                tbody.innerHTML = '';
                if(asignaciones.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" class="hint" style="text-align:center;padding:1rem">No hay asignaciones</td></tr>';
                    return;
                }
                
                asignaciones.forEach((asig, index) => {
                    const tr = document.createElement('tr');
                    tr.style.borderBottom = '1px solid #eef1f7';
                    
                    const tdInst = document.createElement('td');
                    tdInst.style.padding = '6px 4px';
                    let selInst = `<select name="Asignaciones[${index}].InstitucionId" class="form-select form-select-sm" style="width:100%;padding:4px;border:1px solid #ccc;border-radius:4px" required onchange="cambiarInstitucion(${index}, this.value)">`;
                    selInst += `<option value="">Seleccione...</option>`;
                    jerarquia.forEach(i => {
                        selInst += `<option value="${i.Id}" ${i.Id === asig.InstitucionId ? 'selected' : ''}>${i.Nombre}</option>`;
                    });
                    selInst += `</select>`;
                    tdInst.innerHTML = selInst;
                    
                    const instObj = jerarquia.find(i => i.Id === asig.InstitucionId);
                    const tdArea = document.createElement('td');
                    tdArea.style.padding = '6px 4px';
                    let selArea = `<select name="Asignaciones[${index}].AreaId" class="form-select form-select-sm" style="width:100%;padding:4px;border:1px solid #ccc;border-radius:4px" onchange="cambiarArea(${index}, this.value)">`;
                    selArea += `<option value="">-- Todas --</option>`;
                    if (instObj && instObj.Areas) {
                        instObj.Areas.forEach(a => {
                            selArea += `<option value="${a.Id}" ${a.Id === asig.AreaId ? 'selected' : ''}>${a.Nombre}</option>`;
                        });
                    }
                    selArea += `</select>`;
                    tdArea.innerHTML = selArea;

                    const areaObj = instObj && instObj.Areas ? instObj.Areas.find(a => a.Id === asig.AreaId) : null;
                    const tdUnidad = document.createElement('td');
                    tdUnidad.style.padding = '6px 4px';
                    let selUnidad = `<select name="Asignaciones[${index}].UnidadId" class="form-select form-select-sm" style="width:100%;padding:4px;border:1px solid #ccc;border-radius:4px">`;
                    selUnidad += `<option value="">-- Todas --</option>`;
                    if (areaObj && areaObj.Unidades) {
                        areaObj.Unidades.forEach(u => {
                            selUnidad += `<option value="${u.Id}" ${u.Id === asig.UnidadId ? 'selected' : ''}>${u.Nombre}</option>`;
                        });
                    }
                    selUnidad += `</select>`;
                    tdUnidad.innerHTML = selUnidad;

                    const tdBtn = document.createElement('td');
                    tdBtn.style.padding = '6px 4px';
                    tdBtn.style.textAlign = 'right';
                    tdBtn.innerHTML = `<button type="button" style="background:none;border:none;color:#dc2626;cursor:pointer;padding:4px" onclick="removeAsignacion(${index})">✕</button>`;

                    tr.appendChild(tdInst);
                    tr.appendChild(tdArea);
                    tr.appendChild(tdUnidad);
                    tr.appendChild(tdBtn);
                    tbody.appendChild(tr);
                });
            }

            function addAsignacion() {
                asignaciones.push({ InstitucionId: '', AreaId: '', UnidadId: '' });
                renderAsignaciones();
            }

            function removeAsignacion(index) {
                asignaciones.splice(index, 1);
                renderAsignaciones();
            }

            function cambiarInstitucion(index, instId) {
                asignaciones[index].InstitucionId = instId;
                asignaciones[index].AreaId = '';
                asignaciones[index].UnidadId = '';
                renderAsignaciones();
            }

            function cambiarArea(index, areaId) {
                asignaciones[index].AreaId = areaId;
                asignaciones[index].UnidadId = '';
                renderAsignaciones();
            }

            document.addEventListener('DOMContentLoaded', renderAsignaciones);
        </script>

        <div class="field" style="margin-top:.4rem">
            <label>Temas que atiende</label>
            <p class="hint" style="margin:0 0 .6rem">
                Como especialista, este usuario verá y podrá tomar los tickets de estos temas («Sus temas»).
                <a asp-page="/Tickets/Temas">Administrar temas y SLA →</a>
            </p>
            <div style="border:1px solid #eef1f7;border-radius:10px;padding:.4rem .9rem">
                @if (!Model.Temas.Any())
                {
                    <span class="hint">No hay temas definidos todavía.</span>
                }
                @foreach (var grupo in Model.Temas.GroupBy(t => t.Categoria ?? "Sin categoría").OrderBy(g => g.Key))
                {
                    <div class="tema-grupo" style="padding:.5rem 0;border-bottom:1px solid #f4f6fb">
                        <label class="chk" style="margin:0 0 .35rem;font-weight:700;color:#0a2d6e" title="Seleccionar toda la categoría">
                            <input type="checkbox" class="cat-all" onchange="toggleCat(this)" />
                            <span>@grupo.Key</span>
                        </label>
                        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:4px 14px;padding-left:1.5rem">
                            @foreach (var tm in grupo)
                            {
                                <label class="chk" style="margin:0@(tm.Activo ? "" : ";opacity:.55")">
                                    <input type="checkbox" class="tema-chk" name="TemaIds" value="@tm.Id" checked="@(Model.TemaIds.Contains(tm.Id))" onchange="syncCat(this)" />
                                    <span>@tm.Nombre@(tm.HorasResolucion > 0 ? $" · {tm.HorasResolucion} h" : "")@(tm.Activo ? "" : " (inactivo)")</span>
                                </label>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <script>
            function toggleCat(master) {
                master.closest('.tema-grupo').querySelectorAll('.tema-chk').forEach(function (c) { c.checked = master.checked; });
            }
            function syncCat(chk) { refreshGrupo(chk.closest('.tema-grupo')); }
            function refreshGrupo(g) {
                var all = g.querySelectorAll('.tema-chk'), sel = g.querySelectorAll('.tema-chk:checked'), m = g.querySelector('.cat-all');
                if (!m) return;
                m.checked = all.length > 0 && all.length === sel.length;
                m.indeterminate = sel.length > 0 && sel.length < all.length;
            }
            document.querySelectorAll('.tema-grupo').forEach(refreshGrupo);
        </script>

        <div class="nav">
            <a class="btns" asp-page="/Usuarios/Index">Cancelar</a>
            <button class="btnp" type="submit">@(Model.UsuarioId is null ? "Crear usuario" : "Guardar cambios")</button>
        </div>
    </form>

    @if (Model.UsuarioId is not null)
    {
        <form method="post" asp-page-handler="Restablecer" asp-route-id="@Model.UsuarioId" class="card" style="margin-top:1rem">
            <h3 class="sec-h">Restablecer contraseña</h3>
            <div class="field" style="margin-bottom:.7rem">
                <input asp-for="NuevaPassword" type="password" autocomplete="new-password" placeholder="Nueva contraseña (mínimo 8 caracteres)" />
            </div>
            <button class="btns" type="submit">Restablecer contraseña</button>
        </form>
    }
</div>
