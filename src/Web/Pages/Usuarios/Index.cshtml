@page
@model Diger.TramitesEstado.Web.Pages.Usuarios.IndexModel
@{
    ViewData["Title"] = "Usuarios";
    (string bg, string fg) RolColor(RolUsuario r) => r switch
    {
        RolUsuario.Administrador => ("#eeedfe", "#3c3489"),
        RolUsuario.Coordinador   => ("#e6f1fb", "#0c447c"),
        _                        => ("#e1f5ee", "#085041"),
    };
}

<div class="container" style="max-width:920px">
    @if (TempData["SuccessMsg"] is string ok)
    {
        <div class="alert-ok" style="margin-bottom:1rem">✅ @ok</div>
    }
    <div class="hist-header">
        <div>
            <h2>Usuarios</h2>
            <p>Gestión de usuarios internos del portal DIGER</p>
        </div>
        <a class="btnp" asp-page="/Usuarios/Editor">+ Nuevo usuario</a>
    </div>

    <table class="seg-table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Correo</th>
                <th>Rol</th>
                <th>Estado</th>
                <th style="width:1%"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model.Usuarios)
            {
                var rc = RolColor(u.Rol);
                <tr>
                    <td><a class="seg-inst" asp-page="/Usuarios/Editor" asp-route-id="@u.Id">@u.Nombre</a></td>
                    <td class="res-meta">@u.Correo</td>
                    <td><span style="background:@rc.bg;color:@rc.fg;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:700">@u.Rol</span></td>
                    <td>
                        @if (u.Activo)
                        {
                            <span style="color:#0f6e56;font-size:13px;font-weight:600">● Activo</span>
                        }
                        else
                        {
                            <span style="color:#94a3b8;font-size:13px;font-weight:600">○ Inactivo</span>
                        }
                    </td>
                    <td style="text-align:right">
                        <a class="btns" asp-page="/Usuarios/Editor" asp-route-id="@u.Id"
                           style="font-size:12.5px;padding:6px 12px">Editar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
