@page
@model Diger.TramitesEstado.Web.Pages.Usuarios.IndexModel
@{
    ViewData["Title"] = "Usuarios";
    string RolClase(RolUsuario r) => r switch
    {
        RolUsuario.Administrador => "admin",
        RolUsuario.Coordinador   => "coordinador",
        _                        => "default",
    };
}

<div class="container" style="max-width:920px">
    <partial name="_SuccessBanner" />
    <div class="hist-header">
        <div>
            <h2>Usuarios</h2>
            <p>Gestión de usuarios internos del portal DIGER</p>
        </div>
        <a class="btnp" asp-page="/Usuarios/Editor">+ Nuevo usuario</a>
    </div>

    <form method="get" class="lista-buscar">
        <input type="search" name="q" value="@Model.Q" placeholder="Buscar por nombre o correo…" />
        <button class="btns" type="submit">Buscar</button>
        @if (!string.IsNullOrEmpty(Model.Q)) { <a class="btns" asp-page="/Usuarios/Index">Limpiar</a> }
    </form>

    <table class="seg-table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Correo</th>
                <th>Rol</th>
                <th>Estado</th>
                <th style="width:1%"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model.Resultado.Items)
            {
                <tr>
                    <td><a class="seg-inst" asp-page="/Usuarios/Editor" asp-route-id="@u.Id">@u.Nombre</a></td>
                    <td class="res-meta">@u.Correo</td>
                    <td><span class="rol-badge @RolClase(u.Rol)" style="padding:2px 10px;font-size:12px">@u.Rol</span></td>
                    <td>
                        @if (u.Activo)
                        {
                            <span style="color:#0f6e56;font-size:13px;font-weight:600">● Activo</span>
                        }
                        else
                        {
                            <span style="color:#94a3b8;font-size:13px;font-weight:600">○ Inactivo</span>
                        }
                    </td>
                    <td style="text-align:right">
                        <a class="btns" asp-page="/Usuarios/Editor" asp-route-id="@u.Id"
                           style="font-size:12.5px;padding:6px 12px">Editar</a>
                    </td>
                </tr>
            }
            @if (Model.Resultado.Total == 0)
            {
                <tr><td colspan="5" class="res-meta" style="text-align:center;padding:1.5rem">Sin resultados.</td></tr>
            }
        </tbody>
    </table>

    <partial name="_Paginacion" model="new PaginacionVm(Model.Resultado.Page, Model.Resultado.TotalPages, Model.Resultado.Total, Model.Resultado.Desde, Model.Resultado.Hasta)" />
</div>
