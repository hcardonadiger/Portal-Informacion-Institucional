@page
@model Diger.TramitesEstado.Web.Pages.Accesos.IndexModel
@{
    ViewData["Title"] = "Control de accesos";
}

<div class="container" style="max-width:720px">
    @if (TempData["SuccessMsg"] is string ok)
    {
        <div class="alert-ok" style="margin-bottom:1rem">✅ @ok</div>
    }

    <div class="hist-header">
        <div>
            <h2>Control de accesos</h2>
            <p>Define qué opciones del portal puede ver y usar cada rol. El <strong>Administrador</strong> siempre tiene acceso completo.</p>
        </div>
    </div>

    <form method="post" class="card">
        <table class="seg-table">
            <thead>
                <tr>
                    <th>Opción / módulo</th>
                    <th style="width:120px;text-align:center">Administrador</th>
                    <th style="width:120px;text-align:center">Jefe Inst.</th>
                    <th style="width:120px;text-align:center">Jefe Área</th>
                    <th style="width:120px;text-align:center">Jefe Unidad</th>
                    <th style="width:120px;text-align:center">Empleado</th>
                    <th style="width:120px;text-align:center">Consultor</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Modulos)
                {
                    <tr>
                        <td><strong>@m.Nombre</strong></td>
                        <td style="text-align:center"><input type="checkbox" checked disabled title="El Administrador siempre tiene acceso" /></td>
                        <td style="text-align:center"><input type="checkbox" name="jefeInstitucion" value="@m.Clave" checked="@Model.JefeInstitucion.Contains(m.Clave)" /></td>
                        <td style="text-align:center"><input type="checkbox" name="jefeArea" value="@m.Clave" checked="@Model.JefeArea.Contains(m.Clave)" /></td>
                        <td style="text-align:center"><input type="checkbox" name="jefeUnidad" value="@m.Clave" checked="@Model.JefeUnidad.Contains(m.Clave)" /></td>
                        <td style="text-align:center"><input type="checkbox" name="empleado" value="@m.Clave" checked="@Model.Empleado.Contains(m.Clave)" /></td>
                        <td style="text-align:center"><input type="checkbox" name="consultor" value="@m.Clave" checked="@Model.Consultor.Contains(m.Clave)" /></td>
                    </tr>
                }
            </tbody>
        </table>
        <div style="margin-top:1rem;display:flex;gap:10px;align-items:center">
            <button class="btnp" type="submit">Guardar accesos</button>
            <span class="hint">Instituciones, Usuarios y este panel son exclusivos del Administrador.</span>
        </div>
    </form>
</div>
