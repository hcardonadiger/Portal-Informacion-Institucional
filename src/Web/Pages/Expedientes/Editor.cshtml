@page "{id:int?}"
@model Diger.TramitesEstado.Web.Pages.Expedientes.EditorModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@{
    ViewData["Title"] = Model.ExpId is null ? "Nuevo expediente" : "Editar expediente";
    var tokens = Xsrf.GetAndStoreTokens(HttpContext);
    var postUrl = Url.Page("/Expedientes/Editor", new { id = Model.ExpId });
    var contactosUrl = Url.Page("/Expedientes/Editor", "Contactos", new { id = Model.ExpId });
}
<link rel="stylesheet" href="~/css/expediente.css" asp-append-version="true" />

<div style="max-width:1280px;margin:0 auto;padding:.6rem 1rem;display:flex;gap:8px;align-items:center;justify-content:space-between">
    <a class="btns" asp-page="/Index">← Volver al historial</a>
    <div style="display:flex;gap:8px">
        @if (Model.ExpId is int segId)
        {
            <a class="btnp" asp-page="/Expedientes/Seguimiento" asp-route-id="@segId">Seguimiento de digitalización</a>
        }
        <button class="btns" type="button" onclick="window.print()">PDF</button>
    </div>
</div>

<div class="wrap">
  <aside class="sidebar">
    <div class="sb-hdr">Generales del expediente</div>
    <div class="sbi active" id="sb0" onclick="ir(0)"><div class="sbi-dot"></div>Apertura del expediente</div>
    <div class="sbi" id="sb2" onclick="ir(2)"><div class="sbi-dot"></div>Marco legal y documentación</div>
    <div class="sbi" id="sb4" onclick="ir(4)"><div class="sbi-dot"></div>Infraestructura SOL</div>
    <div class="sbi" id="sb6" onclick="ir(6)"><div class="sbi-dot"></div>Estado del expediente</div>

    <div class="sb-hdr" style="margin-top:.9rem">Por trámite</div>
    <div class="sbi" id="sb1" onclick="ir(1)"><div class="sbi-dot"></div>Ficha del trámite</div>
    <div class="sbi" id="sb3" onclick="ir(3)"><div class="sbi-dot"></div>Proceso actual</div>
    <div class="sbi" id="sb5" onclick="ir(5)"><div class="sbi-dot"></div>Modelo propuesto</div>
    <div class="sb-div"></div>
    <div class="sb-meta">
      <strong>Institución:</strong> <span id="sb-inst">—</span><br>
      <strong>Expediente:</strong> <span id="sb-codigo">—</span><br>
      <strong>Analista:</strong> <span id="sb-analista">—</span><br>
      <strong>Apertura:</strong> <span id="sb-fecha">—</span>
    </div>
    <div class="pb-wrap">
      <div class="pb-lbl"><span>Completado</span><span id="pb-pct">0%</span></div>
      <div class="pb"><div class="pb-fill" id="pb-fill" style="width:0%"></div></div>
    </div>
  </aside>

  <main class="main" id="form-main">

    <!-- ══ SECCIÓN 0: APERTURA ══ -->
    <div class="sec active" id="sec0">
      <div class="sec-title">Apertura del expediente <span style="font-size:9px;font-weight:400;color:#c0c8d8;letter-spacing:.05em;margin-left:6px">v4.2</span></div>

      <div class="card accent">
        <div class="ct">Identificación del expediente</div>
        <div class="g2">
          <div class="f">
            <label>Institución <span class="star">*</span></label>
            <select id="inst" oninput="actualizarMeta();generarCodigo()">
              <option value="">— Seleccione —</option>
              <option>BANHPROVI</option><option>CANATURH / IHT</option><option>CNBS</option>
              <option>CONATEL</option><option>CONSUCOOP</option><option>CONVIVIENDA</option>
              <option>COPECO</option><option>IHADFA</option><option>IHCINE</option>
              <option>IHTT</option><option>INPREMA</option><option>INPREUNAH</option>
              <option>IP</option><option>SAG</option><option>SECAPPH</option>
              <option>SEN</option><option>SERNA</option><option>SGJD</option>
              <option>SIT</option><option>SRECI</option>
            </select>
          </div>
          <div class="f">
            <label>Fecha de apertura <span class="star">*</span></label>
            <input type="date" id="fecha_apertura" oninput="actualizarMeta()">
          </div>
        </div>
        <div class="f">
          <label>Dirección de la institución (sede principal)</label>
          <input type="text" id="dir_sede" placeholder="Dirección física de la sede principal">
        </div>
        <div class="g2">
          <div class="f">
            <label>Analista DIGER responsable <span class="star">*</span></label>
            <input type="text" id="analista" placeholder="Nombre completo" oninput="actualizarMeta()">
          </div>
          <div class="f">
            <label>Código de expediente</label>
            <input type="text" id="codigo_exp" readonly placeholder="Se genera automáticamente">
            <span class="hint">Se genera al seleccionar la institución</span>
          </div>
        </div>
      </div>

      <div class="card accent">
        <div class="ct">Trámites a digitalizar</div>
        <div class="f" style="margin-bottom:1rem;max-width:340px">
          <label>¿Cuántos trámites hay en plataforma actualmente?</label>
          <input type="number" id="num_tramites_prod" min="0" value="0" oninput="actualizarCodsTramite()" placeholder="Ej: 6" style="max-width:160px">
          <span class="hint">Define el número de inicio para los códigos</span>
        </div>
        <div id="tramites-nombres-wrap"></div>
        <button type="button" class="btn-add" onclick="agregarTramiteApertura()">+ Agregar trámite</button>
        <span class="hint" style="display:block;margin-top:6px">Agregue tantos trámites como necesite; use ✕ para quitar uno.</span>
      </div>

      <div class="card">
        <div class="ct">Contacto institucional principal</div>
        <div class="f" style="margin-bottom:.9rem">
          <label>Buscar enlace en registros de asistencia</label>
          <select id="contacto-buscar" onchange="seleccionarContacto(this)">
            <option value="">— Cargando contactos… —</option>
          </select>
        </div>
        <div class="g3">
          <div class="f"><label>Nombre</label><input type="text" id="contacto_nombre" placeholder="Nombre completo"></div>
          <div class="f"><label>Cargo</label><input type="text" id="contacto_cargo" placeholder="Cargo / función"></div>
          <div class="f"><label>Correo</label><input type="email" id="contacto_correo" placeholder="correo@@inst.gob.hn"></div>
        </div>
        <div class="f" style="max-width:50%"><label>Teléfono de contacto</label><input type="text" id="contacto_tel" placeholder="+504 0000-0000"></div>
      </div>

      <div class="nav">
        <span style="font-size:12px;color:var(--muted)">* Campos obligatorios</span>
        <button class="btn btn-p" onclick="ir(1)">Siguiente →</button>
      </div>
    </div>

    <!-- ══ SECCIÓN 1: FICHA DEL TRÁMITE ══ -->
    <div class="sec" id="sec1">
      <div class="sec-title">Ficha del trámite</div>
      <div class="tram-tab-bar" id="tram-tabs-1" style="display:none"></div>
      <div id="fichas-wrap"></div>

      <div class="nav">
        <button class="btn btn-s" onclick="ir(0)">← Anterior</button>
        <button class="btn btn-p" onclick="ir(2)">Siguiente →</button>
      </div>
    </div>

    <!-- ══ SECCIÓN 2: MARCO LEGAL ══ -->
    <div class="sec" id="sec2">
      <div class="sec-title">Marco legal y documentación solicitada</div>
      <div class="tram-tab-bar" id="tram-tabs-2" style="display:none"></div>

      <div class="card accent">
        <div class="ct">Fundamentos legales</div>
        <p style="font-size:12px;color:var(--muted);margin-bottom:.9rem">Registre cada ley, reglamento, acuerdo o normativa que sustenta el trámite.</p>
        <table class="dtbl" id="tbl-legal">
          <thead><tr><th>#</th><th>Instrumento legal</th><th>Artículos aplicables</th><th>Observación</th><th style="width:36px"></th></tr></thead>
          <tbody id="legal-tbody"></tbody>
        </table>
        <button class="btn-add" onclick="agregarLegal()">+ Agregar fundamento</button>
      </div>

      <div class="card">
        <div class="ct">Documentación solicitada a la institución</div>
        <p style="font-size:12px;color:var(--muted);margin-bottom:.9rem">Registre cada documento solicitado. Adjunte el archivo o coloque el enlace de Google Drive.</p>
        <table class="dtbl" id="tbl-docs">
          <thead><tr><th>#</th><th>Documento</th><th>Tipo</th><th>Recibido</th><th>Fecha</th><th>Archivo / URL Drive</th><th style="width:36px"></th></tr></thead>
          <tbody id="docs-tbody"></tbody>
        </table>
        <button class="btn-add" onclick="agregarDocSolicitado()">+ Agregar documento</button>
      </div>

      <div class="card">
        <div class="ct">Observaciones sobre el marco documental</div>
        <div class="f"><textarea id="obs_legal" rows="3" placeholder="Normativas identificadas en campo, vacíos legales, documentos pendientes..."></textarea></div>
      </div>

      <div class="nav">
        <button class="btn btn-s" onclick="ir(1)">← Anterior</button>
        <button class="btn btn-p" onclick="ir(3)">Siguiente →</button>
      </div>
    </div>

    <!-- ══ SECCIÓN 3: PROCESO ACTUAL ══ -->
    <div class="sec" id="sec3">
      <div class="sec-title">Proceso actual del trámite</div>
      <div class="tram-tab-bar" id="tram-tabs-3" style="display:none"></div>

      <div class="card">
        <div class="ct">Métricas del trámite (línea base)</div>
        <div class="g4">
          <div class="f"><label>No. de funcionarios involucrados</label><input type="number" id="num_func" placeholder="Ej: 5" min="1" oninput="actualizarBVA()"></div>
          <div class="f"><label>No. de requisitos</label><input type="number" id="num_req" placeholder="Auto" min="0" readonly style="background:var(--gris-f);cursor:not-allowed;color:var(--muted)"></div>
          <div class="f"><label>Volumen anual (trámites/año)</label><input type="number" id="num_anio" placeholder="Ej: 300" min="0"></div>
          <div class="f"><label>Tiempo promedio observado</label><input type="text" id="tiempo_obs" placeholder="Ej: 5 días hábiles" oninput="actualizarBVA()"></div>
        </div>
        <div class="f" style="margin-top:.5rem"><label>Tiempo de resolución según normativa</label>
          <div class="tg" id="tg-tnorm">
            <label class="tp"><input type="radio" name="t_norm" value="1 día hábil"> 1 día</label>
            <label class="tp"><input type="radio" name="t_norm" value="3 días hábiles"> 3 días</label>
            <label class="tp"><input type="radio" name="t_norm" value="5 días hábiles"> 5 días</label>
            <label class="tp"><input type="radio" name="t_norm" value="10 días hábiles"> 10 días</label>
            <label class="tp"><input type="radio" name="t_norm" value="15 días hábiles"> 15 días</label>
            <label class="tp"><input type="radio" name="t_norm" value="20 días hábiles"> 20 días</label>
          </div>
        </div>
        <div class="f" style="margin-top:.85rem"><label>Descripción general del proceso actual</label><textarea id="desc_proceso" rows="4" placeholder="Narrativa del proceso desde que el ciudadano llega hasta que recibe el resultado..."></textarea></div>
      </div>

      <div class="card">
        <div class="ct">Documentos internos asociados al trámite</div>
        <p style="font-size:12px;color:var(--muted);margin-bottom:.9rem">Registre los documentos internos que maneja la institución para este trámite.</p>
        <table class="dtbl" id="tbl-docint">
          <thead><tr><th>#</th><th>Documento interno</th><th>Área que lo maneja</th><th>Observación</th><th style="width:36px"></th></tr></thead>
          <tbody id="docint-tbody"></tbody>
        </table>
        <button class="btn-add" onclick="agregarDocInterno()">+ Agregar documento</button>
        <div class="f" style="margin-top:.9rem"><label>Documentos adicionales identificados en campo</label><textarea id="docs_add" rows="2" placeholder="Documentos no contemplados que fueron encontrados durante el levantamiento presencial..."></textarea></div>
      </div>

      <div class="card accent">
        <div class="ct">Flujo real de actividades</div>
        <p style="font-size:12px;color:var(--muted);margin-bottom:.85rem">Registre cada paso tal como ocurre actualmente, etapa por etapa. Indique retornos cuando aplica.</p>
        <div class="flow-toggle">
          <button class="ftog active" id="ftog-actual-edit" onclick="toggleFlowView('actual','edit')">Editar</button>
          <button class="ftog" id="ftog-actual-diag" onclick="toggleFlowView('actual','diag')">Ver diagrama</button>
        </div>
        <div id="flujo-actual-list" class="flow-list"></div>
        <div id="flujo-actual-diag" style="display:none"></div>
        <div id="flujo-actual-btns" style="display:flex;gap:8px;margin-top:.9rem;flex-wrap:wrap">
          <button class="btn-add" style="margin-top:0" onclick="addFlowNode('actual','inicio')">▶ Inicio</button>
          <button class="btn-add" style="margin-top:0" onclick="addFlowNode('actual','paso')">+ Paso</button>
          <button class="btn-add" style="margin-top:0" onclick="addFlowNode('actual','decision')">Decisión</button>
          <button class="btn-add" style="margin-top:0" onclick="addFlowNode('actual','fin')">■ Fin</button>
        </div>
      </div>

      <div class="card">
        <div class="ct">Observaciones del proceso</div>
        <div class="f"><textarea id="obs_flujo" rows="3" placeholder="Cuellos de botella, variaciones, pasos no documentados, excepciones..."></textarea></div>
      </div>

      <div class="nav">
        <button class="btn btn-s" onclick="ir(2)">← Anterior</button>
        <button class="btn btn-p" onclick="ir(4)">Siguiente →</button>
      </div>
    </div>

    <!-- ══ SECCIÓN 4: INFRAESTRUCTURA SOL ══ -->
    <div class="sec" id="sec4">
      <div class="sec-title">Requerimientos mínimos de infraestructura SOL</div>
      <p style="font-size:12px;color:var(--muted);margin:-0.9rem 0 1.2rem">Evaluación de la institución frente a los requerimientos mínimos para alojar la plataforma SOL. Se completa una sola vez por expediente.</p>

      <div class="card accent">
        <div class="ct">Perfiles técnicos y transferencia de capacidades</div>
        <div class="f">
          <label>¿Cuenta con personal técnico capacitado?</label>
          <div class="tg" id="tg-personal">
            <label class="tp"><input type="radio" name="infra_personal" value="Sí"> Sí</label>
            <label class="tp"><input type="radio" name="infra_personal" value="No"> No</label>
            <label class="tp"><input type="radio" name="infra_personal" value="Parcialmente"> Parcialmente</label>
          </div>
        </div>
        <div class="f">
          <label>Perfiles disponibles o requeridos <span style="font-weight:400;color:var(--muted)">— marque cada perfil e indique nombre y correo institucional</span></label>
          <div id="perfiles-grid" class="perfiles-grid"></div>
        </div>
        <div class="g2">
          <div class="f"><label>Cantidad total de personal TI</label><input type="number" id="infra_personal_ti" placeholder="Ej: 8" min="0"></div>
          <div class="f"><label>Responsable técnico de SOL</label><input type="text" id="infra_resp_sol" placeholder="Nombre, cargo y contacto"></div>
        </div>
        <div class="f">
          <label>¿Requiere acompañamiento o talleres?</label>
          <div class="tg" id="tg-acomp">
            <label class="tp"><input type="radio" name="infra_acomp" value="Sí"> Sí</label>
            <label class="tp"><input type="radio" name="infra_acomp" value="No"> No</label>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="ct">Data center y condiciones operativas</div>
        <div class="g3">
          <div class="f"><label>Modalidad</label>
            <select id="infra_dc_modalidad"><option value="">— Seleccione —</option><option>Data center propio</option><option>Nube pública</option><option>Nube privada</option><option>Híbrido</option><option>Tercerizado / Hosting</option></select>
          </div>
          <div class="f"><label>Virtualización</label>
            <select id="infra_dc_virt" onchange="toggleVirtOtro()"><option value="">— Seleccione —</option><option>VMware</option><option>Hyper-V</option><option>Proxmox</option><option>KVM</option><option>Sin virtualización</option><option>Otro</option></select>
          </div>
          <div class="f"><label>Disponibilidad estimada</label><input type="text" id="infra_dc_disp" placeholder="Ej: 99.5%"></div>
        </div>
        <div class="f" id="virt-otro-wrap" style="display:none"><label>Especifique la virtualización <span class="star">*</span></label><input type="text" id="infra_dc_virt_otro" placeholder="Indique la solución de virtualización utilizada"></div>
        <div class="f">
          <label>Condiciones operativas</label>
          <div id="datacenter-grid"></div>
        </div>
        <div class="f"><label>Observaciones del data center</label><textarea id="infra_dc_obs" rows="2" placeholder="Detalles sobre las condiciones del data center..."></textarea></div>
      </div>

      <div class="card">
        <div class="ct">Requerimientos mínimos por servidor</div>
        <p style="font-size:12px;color:var(--muted);margin-bottom:1rem">Para cada requerimiento indique el estado de cumplimiento y registre la capacidad actual, brecha o evidencia.</p>
        <div id="infra-checklist"></div>
      </div>

      <div class="card">
        <div class="ct">Plan de adecuación</div>
        <div class="f"><textarea id="infra_plan" rows="4" placeholder="Acciones necesarias para alcanzar los requerimientos mínimos, presupuesto o fecha estimada..."></textarea></div>
      </div>

      <div class="nav">
        <button class="btn btn-s" onclick="ir(3)">← Anterior</button>
        <button class="btn btn-p" onclick="ir(5)">Siguiente →</button>
      </div>
    </div>

    <!-- ══ SECCIÓN 5: MODELO PROPUESTO ══ -->
    <div class="sec" id="sec5">
      <div class="sec-title">Modelo propuesto (trámite racionalizado)</div>
      <div class="tram-tab-bar" id="tram-tabs-5" style="display:none"></div>

      <!-- ANTES VS AHORA -->
      <div class="card accent">
        <div class="ct">Comparación antes vs. propuesto</div>
        <div class="g2" style="margin-bottom:1rem">
          <div class="f"><label>Funcionarios (versión digitalizada)</label><input type="number" id="func_dig" placeholder="Ej: 2" min="1" oninput="actualizarBVA()"></div>
          <div class="f"><label>Tiempo estimado digitalizado</label><input type="text" id="tiempo_dig" placeholder="Ej: 1 día hábil" oninput="actualizarBVA()"></div>
        </div>
        <div class="bva" id="bva-wrap">
          <div class="bva-col before">
            <div class="bva-lbl">Estado actual</div>
            <div class="bva-stat"><span>Funcionarios</span><span class="bva-num" id="bva-func-antes">—</span></div>
            <div class="bva-stat"><span>Pasos en flujo</span><span class="bva-num" id="bva-pasos-antes">—</span></div>
            <div class="bva-stat"><span>Tiempo</span><span id="bva-tiempo-antes" style="font-weight:700;color:var(--rojo)">—</span></div>
          </div>
          <div class="bva-mid">
            <span class="bva-arr">→</span>
            <span class="bva-pct" id="bva-pct-val">—</span>
            <span class="bva-pct-lbl" id="bva-pct-lbl">reducción</span>
          </div>
          <div class="bva-col after">
            <div class="bva-lbl">Versión propuesta</div>
            <div class="bva-stat"><span>Funcionarios</span><span class="bva-num" id="bva-func-prop">—</span></div>
            <div class="bva-stat"><span>Pasos en flujo</span><span class="bva-num" id="bva-pasos-prop">—</span></div>
            <div class="bva-stat"><span>Tiempo</span><span id="bva-tiempo-prop" style="font-weight:700;color:var(--verde)">—</span></div>
          </div>
        </div>
      </div>

      <!-- FLUJO PROPUESTO INTERACTIVO -->
      <div class="card">
        <div class="ct">Flujo propuesto</div>
        <p style="font-size:12px;color:var(--muted);margin-bottom:.85rem">Diseñe el proceso digitalizado paso a paso.</p>
        <div class="flow-toggle">
          <button class="ftog active" id="ftog-propuesto-edit" onclick="toggleFlowView('propuesto','edit')">Editar</button>
          <button class="ftog" id="ftog-propuesto-diag" onclick="toggleFlowView('propuesto','diag')">Ver diagrama</button>
        </div>
        <div id="flujo-propuesto-list" class="flow-list"></div>
        <div id="flujo-propuesto-diag" style="display:none"></div>
        <div id="flujo-propuesto-btns" style="display:flex;gap:8px;margin-top:.9rem;flex-wrap:wrap">
          <button class="btn-add" style="margin-top:0" onclick="addFlowNode('propuesto','inicio')">▶ Inicio</button>
          <button class="btn-add" style="margin-top:0" onclick="addFlowNode('propuesto','paso')">+ Paso</button>
          <button class="btn-add" style="margin-top:0" onclick="addFlowNode('propuesto','decision')">Decisión</button>
          <button class="btn-add" style="margin-top:0" onclick="addFlowNode('propuesto','fin')">■ Fin</button>
        </div>
      </div>

      <!-- REQUISITOS -->
      <div class="card">
        <div class="ct">Requisitos — acción propuesta</div>
        <p style="font-size:12px;color:var(--muted);margin-bottom:.9rem">Los requisitos se traen automáticamente de la <strong>Ficha del trámite</strong>. Para cada uno, defina la acción y su justificación.</p>
        <div id="modelo-reqs-wrap"></div>
      </div>

      <!-- RESUMEN DE REQUISITOS -->
      <div class="card" id="req-resumen-card">
        <div class="ct">Resumen de requisitos</div>
        <div id="req-resumen-wrap"><p style="font-size:12.5px;color:var(--muted)">Agregue requisitos en la tabla de arriba para ver el resumen aquí.</p></div>
      </div>

      <div class="card">
        <div class="ct">Observaciones del modelo</div>
        <div class="f"><textarea id="obs_modelo" rows="3" placeholder="Restricciones técnicas, dependencias, cambios normativos requeridos..."></textarea></div>
      </div>

      <div class="nav">
        <button class="btn btn-s" onclick="ir(4)">← Anterior</button>
        <button class="btn btn-p" onclick="ir(6)">Siguiente →</button>
      </div>
    </div>

    <!-- ══ SECCIÓN 6: ESTADO ══ -->
    <div class="sec" id="sec6">
      <div class="sec-title">Estado del expediente</div>

      <div class="card accent">
        <div class="ct">Estado general</div>
        <div class="f">
          <div class="tg" id="tg-estado-exp">
            <label class="tp"><input type="radio" name="estado_exp" value="En exploración"> En exploración</label>
            <label class="tp"><input type="radio" name="estado_exp" value="En levantamiento"> En levantamiento</label>
            <label class="tp"><input type="radio" name="estado_exp" value="En modelado"> En modelado</label>
            <label class="tp"><input type="radio" name="estado_exp" value="En validación"> En validación</label>
            <label class="tp on-v"><input type="radio" name="estado_exp" value="Cerrado" checked> ✓ Cerrado</label>
          </div>
        </div>
        <div class="f" style="margin-top:.85rem"><label>Observaciones generales</label><textarea id="obs_expediente" rows="3" placeholder="Resumen del avance, bloqueos actuales, próximos pasos..."></textarea></div>
      </div>

      <div class="card">
        <div class="ct">Estado del levantamiento</div>
        <div class="f">
          <div class="tg" id="tg-estado-lev">
            <label class="tp"><input type="radio" name="estado_lev" value="En proceso"> En proceso</label>
            <label class="tp"><input type="radio" name="estado_lev" value="Completo"> Completo</label>
            <label class="tp"><input type="radio" name="estado_lev" value="Pendiente de validar"> Pendiente de validar</label>
            <label class="tp"><input type="radio" name="estado_lev" value="Requiere revisita"> Requiere revisita</label>
          </div>
        </div>
        <div class="f" style="margin-top:.85rem"><label>Observaciones del levantamiento</label><textarea id="obs_levantamiento" rows="3" placeholder="Hallazgos de campo, pendientes, aspectos a validar o motivos de revisita..."></textarea></div>
      </div>

      <div class="card">
        <div class="ct">Estado por sección</div>
        <div style="border:1px solid var(--borde);border-radius:10px;overflow:hidden">
          <div class="estado-row" style="background:var(--azul-c);font-weight:700;font-size:11.5px;color:var(--azul-m)">
            <span>Sección</span><span style="text-align:center">Estado</span><span>Notas</span>
          </div>
          <div class="estado-row"><span class="estado-label">Apertura del expediente</span><select class="estado-sel" id="est-0" onchange="actualizarEstados()"><option>Pendiente</option><option>En progreso</option><option>Completo</option><option>Validado</option></select><input type="text" style="padding:6px 10px;border:1.5px solid var(--borde);border-radius:7px;font-size:12.5px;font-family:inherit;background:#fafbfd;width:100%" id="nota-0" placeholder="Nota..."></div>
          <div class="estado-row"><span class="estado-label">Ficha del trámite</span><select class="estado-sel" id="est-1" onchange="actualizarEstados()"><option>Pendiente</option><option>En progreso</option><option>Completo</option><option>Validado</option></select><input type="text" style="padding:6px 10px;border:1.5px solid var(--borde);border-radius:7px;font-size:12.5px;font-family:inherit;background:#fafbfd;width:100%" id="nota-1" placeholder="Nota..."></div>
          <div class="estado-row"><span class="estado-label">Marco legal y documentación</span><select class="estado-sel" id="est-2" onchange="actualizarEstados()"><option>Pendiente</option><option>En progreso</option><option>Completo</option><option>Validado</option></select><input type="text" style="padding:6px 10px;border:1.5px solid var(--borde);border-radius:7px;font-size:12.5px;font-family:inherit;background:#fafbfd;width:100%" id="nota-2" placeholder="Nota..."></div>
          <div class="estado-row"><span class="estado-label">Proceso actual</span><select class="estado-sel" id="est-3" onchange="actualizarEstados()"><option>Pendiente</option><option>En progreso</option><option>Completo</option><option>Validado</option></select><input type="text" style="padding:6px 10px;border:1.5px solid var(--borde);border-radius:7px;font-size:12.5px;font-family:inherit;background:#fafbfd;width:100%" id="nota-3" placeholder="Nota..."></div>
          <div class="estado-row"><span class="estado-label">Modelo propuesto</span><select class="estado-sel" id="est-5" onchange="actualizarEstados()"><option>Pendiente</option><option>En progreso</option><option>Completo</option><option>Validado</option></select><input type="text" style="padding:6px 10px;border:1.5px solid var(--borde);border-radius:7px;font-size:12.5px;font-family:inherit;background:#fafbfd;width:100%" id="nota-5" placeholder="Nota..."></div>
        </div>
      </div>

      <div class="card">
        <div class="ct">Validaciones y firma de cierre</div>
        <div class="g2">
          <div class="f"><label>Validado por (DIGER)</label><input type="text" id="validado_diger" placeholder="Nombre completo"></div>
          <div class="f"><label>Validado por (institución)</label><input type="text" id="validado_inst" placeholder="Nombre completo y cargo"></div>
        </div>
        <div class="g2">
          <div class="f"><label>Fecha de validación</label><input type="date" id="fecha_validacion"></div>
          <div class="f"><label>Número de acta</label><input type="text" id="num_acta" placeholder="Referencia del acta firmada"></div>
        </div>
      </div>

      <div class="nav">
        <button class="btn btn-s" onclick="ir(5)">← Anterior</button>
        @if (User.CanMutate())
        {
            <button class="btn btn-p" onclick="guardar()">💾 Guardar expediente</button>
        }
      </div>
    </div>

  </main>
</div>

@if (User.CanMutate())
{
    <button class="btn-save-float" type="button" onclick="guardar()">💾 Guardar</button>
}
<div class="toast" id="toast"></div>

@* ── Detalle de nodo de flujo (visor; ids consumidos por expediente.js → showNodeModal) ── *@
<div id="node-modal" onclick="closeNodeModal()"
     style="display:none;position:fixed;inset:0;background:rgba(10,45,110,.35);z-index:1000;align-items:center;justify-content:center;padding:1rem">
  <div onclick="event.stopPropagation()"
       style="background:#fff;border-radius:16px;max-width:440px;width:100%;box-shadow:0 24px 60px rgba(10,45,110,.25);overflow:hidden">
    <div style="display:flex;align-items:center;gap:12px;padding:1.1rem 1.3rem;border-bottom:1px solid #eef1f7">
      <span id="nm-badge" style="flex:none;width:30px;height:30px;border-radius:50%;background:#1455a4;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px">1</span>
      <div style="flex:1;min-width:0">
        <div id="nm-tipo" style="font-size:10px;font-weight:800;letter-spacing:.08em;color:#1455a4">PASO</div>
        <div id="nm-titulo" style="font-size:15px;font-weight:700;color:#0a2d6e">Paso</div>
      </div>
      <button type="button" onclick="closeNodeModal()" aria-label="Cerrar"
              style="flex:none;border:0;background:#f0f4fa;color:#64748b;width:28px;height:28px;border-radius:8px;cursor:pointer;font-size:15px">✕</button>
    </div>
    <div style="padding:1.1rem 1.3rem;display:flex;flex-direction:column;gap:.9rem">
      <div><div class="nm-lbl">Responsable</div><div id="nm-responsable" style="font-size:14px">—</div></div>
      <div><div class="nm-lbl">Tiempo observado</div><div id="nm-tiempo" style="font-size:14px">—</div></div>
      <div><div class="nm-lbl">Documento emitido</div><div id="nm-documento" style="font-size:14px">—</div></div>
      <div><div class="nm-lbl">Observación de campo</div><div id="nm-obs" style="font-size:14px">—</div></div>
    </div>
  </div>
</div>

@* ── Menú flotante "+" para agregar nodos (poblado por expediente.js con .fam-opt) ── *@
<div id="flow-add-menu"
     style="display:none;position:fixed;z-index:1001;background:#fff;border:1px solid #e2e8f0;border-radius:10px;box-shadow:0 12px 32px rgba(10,45,110,.18);padding:5px;min-width:140px"></div>

<style>
  .nm-lbl { font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:#94a3b8;margin-bottom:2px }
</style>

@section Scripts {
    <script>
        window.__EXPMETA__ = {
            id: @(Model.ExpId?.ToString() ?? "null"),
            postUrl: '@postUrl',
            token: '@tokens.RequestToken',
            indexUrl: '@Url.Page("/Index")',
            contactosUrl: '@contactosUrl'
        };
        @if (Model.ExpJson is not null)
        {
            <text>window.__EXP__ = @Html.Raw(Model.ExpJson);</text>
        }
    </script>
    <script src="~/js/expediente.js" asp-append-version="true"></script>
}
