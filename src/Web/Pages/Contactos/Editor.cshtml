@page "{id:int?}"
@model Diger.TramitesEstado.Web.Pages.Contactos.EditorModel
@{
    ViewData["Title"] = Model.ContactoId is null ? "Nuevo contacto" : "Editar contacto";
}

<div class="container" style="max-width:620px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:1.5rem">
        <a class="btns" asp-page="/Contactos/Index" style="font-size:13px">← Volver</a>
        <h2 style="margin:0;font-size:18px;color:#0a2d6e">@ViewData["Title"]</h2>
    </div>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert-error">@Model.Error</div>
    }

    <form method="post" class="card">
        <div asp-validation-summary="ModelOnly" class="alert-error"></div>

        <div class="row2">
            <div class="field">
                <label>Nombre completo <span style="color:#dc2626">*</span></label>
                <input asp-for="Nombre" placeholder="Nombre y apellidos" />
                <span asp-validation-for="Nombre" class="hint error"></span>
            </div>
            <div class="field">
                <label>Institución <span style="color:#dc2626">*</span></label>
                <select asp-for="InstitucionId">
                    <option value="">— Seleccione —</option>
                    @foreach (var i in Model.Instituciones)
                    {
                        <option value="@i.Id">@i.Nombre</option>
                    }
                </select>
                <span asp-validation-for="InstitucionId" class="hint error"></span>
            </div>
        </div>

        <div class="row2">
            <div class="field">
                <label>Área / Departamento</label>
                <select id="areaSel" onchange="toggleAreaOtro()">
                    <option value="">— Seleccione —</option>
                </select>
                <input type="hidden" asp-for="Area" id="areaVal" />
                <input id="areaOtro" style="display:none;margin-top:6px" placeholder="Escriba el área / departamento" oninput="syncAreaOtro()" />
            </div>
            <div class="field">
                <label>Cargo</label>
                <input asp-for="Cargo" placeholder="Cargo / función" />
            </div>
        </div>

        <div class="row2">
            <div class="field">
                <label>Teléfono</label>
                <input asp-for="Telefono" placeholder="+504 0000-0000" />
            </div>
            <div class="field">
                <label>Correo</label>
                <input asp-for="Correo" type="email" placeholder="correo@@institucion.gob.hn" />
                <span asp-validation-for="Correo" class="hint error"></span>
            </div>
        </div>

        <div class="field">
            <label>Notas</label>
            <textarea asp-for="Notas" placeholder="Notas adicionales…"></textarea>
        </div>

        <div class="nav">
            <a class="btns" asp-page="/Contactos/Index">Cancelar</a>
            <button class="btnp" type="submit">@(Model.ContactoId is null ? "Crear" : "Guardar cambios")</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var catalogAreas = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Areas.Select(a => new { instId = a.InstitucionId, nombre = a.Nombre })));

        function syncAreaOtro(){ document.getElementById('areaVal').value=document.getElementById('areaOtro').value; }

        function toggleAreaOtro(){
            var s=document.getElementById('areaSel'), o=document.getElementById('areaOtro'), v=document.getElementById('areaVal');
            if(!s) return;
            if(s.value==='__OTRO__'){ o.style.display='block'; v.value=o.value; }
            else { o.style.display='none'; v.value=s.value; }
        }

        function renderAreasForInst(instId, actualArea){
            var s=document.getElementById('areaSel'), o=document.getElementById('areaOtro'), v=document.getElementById('areaVal');
            if(!s) return;
            s.innerHTML = '';

            var matching = catalogAreas.filter(function(a){ return a.instId === instId; });

            var optZero = document.createElement('option');
            optZero.value = '';
            optZero.textContent = matching.length > 0 ? '— Seleccione Área —' : '— Área libre / Otros —';
            s.appendChild(optZero);

            matching.forEach(function(a){
                var opt = document.createElement('option');
                opt.value = a.nombre;
                opt.textContent = a.nombre;
                s.appendChild(opt);
            });

            var optOtros = document.createElement('option');
            optOtros.value = '__OTRO__';
            optOtros.textContent = 'Otros…';
            s.appendChild(optOtros);

            actualArea = actualArea || v.value || '';
            if(actualArea){
                var matchOpt = Array.from(s.options).find(function(op){ return op.value === actualArea; });
                if(matchOpt){
                    s.value = actualArea;
                } else {
                    s.value = '__OTRO__';
                    o.value = actualArea;
                }
            } else {
                s.value = '';
            }
            toggleAreaOtro();
        }

        document.addEventListener('DOMContentLoaded', function(){
            var instEl = document.querySelector('select[name="InstitucionId"]');
            if(instEl){
                instEl.addEventListener('change', function(){
                    renderAreasForInst(this.value);
                });
                renderAreasForInst(instEl.value, @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Area ?? "")));
            }
        });
    </script>
}
