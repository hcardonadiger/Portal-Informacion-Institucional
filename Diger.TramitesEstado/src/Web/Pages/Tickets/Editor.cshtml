@page "{id:int?}"
@model Diger.TramitesEstado.Web.Pages.Tickets.EditorModel
@{
    ViewData["Title"] = Model.TicketId is null ? "Nuevo ticket" : "Editar ticket";
}

<div class="container" style="max-width:760px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:1.5rem">
        <a class="btns" asp-page="/Tickets/Index" style="font-size:13px">← Volver</a>
        <h2 style="margin:0;font-size:18px;color:#0a2d6e">@ViewData["Title"]</h2>
    </div>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert-error">@Model.Error</div>
    }

    <form method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="alert-error"></div>

        <div class="card">
            <h3 class="sec-h">Incidencia</h3>
            <div class="field">
                <label>Título <span style="color:#dc2626">*</span></label>
                <input asp-for="Datos.Titulo" placeholder="Resumen breve del problema" />
            </div>
            <div class="field">
                <label>Descripción</label>
                <textarea asp-for="Datos.Descripcion" rows="4" placeholder="Detalle del inconveniente, pasos para reproducirlo, mensajes de error…"></textarea>
            </div>
            <div class="row2">
                <div class="field">
                    <label>Tema</label>
                    <select asp-for="Datos.TemaId">
                        <option value="">— Sin clasificar —</option>
                        @foreach (var grupo in Model.Temas.GroupBy(t => t.Categoria ?? "Sin categoría").OrderBy(g => g.Key))
                        {
                            <optgroup label="@grupo.Key">
                                @foreach (var tm in grupo)
                                {
                                    <option value="@tm.Id">@tm.Nombre@(tm.HorasResolucion > 0 ? $" (SLA {tm.HorasResolucion} h)" : "")</option>
                                }
                            </optgroup>
                        }
                    </select>
                </div>
                <div class="field">
                    <label>Prioridad</label>
                    <select asp-for="Datos.Prioridad">
                        @foreach (var p in Model.Prioridades)
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="card">
            <h3 class="sec-h">Vínculos (opcional)</h3>
            <div class="row2">
                <div class="field">
                    <label>Institución</label>
                    <select asp-for="Datos.InstitucionId" id="tk-inst" onchange="filtrarExpedientes()">
                        <option value="">— Ninguna —</option>
                        @foreach (var i in Model.Instituciones)
                        {
                            <option value="@i.Id">@i.Nombre</option>
                        }
                    </select>
                </div>
                <div class="field">
                    <label>Expediente</label>
                    <select asp-for="Datos.ExpedienteId" id="tk-exp" onchange="alElegirExpediente()">
                        <option value="" data-inst="">— Ninguno —</option>
                        @foreach (var e in Model.Expedientes)
                        {
                            <option value="@e.Id" data-inst="@e.InstitucionId">@e.Codigo — @e.Institucion</option>
                        }
                    </select>
                    <span class="hint" id="tk-exp-hint"></span>
                </div>
            </div>
        </div>

        <div class="card">
            <h3 class="sec-h">Trámites afectados</h3>
            <p class="hint" style="margin-top:-.3rem">Selecciona uno o más trámites del catálogo de la institución que se ven afectados por el incidente (Ctrl/⌘ + clic para varios).</p>
            <select name="Datos.TramiteIds" id="tk-tramites" multiple size="6" style="width:100%">
                @foreach (var t in Model.Tramites)
                {
                    <option value="@t.Id" data-inst="@t.InstitucionId" selected="@(Model.Datos.TramiteIds.Contains(t.Id))">@t.Nombre</option>
                }
            </select>
            <span class="hint" id="tk-tramites-hint"></span>
        </div>

        @if (Model.TicketId is null)
        {
            <div class="card">
                <h3 class="sec-h">Archivos adjuntos</h3>
                <p class="hint" style="margin-top:-.3rem">Capturas, documentos o registros que ayuden a diagnosticar (PDF, imágenes, Office, TXT/CSV/LOG, ZIP · máx. 10 MB c/u).</p>
                <input type="file" name="Archivos" multiple />
            </div>
        }

        <div class="card">
            <h3 class="sec-h">Reportado por</h3>
            @if (Model.TicketId is null)
            {
                <p class="res-meta" style="margin:0">Se registrará automáticamente con tu usuario:
                    <strong style="color:#0a2d6e">@Model.UsuarioActualNombre</strong>@(string.IsNullOrWhiteSpace(Model.UsuarioActualCorreo) ? "" : " · " + Model.UsuarioActualCorreo)
                </p>
            }
            else
            {
                <p class="res-meta" style="margin:0">
                    <strong style="color:#0a2d6e">@(string.IsNullOrWhiteSpace(Model.ReportanteView) ? "—" : Model.ReportanteView)</strong>
                    <span class="hint">(no editable)</span>
                </p>
            }
        </div>

        <div class="nav">
            <a class="btns" asp-page="/Tickets/Index">Cancelar</a>
            <button class="btnp" type="submit">@(Model.TicketId is null ? "Crear ticket" : "Guardar cambios")</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
      var inst = document.getElementById('tk-inst');
      var exp  = document.getElementById('tk-exp');
      var hint = document.getElementById('tk-exp-hint');
      var tram  = document.getElementById('tk-tramites');
      var thint = document.getElementById('tk-tramites-hint');

      // Muestra solo los expedientes de la institución seleccionada (o todos si no hay institución).
      function filtrarExpedientes() {
        var sel = inst.value;
        var visibles = 0;
        Array.prototype.forEach.call(exp.options, function (o) {
          if (o.value === '') { o.hidden = false; return; }   // "— Ninguno —"
          var match = !sel || o.getAttribute('data-inst') === sel;
          o.hidden = !match;
          if (match) visibles++;
        });
        // Si el expediente elegido ya no corresponde a la institución, se limpia.
        var actual = exp.selectedOptions[0];
        if (actual && actual.value !== '' && actual.hidden) exp.value = '';
        hint.textContent = sel && visibles === 0 ? 'Esta institución no tiene expedientes.' : '';
        filtrarTramites();
      }

      // Muestra solo los trámites del catálogo de la institución seleccionada.
      function filtrarTramites() {
        if (!tram) return;
        var sel = inst.value;
        var visibles = 0;
        Array.prototype.forEach.call(tram.options, function (o) {
          var match = sel && o.getAttribute('data-inst') === sel;
          o.hidden = !match;
          if (!match && o.selected) o.selected = false;   // deselecciona los que no aplican
          if (match) visibles++;
        });
        thint.textContent = !sel
          ? 'Selecciona una institución para ver sus trámites.'
          : (visibles === 0 ? 'Esta institución no tiene trámites en el catálogo.' : '');
      }

      // Al elegir un expediente, fija la institución a la de ese expediente (coherencia).
      function alElegirExpediente() {
        var o = exp.selectedOptions[0];
        var di = o ? o.getAttribute('data-inst') : '';
        if (o && o.value !== '' && di) { inst.value = di; filtrarExpedientes(); }
      }

      document.addEventListener('DOMContentLoaded', filtrarExpedientes);
    </script>
}
