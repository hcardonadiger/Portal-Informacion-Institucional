@page "{id:int?}"
@model Diger.TramitesEstado.Web.Pages.Reuniones.EditorModel
@{
    ViewData["Title"] = Model.ReunionId is null ? "Nueva reunión" : "Editar reunión";
    var d = Model.Datos;
}
<link rel="stylesheet" href="~/css/expediente.css" asp-append-version="true" />

<div style="max-width:1280px;margin:0 auto;padding:.6rem 1rem;display:flex;gap:8px;align-items:center;justify-content:space-between">
    <a class="btns" asp-page="/Reuniones/Index">← Volver</a>
    @if (Model.ReunionId is not null)
    {
        <a class="btns" asp-page="/Reuniones/Acta" asp-route-id="@Model.ReunionId">🖨 Ver acta</a>
    }
</div>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="container" style="max-width:1280px;padding-top:0"><div class="alert-error">@Model.Error</div></div>
}

<form method="post" enctype="multipart/form-data" id="reu-form">
<div class="wrap">
  <aside class="sidebar">
    <div class="sb-hdr">Pasos</div>
    <div class="sbi active" id="sb0" onclick="irPaso(0)"><div class="sbi-dot"></div>Generales</div>
    <div class="sbi" id="sb1" onclick="irPaso(1)"><div class="sbi-dot"></div>Asistencia</div>
    <div class="sbi" id="sb2" onclick="irPaso(2)"><div class="sbi-dot"></div>Memoria</div>
    <div class="sbi" id="sb3" onclick="irPaso(3)"><div class="sbi-dot"></div>Capacitación</div>
    <div class="sbi" id="sb4" onclick="irPaso(4)"><div class="sbi-dot"></div>Cierre</div>
  </aside>

  <main class="main">

    @* ══ PASO 0: GENERALES ══ *@
    <div class="sec active" id="sec0">
      <div class="sec-title">📅 Generales</div>
      <div class="card">
        <div class="field"><label>Título <span style="color:#dc2626">*</span></label>
          <input asp-for="Datos.Titulo" placeholder="Ej: Taller de inducción a la plataforma" /></div>
        <div class="row3">
          <div class="field"><label>Fecha</label><input asp-for="Datos.Fecha" type="date" /></div>
          <div class="field"><label>Hora</label><input asp-for="Datos.Hora" placeholder="09:00" /></div>
          <div class="field"><label>Duración</label><input asp-for="Datos.Duracion" placeholder="2 horas" /></div>
        </div>
        <div class="row3">
          <div class="field"><label>Modalidad</label>
            <select id="md-sel" onchange="otroSync('md')">
              <option value="">— Seleccione —</option>
              @foreach (var m in Model.Modalidades) { <option value="@m">@m</option> }
            </select>
            <input id="md-otro" placeholder="Especifique…" style="display:none;margin-top:6px" oninput="otroSync('md')" />
            <input type="hidden" asp-for="Datos.Modalidad" id="md-val" />
          </div>
          <div class="field"><label>Tipo</label>
            <select id="tp-sel" onchange="otroSync('tp')">
              <option value="">— Seleccione —</option>
              @foreach (var t in Model.Tipos) { <option value="@t">@t</option> }
            </select>
            <input id="tp-otro" placeholder="Especifique…" style="display:none;margin-top:6px" oninput="otroSync('tp')" />
            <input type="hidden" asp-for="Datos.Tipo" id="tp-val" />
          </div>
          <div class="field"><label>Institución beneficiaria</label>
            <select asp-for="Datos.InstitucionId">
              <option value="">— Ninguna / Otro —</option>
              @foreach (var i in Model.Instituciones) { <option value="@i.Id">@i.Nombre</option> }
            </select>
          </div>
        </div>
        <div class="row2" style="gap:14px">
          <div class="field"><label>Lugar</label><input asp-for="Datos.Lugar" placeholder="Sede, sala o enlace de videollamada" /></div>
          <div class="field">
            <label>Visibilidad</label>
            <select asp-for="Datos.Visibilidad">
              <option value="@VisibilidadReunion.Publica">🏛 Pública — mi institución</option>
              <option value="@VisibilidadReunion.Privada">🔒 Privada — solo yo</option>
            </select>
            <span class="hint">Las privadas solo las ve quien las crea.</span>
          </div>
        </div>
        <label class="chk"><input asp-for="Datos.EsCapacitacionPlataforma" id="es-cap" type="checkbox" onchange="toggleCap()" /><span>Es una capacitación de la plataforma</span></label>
      </div>
      <div class="nav"><span></span><button class="btn btn-p" type="button" onclick="siguiente()">Siguiente →</button></div>
    </div>

    @* ══ PASO 1: ASISTENCIA ══ *@
    <div class="sec" id="sec1">
      <div class="sec-title">👥 Asistencia</div>
      @if (Model.ReunionId is int ridA)
      {
        <div class="card" style="background:#f0f7ff;border:1px solid #d4e4fb">
          <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap">
            <div style="font-size:13px;color:#0a2d6e">
              <strong>Auto-registro disponible.</strong> Comparte un enlace/QR para que los participantes se registren desde su teléfono.
            </div>
            <a class="btnp" asp-page="/Reuniones/Asistencia" asp-route-id="@ridA">Enlace y QR de asistencia →</a>
          </div>
        </div>
      }
      <div class="card">
        <table class="seg-table edit-grid" id="asistentes-tbl">
          <thead><tr>
            <th style="width:22%">Nombre</th><th style="width:15%">Cargo</th><th style="width:15%">Institución</th>
            <th style="width:14%">Depto.</th><th style="width:20%">Correo</th><th style="width:14%">Teléfono</th><th style="width:40px"></th>
          </tr></thead>
          <tbody>
            @for (var i = 0; i < Model.Asistentes.Count; i++)
            {
              <tr>
                <td><input type="hidden" name="Asistentes.Index" value="@i" /><input name="Asistentes[@i].Nombre" value="@Model.Asistentes[i].Nombre" /></td>
                <td><input name="Asistentes[@i].Cargo" value="@Model.Asistentes[i].Cargo" /></td>
                <td><input name="Asistentes[@i].Institucion" value="@Model.Asistentes[i].Institucion" /></td>
                <td><input name="Asistentes[@i].Departamento" value="@Model.Asistentes[i].Departamento" /></td>
                <td><input name="Asistentes[@i].Correo" value="@Model.Asistentes[i].Correo" /></td>
                <td><input name="Asistentes[@i].Telefono" value="@Model.Asistentes[i].Telefono" /></td>
                <td>
                  <input type="hidden" name="Asistentes[@i].AutoRegistro" value="@Model.Asistentes[i].AutoRegistro.ToString().ToLowerInvariant()" />
                  @if (Model.Asistentes[i].RegistradoEl is DateTime re)
                  {
                    <input type="hidden" name="Asistentes[@i].RegistradoEl" value="@re.ToString("o")" />
                  }
                  <button type="button" class="hist-del" onclick="this.closest('tr').remove()">✕</button>
                </td>
              </tr>
            }
          </tbody>
        </table>
        <button type="button" class="btns" style="margin-top:.6rem" onclick="addAsistente()">+ Agregar asistente</button>
      </div>
      <div class="card">
        <div class="row3">
          <div class="field"><label>Convocados</label><input asp-for="Datos.Convocados" id="r-conv" type="number" min="0" oninput="calcPct()" /></div>
          <div class="field"><label>Nº asistentes</label><input asp-for="Datos.NumAsistentes" id="r-asis" type="number" min="0" oninput="calcPct()" />
            <span class="hint">Si registra asistentes arriba, se usa ese conteo.</span></div>
          <div class="field"><label>% asistencia <span class="hint">(automático)</span></label>
            <div class="val" id="r-pct-disp" style="font-size:22px;font-weight:800;color:#0a2d6e">0%</div>
            <input type="hidden" asp-for="Datos.PctAsistencia" id="r-pct-val" />
          </div>
        </div>
      </div>
      <div class="nav"><button class="btn btn-s" type="button" onclick="anterior()">← Anterior</button><button class="btn btn-p" type="button" onclick="siguiente()">Siguiente →</button></div>
    </div>

    @* ══ PASO 2: MEMORIA ══ *@
    <div class="sec" id="sec2">
      <div class="sec-title">📝 Memoria de la reunión</div>
      <div class="card">
        <div class="field"><label>Objetivo / agenda</label><textarea asp-for="Datos.ObjetivoAgenda" rows="3" placeholder="Propósito y puntos de agenda…"></textarea></div>
        <div class="field">
          <label>Desarrollo</label>
          <div class="rte-toolbar">
            <button type="button" onmousedown="event.preventDefault()" onclick="rteCmd('bold')" title="Negrita"><b>B</b></button>
            <button type="button" onmousedown="event.preventDefault()" onclick="rteCmd('italic')" title="Cursiva"><i>I</i></button>
            <button type="button" onmousedown="event.preventDefault()" onclick="rteCmd('underline')" title="Subrayado"><u>U</u></button>
            <button type="button" onmousedown="event.preventDefault()" onclick="rteCmd('insertUnorderedList')" title="Viñetas">• Lista</button>
            <button type="button" onmousedown="event.preventDefault()" onclick="rteCmd('insertOrderedList')" title="Numeración">1. Lista</button>
            <button type="button" onmousedown="event.preventDefault()" onclick="rteCmd('removeFormat')" title="Quitar formato">✗</button>
          </div>
          <div id="dev-rte" class="rte-body" contenteditable="true" data-placeholder="Resumen de lo tratado…" oninput="syncDev()"></div>
          <input type="hidden" asp-for="Datos.Desarrollo" id="dev-val" />
        </div>
      </div>
      <div class="card">
        <h3 class="sec-h">Acuerdos y seguimiento</h3>
        <table class="seg-table edit-grid" id="acuerdos-tbl">
          <thead><tr>
            <th style="width:28%">Compromiso</th>
            <th style="width:15%">Responsable</th>
            <th style="width:140px">Plazo</th>
            <th style="width:140px">Estado</th>
            <th>Nota de seguimiento</th>
            <th style="width:40px"></th>
          </tr></thead>
          <tbody>
            @for (var i = 0; i < Model.Acuerdos.Count; i++)
            {
              <tr>
                <td><input type="hidden" name="Acuerdos.Index" value="@i" /><input name="Acuerdos[@i].Compromiso" value="@Model.Acuerdos[i].Compromiso" /></td>
                <td><input name="Acuerdos[@i].Responsable" value="@Model.Acuerdos[i].Responsable" /></td>
                <td><input name="Acuerdos[@i].Plazo" type="date" value="@(Model.Acuerdos[i].Plazo?.ToString("yyyy-MM-dd"))" /></td>
                <td>
                  <select name="Acuerdos[@i].Estado">
                    @foreach (var e in CompromisoUi.Estados)
                    {
                      <option value="@e" selected="@(Model.Acuerdos[i].Estado == e)">@CompromisoUi.Label(e)</option>
                    }
                  </select>
                  <input type="hidden" name="Acuerdos[@i].FechaCumplimiento" value="@(Model.Acuerdos[i].FechaCumplimiento?.ToString("yyyy-MM-dd"))" />
                </td>
                <td><input name="Acuerdos[@i].NotaSeguimiento" value="@Model.Acuerdos[i].NotaSeguimiento" placeholder="Avance / observación…" /></td>
                <td><button type="button" class="hist-del" onclick="this.closest('tr').remove()">✕</button></td>
              </tr>
            }
          </tbody>
        </table>
        <button type="button" class="btns" style="margin-top:.6rem" onclick="addAcuerdo()">+ Agregar acuerdo</button>
        <p class="hint" style="margin-top:.4rem">El estado y la nota también se gestionan desde <a asp-page="/Reuniones/Compromisos">Seguimiento de compromisos</a>.</p>
      </div>
      <div class="card">
        <div class="field"><label>Compromisos <span class="hint">(uno por línea)</span></label><textarea asp-for="Datos.Compromisos" rows="3"></textarea></div>
      </div>
      <div class="nav"><button class="btn btn-s" type="button" onclick="anterior()">← Anterior</button><button class="btn btn-p" type="button" onclick="siguiente()">Siguiente →</button></div>
    </div>

    @* ══ PASO 3: CAPACITACIÓN ══ *@
    <div class="sec" id="sec3">
      <div class="sec-title">🎓 Detalle de capacitación</div>
      <div class="card">
        <div class="field"><label>Tema</label><input asp-for="Datos.Tema" /></div>
        <div class="field"><label>Objetivo de la capacitación</label><textarea asp-for="Datos.ObjetivoCap" rows="2"></textarea></div>
        <div class="field"><label>Contenido <span class="hint">(un punto por línea)</span></label><textarea asp-for="Datos.Contenido" rows="4"></textarea></div>
      </div>
      <div class="card">
        <h3 class="sec-h">Enlace institucional</h3>
        <div class="row2">
          <div class="field"><label>Nombre</label><input asp-for="Datos.EpNombre" /></div>
          <div class="field"><label>Cargo</label><input asp-for="Datos.EpCargo" /></div>
        </div>
        <div class="row2">
          <div class="field"><label>Correo</label><input asp-for="Datos.EpCorreo" type="email" /></div>
          <div class="field"><label>Teléfono</label><input asp-for="Datos.EpTel" /></div>
        </div>
      </div>
      <div class="card">
        <h3 class="sec-h">Facilitador DIGER</h3>
        <div class="row3">
          <div class="field"><label>Nombre</label><input asp-for="Datos.FacNombre" /></div>
          <div class="field"><label>Cargo</label><input asp-for="Datos.FacCargo" /></div>
          <div class="field"><label>Correo</label><input asp-for="Datos.FacCorreo" type="email" /></div>
        </div>
      </div>
      <div class="nav"><button class="btn btn-s" type="button" onclick="anterior()">← Anterior</button><button class="btn btn-p" type="button" onclick="siguiente()">Siguiente →</button></div>
    </div>

    @* ══ PASO 4: CIERRE ══ *@
    <div class="sec" id="sec4">
      <div class="sec-title">✅ Cierre</div>
      <div class="card">
        <div class="row2">
          <div class="field"><label>Satisfacción</label><input asp-for="Datos.Satisfaccion" placeholder="Ej: Alta / 4.5 de 5" /></div>
          <div class="field"><label>Validación DIGER</label><input asp-for="Datos.ValDiger" /></div>
        </div>
        <div class="field"><label>Validación institución</label><input asp-for="Datos.ValInst" /></div>
        <div class="field"><label>Documentos / recursos <span class="hint">(uno por línea)</span></label><textarea asp-for="Datos.DocsRecursos" rows="2"></textarea></div>
      </div>
      <div class="card">
        <h3 class="sec-h">Evidencia fotográfica</h3>
        <div class="row2">
          <div class="field"><label>Foto 1</label>
            <div class="foto-up">
              <img id="f1-img" class="@(string.IsNullOrEmpty(d.Foto1Url) ? "" : "has")" src="@d.Foto1Url" alt="" />
              <input type="file" name="Foto1File" accept="image/*" onchange="previewFoto(this,'f1-img')" />
            </div>
            <input asp-for="Datos.Foto1Desc" placeholder="Descripción foto 1" style="margin-top:6px" />
            <input type="hidden" asp-for="Datos.Foto1Url" />
          </div>
          <div class="field"><label>Foto 2</label>
            <div class="foto-up">
              <img id="f2-img" class="@(string.IsNullOrEmpty(d.Foto2Url) ? "" : "has")" src="@d.Foto2Url" alt="" />
              <input type="file" name="Foto2File" accept="image/*" onchange="previewFoto(this,'f2-img')" />
            </div>
            <input asp-for="Datos.Foto2Desc" placeholder="Descripción foto 2" style="margin-top:6px" />
            <input type="hidden" asp-for="Datos.Foto2Url" />
          </div>
        </div>
      </div>
      <div class="nav">
        <button class="btn btn-s" type="button" onclick="anterior()">← Anterior</button>
        <button class="btn btn-p" type="submit" onclick="syncTodo()">💾 @(Model.ReunionId is null ? "Crear reunión" : "Guardar cambios")</button>
      </div>
    </div>

  </main>
</div>
</form>

@section Scripts {
<script>
  var MODALIDADES = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Modalidades));
  var TIPOS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Tipos));
  var pasoActual = 0;

  function pasosVisibles() {
    var cap = document.getElementById('es-cap').checked;
    return cap ? [0,1,2,3,4] : [0,1,2,4];
  }
  function irPaso(n) {
    document.querySelectorAll('.sec').forEach(function(s){ s.classList.remove('active'); });
    document.querySelectorAll('.sbi').forEach(function(s){ s.classList.remove('active'); });
    document.getElementById('sec'+n).classList.add('active');
    document.getElementById('sb'+n).classList.add('active');
    pasoActual = n; window.scrollTo(0,0);
  }
  function siguiente(){ var v=pasosVisibles(), i=v.indexOf(pasoActual); if(i<v.length-1) irPaso(v[i+1]); }
  function anterior(){ var v=pasosVisibles(), i=v.indexOf(pasoActual); if(i>0) irPaso(v[i-1]); }
  function toggleCap(){
    var cap=document.getElementById('es-cap').checked;
    document.getElementById('sb3').style.display = cap ? '' : 'none';
    if(!cap && pasoActual===3) irPaso(2);
  }

  // Editor enriquecido
  function rteCmd(cmd){ document.getElementById('dev-rte').focus(); document.execCommand(cmd,false,null); syncDev(); }
  function syncDev(){ document.getElementById('dev-val').value = document.getElementById('dev-rte').innerHTML; }

  // % asistencia automático
  function calcPct(){
    var c=parseInt(document.getElementById('r-conv').value)||0;
    var a=parseInt(document.getElementById('r-asis').value)||0;
    var p = c>0 ? Math.round(a/c*100) : 0;
    document.getElementById('r-pct-disp').textContent = p+'%';
    document.getElementById('r-pct-val').value = p;
  }

  // Campos "Otro" (modalidad/tipo)
  function otroSync(k){
    var sel=document.getElementById(k+'-sel'), otro=document.getElementById(k+'-otro'), val=document.getElementById(k+'-val');
    if(sel.value==='Otro'){ otro.style.display=''; val.value = otro.value.trim(); }
    else { otro.style.display='none'; val.value = sel.value; }
  }
  function initOtro(k, lista, actual){
    var sel=document.getElementById(k+'-sel'), otro=document.getElementById(k+'-otro');
    actual = actual || '';
    if(actual && lista.indexOf(actual) < 0){ sel.value='Otro'; otro.value=actual; }
    else { sel.value=actual; }
    otroSync(k);
  }

  // Foto preview
  function previewFoto(input, imgId){
    var img=document.getElementById(imgId);
    if(input.files && input.files[0]){ img.src=URL.createObjectURL(input.files[0]); img.classList.add('has'); }
  }

  // Tablas dinámicas
  var aIdx=@Model.Asistentes.Count, kIdx=@Model.Acuerdos.Count;
  function addAsistente(){
    var i=aIdx++; var tr=document.createElement('tr');
    tr.innerHTML='<td><input type="hidden" name="Asistentes.Index" value="'+i+'" /><input name="Asistentes['+i+'].Nombre" /></td>'
      +'<td><input name="Asistentes['+i+'].Cargo" /></td><td><input name="Asistentes['+i+'].Institucion" /></td>'
      +'<td><input name="Asistentes['+i+'].Departamento" /></td>'
      +'<td><input name="Asistentes['+i+'].Correo" /></td><td><input name="Asistentes['+i+'].Telefono" /></td>'
      +'<td><input type="hidden" name="Asistentes['+i+'].AutoRegistro" value="false" /><button type="button" class="hist-del" onclick="this.closest(\'tr\').remove()">✕</button></td>';
    document.querySelector('#asistentes-tbl tbody').appendChild(tr);
  }
  function addAcuerdo(){
    var i=kIdx++; var tr=document.createElement('tr');
    var est='<select name="Acuerdos['+i+'].Estado">'
      +'<option value="Pendiente">Pendiente</option><option value="EnProgreso">En progreso</option>'
      +'<option value="Cumplido">Cumplido</option><option value="Reprogramado">Reprogramado</option>'
      +'<option value="Cancelado">Cancelado</option></select>'
      +'<input type="hidden" name="Acuerdos['+i+'].FechaCumplimiento" />';
    tr.innerHTML='<td><input type="hidden" name="Acuerdos.Index" value="'+i+'" /><input name="Acuerdos['+i+'].Compromiso" /></td>'
      +'<td><input name="Acuerdos['+i+'].Responsable" /></td><td><input name="Acuerdos['+i+'].Plazo" type="date" /></td>'
      +'<td>'+est+'</td>'
      +'<td><input name="Acuerdos['+i+'].NotaSeguimiento" placeholder="Avance / observación…" /></td>'
      +'<td><button type="button" class="hist-del" onclick="this.closest(\'tr\').remove()">✕</button></td>';
    document.querySelector('#acuerdos-tbl tbody').appendChild(tr);
  }

  function syncTodo(){ syncDev(); otroSync('md'); otroSync('tp'); }

  document.addEventListener('DOMContentLoaded', function(){
    document.getElementById('dev-rte').innerHTML = document.getElementById('dev-val').value || '';
    initOtro('md', MODALIDADES, @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.Modalidad ?? "")));
    initOtro('tp', TIPOS, @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.Tipo ?? "")));
    calcPct(); toggleCap(); irPaso(0);
  });
</script>
}
