@using Diger.TramitesEstado.Application.Accesos
@inject Diger.TramitesEstado.Web.Common.AccesoModulosService Acceso
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DIGER</title>
    <link rel="stylesheet" href="~/css/diger.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <header class="topnav">
            <div class="topnav-inner">
                <a class="topnav-brand" asp-page="/Tableros/Index">
                    <span class="topnav-logo">DG</span> Portal DIGER
                </a>
                <nav class="topnav-links">
                    @if (await Acceso.PuedeAsync(ModulosPortal.Tableros)) { <a asp-page="/Tableros/Index">Tableros</a> }
                    @if (await Acceso.PuedeAsync(ModulosPortal.Calendario)) { <a asp-page="/Calendario/Index">Calendario</a> }
                    @if (await Acceso.PuedeAsync(ModulosPortal.Expedientes)) { <a asp-page="/Index">Expedientes</a> }
                    @if (await Acceso.PuedeAsync(ModulosPortal.Reuniones))
                    {
                        <a asp-page="/Reuniones/Index">Reuniones</a>
                        <a asp-page="/Reuniones/Compromisos">Compromisos</a>
                    }
                    @if (await Acceso.PuedeAsync(ModulosPortal.Tickets)) { <a asp-page="/Tickets/Index">Tickets</a> }
                    @if (await Acceso.PuedeAsync(ModulosPortal.Contactos)) { <a asp-page="/Contactos/Index">Contactos</a> }
                    @if (Acceso.EsAdministrador)
                    {
                        <a asp-page="/Instituciones/Index">Instituciones</a>
                        <a asp-page="/Usuarios/Index">Usuarios</a>
                        <a asp-page="/Accesos/Index">Accesos</a>
                    }
                </nav>
                <div class="topnav-user">
                    <span class="topnav-name">@User.Identity!.Name</span>
                    <span class="topnav-rol">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</span>
                    <form method="post" asp-page="/Cuenta/Logout" style="display:inline">
                        <button type="submit" class="topnav-logout" title="Cerrar sesión">Salir</button>
                    </form>
                </div>
            </div>
        </header>
    }
    @RenderBody()
    <script src="~/js/diger.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
