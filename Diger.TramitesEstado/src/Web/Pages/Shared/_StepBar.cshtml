@model int
@* paso activo: 1, 2 o 3 *@

<div class="step-bar">
    @for (int i = 1; i <= 3; i++)
    {
        string[] labels = ["Información General", "Trámites", "Envío"];
        string cls = i < Model ? "step-item done"
                   : i == Model ? "step-item active"
                   : "step-item";
        <div class="@cls">
            <div class="step-circle">
                @if (i < Model) { <span>✓</span> } else { <span>@i</span> }
            </div>
            <div class="step-label">@labels[i - 1]</div>
        </div>
    }
</div>
